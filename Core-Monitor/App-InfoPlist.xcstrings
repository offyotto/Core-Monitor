    "NSLocationWhenInUseUsageDescription": {
      "comment": "Privacy - Location When In Use Usage Description",
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor gebruik jou ligging vir die opsionele Touch Bar weeritem."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor የእርስዎን መገኛ ለአማራጭ Touch Bar የአየር ሁኔታ ነገር ይጠቀማል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم Core-Monitor موقعك لعنصر الطقس الاختياري Touch Bar."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor isteğe bağlı Touch Bar hava elementi üçün məkanınızdan istifadə edir."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor выкарыстоўвае ваша месцазнаходжанне для дадатковага элемента надвор'я Touch Bar."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor използва вашето местоположение за незадължителния елемент за времето Touch Bar."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor ঐচ্ছিক Touch Bar আবহাওয়া আইটেমের জন্য আপনার অবস্থান ব্যবহার করে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor koristi vašu lokaciju za opcionu vremensku stavku Touch Bar."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor utilitza la vostra ubicació per a l'element meteorològic opcional Touch Bar."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gigamit sa Core-Monitor ang imong lokasyon para sa opsyonal nga butang sa panahon nga Touch Bar."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor usa a vostra situazione per l'elementu meteorologicu opcional Touch Bar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor používá vaši polohu pro volitelnou položku počasí Touch Bar."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae Core-Monitor yn defnyddio'ch lleoliad ar gyfer yr eitem tywydd Touch Bar dewisol."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor bruger din placering til det valgfrie Touch Bar vejrelement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor verwendet Ihren Standort für das optionale Wetterelement Touch Bar."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Core-Monitor χρησιμοποιεί την τοποθεσία σας για το προαιρετικό στοιχείο καιρού Touch Bar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uzas vian lokon por la laŭvola Touch Bar veteraĵo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor utiliza su ubicación para el elemento meteorológico opcional Touch Bar."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor kasutab teie asukohta valikulise Touch Bar ilmastiku jaoks."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor zure kokapena erabiltzen du aukerako Touch Bar eguraldi elementurako."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor از موقعیت مکانی شما برای گزینه آب و هوای اختیاری Touch Bar استفاده می کند."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor käyttää sijaintiasi valinnaisen Touch Bar säätuotteen luomiseen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ginagamit ng Core-Monitor ang iyong lokasyon para sa opsyonal na item ng panahon na Touch Bar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor utilise votre emplacement pour l'élément météo optionnel Touch Bar."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor brûkt jo lokaasje foar it opsjonele Touch Bar waar item."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Úsáideann Core-Monitor do shuíomh don mhír roghnach aimsire Touch Bar."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Bidh Core-Monitor a’ cleachdadh d’ àite airson an rud sìde roghainneil Touch Bar."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor usa a túa localización para o elemento meteorolóxico opcional Touch Bar."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor uses your location for the optional Touch Bar weather item."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor વૈકલ્પિક Touch Bar હવામાન આઇટમ માટે તમારા સ્થાનનો ઉપયોગ કરે છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor yana amfani da wurin ku don zaɓin yanayin Touch Bar na zaɓi."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoʻohana ʻo Core-Monitor i kou wahi no ka mea koho Touch Bar."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor משתמש במיקום שלך עבור פריט מזג האוויר האופציונלי Touch Bar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor वैकल्पिक Touch Bar मौसम आइटम के लिए आपके स्थान का उपयोग करता है।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor siv koj qhov chaw nyob rau qhov xaiv Touch Bar huab cua."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor koristi vašu lokaciju za dodatnu stavku vremenske prognoze Touch Bar."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Core-Monitor sèvi ak kote w genyen pou atik metewolojik Touch Bar opsyonèl."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Core-Monitor az Ön tartózkodási helyét használja az opcionális Touch Bar időjárásjelzőhöz."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
