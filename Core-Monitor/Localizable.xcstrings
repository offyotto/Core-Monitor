    "System controls enable adjusting volume, screen brightness, and launch-at-login behavior.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelselkontroles maak dit moontlik om volume, skermhelderheid en begin-by-aanmelding-gedrag aan te pas."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የስርዓት ቁጥጥሮች የድምጽ መጠን ማስተካከል፣ የስክሪን ብሩህነት እና በመግቢያ መግቢያ ባህሪን ማስተካከልን ያነቃሉ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتيح عناصر التحكم في النظام ضبط مستوى الصوت وسطوع الشاشة وسلوك التشغيل عند تسجيل الدخول."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem nəzarətləri səs səviyyəsini, ekran parlaqlığını və giriş zamanı işə salınma davranışını tənzimləməyə imkan verir."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Сістэмныя элементы кіравання дазваляюць рэгуляваць гучнасць, яркасць экрана і паводзіны запуску пры ўваходзе."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Системните контроли позволяват регулиране на силата на звука, яркостта на екрана и поведението при стартиране при влизане."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্টেম কন্ট্রোল ভলিউম, স্ক্রিনের উজ্জ্বলতা এবং লঞ্চ-এ-লগইন আচরণ সামঞ্জস্য করতে সক্ষম করে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemske kontrole omogućavaju podešavanje jačine zvuka, svjetline ekrana i ponašanja prilikom pokretanja."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els controls del sistema permeten ajustar el volum, la brillantor de la pantalla i el comportament d'inici de sessió."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang mga kontrol sa sistema makahimo sa pag-adjust sa volume, kahayag sa screen, ug paglansad-sa-login nga kinaiya."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "I cuntrolli di u sistema permettenu di aghjustà u voluminu, a luminosità di u screnu, è u cumpurtamentu di lanciamentu à u login."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Systémové ovládací prvky umožňují upravit hlasitost, jas obrazovky a chování při spuštění při přihlášení."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae rheolaethau system yn galluogi addasu cyfaint, disgleirdeb sgrin, ac ymddygiad lansio wrth fewngofnodi."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemkontroller gør det muligt at justere lydstyrken, skærmens lysstyrke og start-ved-login-adfærd."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemsteuerungen ermöglichen die Anpassung der Lautstärke, der Bildschirmhelligkeit und des Startverhaltens beim Anmelden."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα χειριστήρια συστήματος επιτρέπουν τη ρύθμιση της έντασης ήχου, της φωτεινότητας της οθόνης και της συμπεριφοράς εκκίνησης κατά τη σύνδεση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemaj kontroloj ebligas ĝustigi volumon, ekranan brilon kaj lanĉon ĉe ensaluto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los controles del sistema permiten ajustar el volumen, el brillo de la pantalla y el comportamiento de inicio de sesión."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Süsteemi juhtnupud võimaldavad reguleerida helitugevust, ekraani heledust ja sisselogimisel käivitamise käitumist."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemaren kontrolek bolumena, pantailaren distira eta saioa hasteko portaera doitzea ahalbidetzen dute."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "کنترل‌های سیستم تنظیم صدا، روشنایی صفحه و رفتار راه‌اندازی هنگام ورود را فعال می‌کنند."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestelmän ohjaimilla voidaan säätää äänenvoimakkuutta, näytön kirkkautta ja käynnistystä sisäänkirjautumisen yhteydessä."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang mga kontrol ng system ay nagbibigay-daan sa pagsasaayos ng volume, liwanag ng screen, at pag-uugali sa paglunsad sa pag-login."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les commandes du système permettent de régler le volume, la luminosité de l'écran et le comportement de lancement à la connexion."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Systeemkontrôles kinne it oanpassen fan folume, skermhelderheid en launch-by-login gedrach ynskeakelje."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuireann rialuithe córais ar chumas toirte, gile an scáileáin, agus iompar seoladh-ag-logáil isteach a choigeartú."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Tha smachdan siostaim a’ comasachadh tomhas-lìonaidh, soilleireachd sgrion, agus giùlan cur air bhog-aig-logadh a-steach atharrachadh."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Os controis do sistema permiten axustar o volume, o brillo da pantalla e o comportamento ao iniciar sesión."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સિસ્ટમ નિયંત્રણો વોલ્યુમ, સ્ક્રીન બ્રાઇટનેસ અને લોંચ-એટ-લોગિન વર્તનને સમાયોજિત કરવા સક્ષમ કરે છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikon tsarin yana ba da damar daidaita ƙarar, hasken allo, da halayyar ƙaddamarwa-a-shigo."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiki i nā mana ʻōnaehana ke hoʻololi i ka leo, ka ʻālohilohi o ka pale, a me ka hana hoʻomaka-ma-login."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בקרות המערכת מאפשרות כוונון עוצמת הקול, בהירות המסך והתנהגות הפעלה בעת הכניסה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम नियंत्रण वॉल्यूम, स्क्रीन चमक और लॉन्च-एट-लॉगिन व्यवहार को समायोजित करने में सक्षम बनाता है।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Lub kaw lus tswj tau pab kho qhov ntim, qhov ci ci ntawm lub vijtsam, thiab tus cwj pwm tso tawm-ntawm-login."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrole sustava omogućuju podešavanje glasnoće, svjetline zaslona i ponašanja pri pokretanju pri prijavi."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontwòl sistèm yo pèmèt ajiste volim, klète ekran an, ak konpòtman lanse nan koneksyon."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A rendszervezérlők lehetővé teszik a hangerő, a képernyő fényerejének és az indítás bejelentkezéskor viselkedésének beállítását."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Համակարգի կառավարումը թույլ է տալիս կարգավորել ձայնի ձայնը, էկրանի պայծառությունը և մուտքի գործարկման պահվածքը:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrol sistem memungkinkan penyesuaian volume, kecerahan layar, dan perilaku peluncuran saat masuk."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Njikwa sistemụ na-enyere aka ịhazigharị olu, nchapụta ihuenyo, yana omume mmalite na nbanye."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Kerfisstýringar gera kleift að stilla hljóðstyrk, birtustig skjásins og hegðun við ræsingu við innskráningu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I controlli di sistema consentono di regolare il volume, la luminosità dello schermo e il comportamento di avvio all'accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム コントロールを使用すると、音量、画面の明るさ、ログイン時の起動動作を調整できます。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrol sistem mbisakake nyetel volume, padhange layar, lan prilaku mbukak-ing-login."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "სისტემის კონტროლი იძლევა ხმის, ეკრანის სიკაშკაშის და შესვლისას ქცევის რეგულირებას."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жүйені басқару элементтері дыбыс деңгейін, экран жарықтығын және кіру кезінде іске қосу әрекетін реттеуге мүмкіндік береді."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ការគ្រប់គ្រងប្រព័ន្ធបើកការលៃតម្រូវកម្រិតសំឡេង ពន្លឺអេក្រង់ និងឥរិយាបថនៃការបើកដំណើរការនៅពេលចូល។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಿಸ್ಟಮ್ ನಿಯಂತ್ರಣಗಳು ಪರಿಮಾಣ, ಪರದೆಯ ಹೊಳಪು ಮತ್ತು ಲಾಂಚ್-ಆಟ್-ಲಾಗಿನ್ ನಡವಳಿಕೆಯನ್ನು ಸರಿಹೊಂದಿಸುವುದನ್ನು ಸಕ್ರಿಯಗೊಳಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 컨트롤을 사용하면 볼륨, 화면 밝기 및 로그인 시 실행 동작을 조정할 수 있습니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrolên pergalê verastkirina deng, ronahiya ekranê, û tevgera destpêkirina têketinê çalak dike."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Системанын башкаруу элементтери үнүн, экрандын жарыктыгын жана кирүү учурундагы кыймыл-аракетти жөнгө салат."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Systema controllata dabunt volumen accommodans, splendorem velum, et mores launch-at-login."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "System Kontrollen erméiglechen d'Astellung vum Volume, d'Hellegkeet vum Bildschierm a Start-um-Login Verhalen."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ການຄວບຄຸມລະບົບເຮັດໃຫ້ການປັບລະດັບສຽງ, ຄວາມສະຫວ່າງຂອງຫນ້າຈໍ, ແລະພຶດຕິກໍາການເປີດຕົວໃນເວລາເຂົ້າສູ່ລະບົບ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemos valdikliai leidžia reguliuoti garsumą, ekrano ryškumą ir paleidimą prisijungus."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistēmas vadīklas ļauj pielāgot skaļumu, ekrāna spilgtumu un palaišanas darbību pieteikšanās laikā."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ny fanaraha-maso ny rafitra dia ahafahana manitsy ny habe, ny famirapiratry ny efijery ary ny fihetsika manomboka amin'ny fidirana."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ka taea e nga mana o te punaha te whakatika i te rōrahi, te kanapa o te mata, me te whanonga whakarewa-i-takiuru."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Системските контроли овозможуваат прилагодување на јачината на звукот, осветленоста на екранот и однесувањето при стартување при најавување."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സിസ്റ്റം നിയന്ത്രണങ്ങൾ വോളിയം ക്രമീകരിക്കൽ, സ്‌ക്രീൻ തെളിച്ചം, ലോഞ്ച്-അറ്റ്-ലോഗിൻ പെരുമാറ്റം എന്നിവ പ്രവർത്തനക്ഷമമാക്കുന്നു."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Системийн удирдлага нь дууны хэмжээ, дэлгэцийн тод байдал, нэвтрэх үед ажиллах горимыг тохируулах боломжийг олгодог."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम नियंत्रणे व्हॉल्यूम, स्क्रीन ब्राइटनेस आणि लॉन्च-एट-लॉगिन वर्तन समायोजित करण्यास सक्षम करतात."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kawalan sistem membolehkan melaraskan kelantangan, kecerahan skrin dan tingkah laku pelancaran semasa log masuk."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Il-kontrolli tas-sistema jippermettu l-aġġustament tal-volum, il-luminożità tal-iskrin, u l-imġiba tat-tnedija mal-login."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "စနစ်ထိန်းချုပ်မှုများသည် အသံအတိုးအကျယ်၊ ဖန်သားပြင်အလင်းအမှောင်ကို ချိန်ညှိခြင်းနှင့် စတင်သည့်အချိန်၌ အကောင့်ဝင်ခြင်းအပြုအမူတို့ကို ဖွင့်ပေးသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemkontroller gjør det mulig å justere volum, lysstyrke på skjermen og oppførsel ved start ved pålogging."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रणाली नियन्त्रणहरूले भोल्युम, स्क्रिनको चमक, र लन्च-एट-लगइन व्यवहार समायोजन सक्षम गर्दछ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Systeembedieningen maken het aanpassen van het volume, de schermhelderheid en het gedrag bij het opstarten bij inloggen mogelijk."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuwongolera kwamakina kumathandizira kusintha kuchuluka kwa voliyumu, kuwala kwa skrini, ndi machitidwe oyambitsa kulowa."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸਿਸਟਮ ਨਿਯੰਤਰਣ ਵਾਲੀਅਮ, ਸਕ੍ਰੀਨ ਚਮਕ, ਅਤੇ ਲਾਂਚ-ਤੇ-ਲੌਗਇਨ ਵਿਵਹਾਰ ਨੂੰ ਅਨੁਕੂਲ ਕਰਨ ਨੂੰ ਸਮਰੱਥ ਬਣਾਉਂਦੇ ਹਨ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elementy sterujące systemu umożliwiają regulację głośności, jasności ekranu i zachowania podczas logowania."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د سیسټم کنټرولونه د حجم تنظیمولو، د سکرین روښانتیا، او د پیل په وخت کې د ننوتلو چلند فعالوي."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os controles do sistema permitem ajustar o volume, o brilho da tela e o comportamento de inicialização no login."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Comenzile sistemului permit reglarea volumului, a luminozității ecranului și a comportamentului de lansare la conectare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Системные элементы управления позволяют регулировать громкость, яркость экрана и поведение запуска при входе в систему."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٽم ڪنٽرول حجم کي ترتيب ڏيڻ، اسڪرين جي چمڪ، ۽ لانچ-تي-لاگ ان رويي کي فعال ڪن ٿا."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "පද්ධති පාලන මඟින් පරිමාව, තිරයේ දීප්තිය සහ දියත් කිරීමේ දී-පිවිසීමේ හැසිරීම සීරුමාරු කිරීම සබල කරයි."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Systémové ovládacie prvky umožňujú upraviť hlasitosť, jas obrazovky a správanie pri spustení pri prihlásení."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemske kontrole omogočajo prilagajanje glasnosti, svetlosti zaslona in obnašanja pri zagonu ob prijavi."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Fa'atonu faiga e mafai ai ona fetu'una'i le leo, pupula o lau, ma le fa'alauiloa-i-login amioga."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvidzoreso zveSitimu zvinogonesa kugadzirisa vhoriyamu, kupenya kwescreen, uye kutanga-pa-kupinda maitiro."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Koontaroolada nidaamku waxay awood u siinayaan hagaajinta mugga, dhalaalka shaashadda, iyo habdhaqanka soo-gelidda."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrollet e sistemit mundësojnë rregullimin e volumit, ndriçimin e ekranit dhe sjelljen e nisjes në hyrje."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "System controls enable adjusting volume, screen brightness, and launch-at-login behavior."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Litaolo tsa sistimi li thusa ho lokisa molumo, khanya ea skrini, le boitšoaro ba ho qala ha u kena."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Kadali sistem ngaktifkeun nyaluyukeun polumeu, kacaangan layar, sareng paripolah peluncuran-di-asup."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemkontroller möjliggör justering av volym, skärmens ljusstyrka och beteende vid start vid inloggning."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Vidhibiti vya mfumo huwezesha kurekebisha sauti, mwangaza wa skrini na tabia ya kuzindua kuingia."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சிஸ்டம் கட்டுப்பாடுகள், ஒலியளவு, திரைப் பிரகாசம் மற்றும் லான்ச்-ஆட்-லாக்-இன் நடத்தை ஆகியவற்றைச் சரிசெய்யும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సిస్టమ్ నియంత్రణలు వాల్యూమ్, స్క్రీన్ బ్రైట్‌నెస్ మరియు లాంచ్-ఎట్-లాగిన్ ప్రవర్తనను సర్దుబాటు చేయడాన్ని ప్రారంభిస్తాయి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Назорати система имкон медиҳад, ки баландӣ, равшании экран ва рафтори воридшавӣ ҳангоми воридшавӣ танзим карда шавад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การควบคุมระบบช่วยให้สามารถปรับระดับเสียง ความสว่างหน้าจอ และลักษณะการทำงานเมื่อเข้าสู่ระบบได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem kontrolleri ses düzeyinin, ekran parlaklığının ve oturum açma sırasında başlatma davranışının ayarlanmasına olanak tanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Елементи керування системою дозволяють регулювати гучність, яскравість екрана та поведінку запуску під час входу."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٹم کنٹرولز والیوم، اسکرین کی چمک اور لانچ کے وقت لاگ ان رویے کو ایڈجسٹ کرنے کا اہل بناتے ہیں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Tizim boshqaruvlari ovoz balandligini, ekran yorqinligini va tizimga kirishda harakatni sozlash imkonini beradi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các điều khiển hệ thống cho phép điều chỉnh âm lượng, độ sáng màn hình và hành vi khởi chạy khi đăng nhập."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Ulawulo lwenkqubo luvumela uhlengahlengiso lwevolumu, ukuqaqamba kwesikrini, kunye nokuqaliswa kokungena ekuziphatheni."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "סיסטעם קאָנטראָלס געבן אַדזשאַסטינג באַנד, פאַרשטעלן ברייטנאַס און קאַטער-ביי-לאָגין נאַטור."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Awọn iṣakoso eto jẹ ki iwọn didun ṣatunṣe, imọlẹ iboju, ati ihuwasi ifilọlẹ-ni wiwọle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统控件可以调整音量、屏幕亮度和登录时启动行为。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統控制可以調整音量、螢幕亮度和登入時啟動行為。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Izilawuli zesistimu zinika amandla ukulungisa ivolumu, ukukhanya kwesikrini, nokuziphatha kokungena ngemvume."
          }
        }
      }
    },
