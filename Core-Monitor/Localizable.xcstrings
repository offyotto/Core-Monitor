    "Opt into the deliberately odd extras that do not belong in a thermal monitor, starting with a tiny 2-bit arcade.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies die doelbewus vreemde ekstras wat nie in 'n termiese monitor hoort nie, begin met 'n klein 2-bis-arcade."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ከትንሽ ባለ2-ቢት የመጫወቻ ማዕከል ጀምሮ ሆን ተብሎ በሙቀት መቆጣጠሪያ ውስጥ ወደሌሉ ያልተለመዱ ተጨማሪ ነገሮች መርጠው ይግቡ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم باختيار الإضافات الغريبة التي لا تنتمي إلى جهاز مراقبة حراري، بدءًا من لعبة أركيد صغيرة بحجم 2 بت."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Opt into the deliberately odd extras that do not belong in a thermal monitor, starting with a tiny 2-bit arcade."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Opt into the deliberately odd extras that do not belong in a thermal monitor, starting with a tiny 2-bit arcade."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiçik 2 bitlik arcadedən başlayaraq, termal monitora aid olmayan qəsdən qəribə əlavələrə üstünlük verin."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберыце наўмысна дзіўныя дадатковыя магчымасці, якія не належаць да цеплавога манітора, пачынаючы з малюсенькай 2-бітнай аркады."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Изберете умишлено странните екстри, които не принадлежат на термомонитора, като започнете с малка 2-битова аркада."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Opt into the deliberately odd extras that do not belong in a thermal monitor, starting with a tiny 2-bit arcade."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি ছোট 2-বিট তোরণ দিয়ে শুরু করে, ইচ্ছাকৃতভাবে অদ্ভুত অতিরিক্তগুলি বেছে নিন যা একটি তাপ মনিটরের অন্তর্গত নয়।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Opt into the deliberately odd extras that do not belong in a thermal monitor, starting with a tiny 2-bit arcade."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odlučite se za namjerno neobične dodatke koji ne pripadaju termalnom monitoru, počevši od male 2-bitne arkade."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Opteu pels extres deliberadament estranys que no pertanyen a un monitor tèrmic, començant per un petit arcade de 2 bits."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pagpili sa tinuyo nga katingad-an nga mga ekstra nga wala sa usa ka thermal monitor, sugod sa usa ka gamay nga 2-bit nga arcade."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Opte per l'extra deliberatamente strani chì ùn appartenenu micca in un monitoru termale, cuminciendu cù una piccula arcade 2-bit."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapojte se do záměrně zvláštních doplňků, které do tepelného monitoru nepatří, počínaje malou 2bitovou arkádou."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Optiwch i mewn i'r pethau ychwanegol sy'n fwriadol od nad ydynt yn perthyn i fonitor thermol, gan ddechrau gydag arcêd 2-did bach."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg de bevidst mærkelige ekstramateriale, der ikke hører hjemme i en termisk skærm, startende med en lille 2-bit arkade."
          }
