          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozšírené zobrazenie počasia zobrazuje dlhšiu čiaru stavu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Razširjen pogled vremena prikazuje daljšo črto stanja."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "O le fa'alauteleina o le va'aiga o le tau o lo'o fa'aalia ai le laina o tulaga umi."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Maonero emamiriro ekunze akawedzerwa ari kuratidza mutsetse wakareba."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Muuqaalka cimilada oo balaadhiyay ayaa muujinaya xariiqda xaaladda dheer."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Pamja e zgjeruar e motit po tregon linjën më të gjatë të kushteve."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
