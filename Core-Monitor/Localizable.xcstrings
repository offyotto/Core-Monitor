        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang aktibong stack ng widget ay mas malawak kaysa sa isang buong Touch Bar. I-trim o muling ayusin ang mga widget upang maiwasan ang pag-clipping."
