    "Battery monitoring now combines battery health with live runtime and electrical details.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Batterymonitering kombineer nou batterygesondheid met lewendige looptyd en elektriese besonderhede."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የባትሪ ክትትል አሁን የባትሪ ጤናን ከቀጥታ የስራ ጊዜ እና የኤሌክትሪክ ዝርዝሮች ጋር ያጣምራል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تجمع مراقبة البطارية الآن بين صحة البطارية ووقت التشغيل المباشر والتفاصيل الكهربائية."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Batareyanın monitorinqi indi batareyanın sağlamlığını canlı işləmə müddəti və elektrik detalları ilə birləşdirir."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Цяпер маніторынг акумулятара спалучае ў сабе інфармацыю пра стан акумулятара, час працы і электрычныя дэталі."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторингът на батерията сега комбинира здравето на батерията с времето на работа и електрическите подробности."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ব্যাটারি পর্যবেক্ষণ এখন লাইভ রানটাইম এবং বৈদ্যুতিক বিবরণের সাথে ব্যাটারি স্বাস্থ্যকে একত্রিত করে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Praćenje baterije sada kombinuje zdravlje baterije s vremenom rada i električnim detaljima."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El monitoratge de la bateria ara combina la salut de la bateria amb el temps d'execució en directe i els detalls elèctrics."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang pag-monitor sa baterya karon naghiusa sa kahimsog sa baterya sa live runtime ug mga detalye sa kuryente."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "U monitoraghju di a batteria combina avà a salute di a batteria cù u runtime in diretta è i dettagli elettrici."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorování baterie nyní kombinuje stav baterie s provozní dobou a elektrickými detaily."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae monitro batri bellach yn cyfuno iechyd batri ag amser rhedeg byw a manylion trydanol."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Batteriovervågning kombinerer nu batterisundhed med live runtime og elektriske detaljer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Batterieüberwachung kombiniert jetzt den Batteriezustand mit Live-Laufzeit und elektrischen Details."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η παρακολούθηση μπαταρίας συνδυάζει τώρα την υγεία της μπαταρίας με το χρόνο λειτουργίας ζωντανής λειτουργίας και τις ηλεκτρικές λεπτομέρειες."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Battery monitoring now combines battery health with live runtime and electrical details."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Bateria monitorado nun kombinas baterian sanon kun viva rultempo kaj elektraj detaloj."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El monitoreo de la batería ahora combina el estado de la batería con el tiempo de ejecución en vivo y detalles eléctricos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Aku jälgimine ühendab nüüd aku seisundi reaalajas tööaja ja elektriliste üksikasjadega."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bateriaren monitorizazioak bateriaren osasuna zuzeneko iraupena eta xehetasun elektrikoekin konbinatzen ditu."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نظارت بر باتری اکنون سلامت باتری را با زمان اجرای زنده و جزئیات الکتریکی ترکیب می کند."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Akun valvonta yhdistää nyt akun kunnon reaaliaikaiseen käyttöaikaan ja sähköisiin yksityiskohtiin."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Pinagsasama na ngayon ng pagsubaybay sa baterya ang kalusugan ng baterya sa mga live na runtime at mga detalye ng kuryente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La surveillance de la batterie combine désormais l'état de la batterie avec l'autonomie en direct et les détails électriques."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Batterijmonitoring kombineart no batterijsûnens mei live runtime en elektryske details."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Comhcheanglaíonn monatóireacht ceallraí sláinte ceallraí anois le ham rite beo agus sonraí leictreacha."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Bidh sgrùdadh bataraidh a-nis a’ cothlamadh slàinte bataraidh le ùine ruith beò agus mion-fhiosrachadh dealain."
          }
        },
