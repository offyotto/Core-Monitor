        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "გჭირდებათ მხარდაჭერა ან ვენტილატორის კონტროლის პრობლემების მოგვარება?"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қолдау немесе желдеткішті басқару ақауларын жою керек пе?"
