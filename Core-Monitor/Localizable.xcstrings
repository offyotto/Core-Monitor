            "value": "Core Monitor சாதாரணமாக கண்காணிக்கும், ஆனால் உள்நுழைவு-உருப்படி கட்டுப்பாடு கவனம் தேவை."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor సాధారణంగా పర్యవేక్షిస్తుంది, అయితే లాగిన్-ఐటెమ్ నియంత్రణకు శ్రద్ధ అవసరం."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor мониторингро ба таври муқаррарӣ нигоҳ медорад, аммо назорати элементи воридшавӣ ба диққат ниёз дорад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ติดตามการตรวจสอบตามปกติ แต่การควบคุมรายการเข้าสู่ระบบจำเป็นต้องได้รับการดูแล"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor normal şekilde izlemeye devam ediyor ancak oturum açma öğesi kontrolüne dikkat edilmesi gerekiyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor продовжує моніторинг у звичайному режимі, але контроль елементів входу потребує уваги."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor عام طور پر نگرانی کرتا رہتا ہے، لیکن لاگ ان آئٹم کنٹرول پر توجہ کی ضرورت ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor kuzatuvni an'anaviy tarzda davom ettiradi, lekin kirish elementini boshqarish e'tiborga muhtoj."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor vẫn theo dõi bình thường nhưng cần chú ý kiểm soát mục đăng nhập."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "I-Core Monitor igcina esweni ngokuqhelekileyo, kodwa ulawulo lwento yokungena lufuna ukuhoywa."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor האלט מאָניטאָרינג נאָרמאַלי, אָבער לאָגין-נוץ קאָנטראָל דאַרף ופמערקזאַמקייט."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor n ṣe abojuto deede, ṣugbọn iṣakoso ohun kan nilo akiyesi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor监控正常，但登录项控制需要注意。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor監控正常，但登入項目控制需要注意。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "I-Core Monitor igcina ukuqapha ngokujwayelekile, kodwa ukulawula into yokungena kudinga ukunakwa."
          }
        }
      }
    },
