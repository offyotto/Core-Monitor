        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\". ڪوشش ڪريو اصطلاحن جھڙوڪ مددگار، موسم، لاگ ان شيون، مينيو بار، يا Touch Bar."
          }
