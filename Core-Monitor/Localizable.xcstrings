    "Core Monitor keeps monitoring normally, but login-item control needs attention.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor hou aan om normaalweg te moniteer, maar login-item beheer moet aandag kry."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor በመደበኛነት መከታተልን ይቀጥላል፣ ነገር ግን የመግቢያ ንጥል ቁጥጥር ትኩረት ያስፈልገዋል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستمر Core Monitor في المراقبة بشكل طبيعي، ولكن التحكم في عنصر تسجيل الدخول يحتاج إلى الاهتمام."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor keeps monitoring normally, but login-item control needs attention."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor keeps monitoring normally, but login-item control needs attention."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor monitorinqi normal saxlayır, lakin giriş elementinə nəzarət diqqət tələb edir."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor працягвае маніторынг у нармальным рэжыме, але кантроль элементаў ўваходу патрабуе ўвагі."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
