        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "कुनै पनि मद्दत खण्डहरू \"%@\" सँग मेल खाएनन्। सहायक, मौसम, लगइन वस्तुहरू, मेनु बार, वा Touch Bar जस्ता सर्तहरू प्रयास गर्नुहोस्।"
