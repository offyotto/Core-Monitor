        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Whakamahia te %@ ki te kawe i te Core Monitor ki mua ahakoa kua huna e macOS nga taonga pae tahua. Ka puta ano taua pokatata ki te tahua taupānga i te wa e hohe ana a Core Monitor."
