          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "The Overview Dashboard e fana ka kakaretso e felletseng ea boemo ba Mac ea hau ha joale ho kenyeletsoa CPU, GPU, mohopolo, mocheso, matla, le tlhaiso-leseling ea marang-rang."
