    "Apply a preset or fine-tune each live item. Changes appear immediately.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas 'n voorafinstelling toe of verfyn elke lewendige item. Veranderinge verskyn onmiddellik."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ቅድመ ዝግጅትን ይተግብሩ ወይም እያንዳንዱን የቀጥታ ንጥል ነገር ያስተካክሉ። ለውጦች ወዲያውኑ ይታያሉ."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتطبيق إعداد مسبق أو ضبط كل عنصر مباشر. تظهر التغييرات على الفور."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Əvvəlcədən təyin edilmiş tətbiq edin və ya hər canlı elementi dəqiqləşdirin. Dəyişikliklər dərhal görünür."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Прымяніце перадусталёўку або наладзьце кожны жывы элемент. Змены з'яўляюцца адразу."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложете предварително зададени настройки или фино настройте всеки жив елемент. Промените се появяват веднага."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি লাইভ আইটেম একটি প্রিসেট বা ফাইন-টিউন প্রয়োগ করুন। পরিবর্তন অবিলম্বে প্রদর্শিত হবে."
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Primijenite unaprijed podešeno ili fino podesite svaku živu stavku. Promjene se pojavljuju odmah."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Apliqueu un valor predefinit o afineu cada element en directe. Els canvis apareixen immediatament."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ibutang ang usa ka preset o pag-ayo sa matag buhi nga butang. Ang mga pagbag-o makita dayon."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Applicà un predefinitu o sintonizà ogni articulu live. I cambiamenti appariscenu immediatamente."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte předvolbu nebo jemně dolaďte každou živou položku. Změny se projeví okamžitě."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Cymhwyswch ragosodiad neu fireinio pob eitem fyw. Mae newidiadau yn ymddangos ar unwaith."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Anvend en forudindstilling eller finjuster hvert live-emne. Ændringer vises med det samme."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenden Sie eine Voreinstellung an oder optimieren Sie jedes Live-Element. Änderungen werden sofort angezeigt."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εφαρμόστε μια προεπιλογή ή βελτιστοποιήστε κάθε ζωντανό στοιχείο. Οι αλλαγές εμφανίζονται αμέσως."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a preset or fine-tune each live item. Changes appear immediately."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Apliku antaŭfiksitan aŭ agordu ĉiun vivan eron. Ŝanĝoj aperas tuj."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplique un ajuste preestablecido o ajuste cada elemento en vivo. Los cambios aparecen inmediatamente."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Rakendage eelseadistus või viimistlege iga reaalajas üksust. Muudatused ilmuvad kohe."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikatu aurrezartutako bat edo doitu zuzeneko elementu bakoitza. Aldaketak berehala agertzen dira."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
