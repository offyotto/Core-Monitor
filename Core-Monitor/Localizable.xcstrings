          "stringUnit": {
            "state": "translated",
            "value": "पॉवर वापरकर्ते तरीही व्युत्पन्न केलेले प्रीसेट JSON तपासू शकतात किंवा कॉपी करू शकतात. संपादन वरील सुरक्षित फॉर्मद्वारे होते."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengguna kuasa masih boleh memeriksa atau menyalin pratetap JSON yang dijana. Pengeditan berlaku melalui borang yang lebih selamat di atas."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "L-utenti tal-qawwa xorta jistgħu jispezzjonaw jew jikkopjaw l-issettjat minn qabel iġġenerat JSON. L-editjar isir permezz tal-formola aktar sigura hawn fuq."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ပါဝါအသုံးပြုသူများသည် ထုတ်လုပ်ထားသော ကြိုတင်သတ်မှတ် JSON ကို စစ်ဆေးခြင်း သို့မဟုတ် ကူးယူနိုင်သေးသည်။ တည်းဖြတ်ခြင်းသည် အထက်ဖော်ပြပါ ပိုလုံခြုံသောပုံစံဖြင့် ပြုလုပ်ပါသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Superbrukere kan fortsatt inspisere eller kopiere den genererte forhåndsinnstillingen JSON. Redigering skjer gjennom det tryggere skjemaet ovenfor."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "पावर प्रयोगकर्ताहरूले अझै पनि उत्पन्न पूर्वसेट JSON निरीक्षण वा प्रतिलिपि गर्न सक्छन्। सम्पादन माथिको सुरक्षित फारम मार्फत हुन्छ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoofdgebruikers kunnen de gegenereerde preset JSON nog steeds inspecteren of kopiëren. Bewerken gebeurt via het veiligere formulier hierboven."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogwiritsa ntchito magetsi amathanso kuyang'ana kapena kukopera JSON zomwe zapangidwa. Kusintha kumachitika kudzera mu fomu yotetezeka yomwe ili pamwambapa."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "Power users can still inspect or copy the generated preset JSON. Editing happens through the safer form above."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪਾਵਰ ਉਪਭੋਗਤਾ ਅਜੇ ਵੀ ਤਿਆਰ ਕੀਤੇ ਪ੍ਰੀਸੈਟ JSON ਦੀ ਜਾਂਚ ਜਾਂ ਕਾਪੀ ਕਰ ਸਕਦੇ ਹਨ। ਸੰਪਾਦਨ ਉੱਪਰ ਦਿੱਤੇ ਸੁਰੱਖਿਅਤ ਫਾਰਮ ਰਾਹੀਂ ਹੁੰਦਾ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaawansowani użytkownicy mogą nadal sprawdzać lub kopiować wygenerowane ustawienie wstępne JSON. Edycja odbywa się poprzez bezpieczniejszą formę powyżej."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د بریښنا کارونکي لاهم کولی شي د تولید شوي مخکینۍ JSON معاینه یا کاپي کړي. ترمیم د پورته خوندي فارم له لارې ترسره کیږي."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuários avançados ainda podem inspecionar ou copiar a predefinição gerada JSON. A edição acontece através do formulário mais seguro acima."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizatorii cu putere pot încă inspecta sau copia presetarea JSON generată. Editarea are loc prin formularul mai sigur de mai sus."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опытные пользователи по-прежнему могут проверять или копировать сгенерированный пресет JSON. Редактирование происходит через более безопасную форму, описанную выше."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Power users can still inspect or copy the generated preset JSON. Editing happens through the safer form above."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "پاور استعمال ڪندڙ اڃا تائين ٺاهيل پريزيٽ JSON جو معائنو يا نقل ڪري سگھن ٿا. ترميم مٿي ڏنل محفوظ فارم ذريعي ٿئي ٿي."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "බල පරිශීලකයින්ට තවමත් උත්පාදනය කරන ලද පෙරසිටුව JSON පරීක්ෂා කිරීමට හෝ පිටපත් කිරීමට හැකිය. සංස්කරණය කිරීම ඉහත ආරක්ෂිත පෝරමය හරහා සිදු වේ."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokročilí používatelia môžu stále kontrolovať alebo kopírovať vygenerovanú predvoľbu JSON. Úpravy sa vykonávajú prostredníctvom vyššie uvedeného bezpečnejšieho formulára."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izkušeni uporabniki lahko še vedno pregledajo ali kopirajo ustvarjeno prednastavitev JSON. Urejanje poteka prek zgornjega varnejšega obrazca."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "E mafai lava e tagata fa'aoga eletise ona siaki pe kopi le JSON. Fa'ata'ita'iga e tupu ile fomu saogalemu i luga."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Vashandisi vemagetsi vanogona kuramba vachiongorora kana kukopa iyo yakagadzirwa preset JSON. Kugadzirisa kunoitika kuburikidza nefomu rakachengeteka riri pamusoro."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Isticmaalayaasha tamarta ayaa wali baari kara ama koobi kara preset-ka hore ee JSON. Tafatirka waxay ku dhacdaa foomka nabdoon ee sare."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Përdoruesit e fuqisë ende mund të inspektojnë ose kopjojnë paravendosjen e krijuar JSON. Redaktimi ndodh përmes formularit më të sigurt të mësipërm."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Power users can still inspect or copy the generated preset JSON. Editing happens through the safer form above."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Basebelisi ba matla ba ntse ba ka hlahloba kapa ba kopitsa setaele se entsoeng esale pele JSON. Ho hlophisa ho etsoa ka mokhoa o sireletsehileng ka holimo."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Pamaké kakuatan masih tiasa mariksa atanapi nyalin prasetél JSON anu dihasilkeun. Ngédit lumangsung ngaliwatan formulir aman di luhur."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Avancerade användare kan fortfarande inspektera eller kopiera den genererade förinställningen JSON. Redigering sker genom det säkrare formuläret ovan."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Watumiaji wa nishati bado wanaweza kukagua au kunakili JSON iliyowekwa tayari. Kuhariri hufanyika kupitia fomu salama iliyo hapo juu."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஆற்றல் பயனர்கள் உருவாக்கப்பட்ட முன்னமைக்கப்பட்ட JSON ஐ இன்னும் ஆய்வு செய்யலாம் அல்லது நகலெடுக்கலாம். மேலே உள்ள பாதுகாப்பான படிவத்தின் மூலம் திருத்துதல் நடக்கிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "పవర్ వినియోగదారులు ఇప్పటికీ ఉత్పత్తి చేయబడిన ప్రీసెట్ JSONని తనిఖీ చేయవచ్చు లేదా కాపీ చేయవచ్చు. పైన ఉన్న సురక్షితమైన ఫారమ్ ద్వారా సవరణ జరుగుతుంది."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Истифодабарандагони пурқувват ҳоло ҳам метавонанд JSON-и пешакии тавлидшударо тафтиш ё нусхабардорӣ кунанд. Таҳрир тавассути шакли бехатартари боло сурат мегирад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ผู้ใช้ระดับสูงยังคงสามารถตรวจสอบหรือคัดลอก JSON ที่ตั้งไว้ล่วงหน้าที่สร้างขึ้นได้ การแก้ไขจะดำเนินการผ่านแบบฟอร์มที่ปลอดภัยกว่าด้านบน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzman kullanıcılar yine de oluşturulan ön ayarı JSON inceleyebilir veya kopyalayabilir. Düzenleme yukarıdaki daha güvenli form aracılığıyla gerçekleşir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Досвідчені користувачі можуть перевірити або скопіювати створений пресет JSON. Редагування відбувається через безпечнішу форму вище."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پاور استعمال کرنے والے اب بھی تیار کردہ پری سیٹ JSON کا معائنہ یا کاپی کر سکتے ہیں۔ ترمیم اوپر دی گئی محفوظ شکل کے ذریعے ہوتی ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuchli foydalanuvchilar hali ham yaratilgan oldindan o'rnatilgan JSON ni tekshirishi yoki nusxalashi mumkin. Tahrirlash yuqoridagi xavfsizroq shakl orqali amalga oshiriladi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Người dùng thành thạo vẫn có thể kiểm tra hoặc sao chép JSON cài sẵn đã tạo. Việc chỉnh sửa diễn ra thông qua hình thức an toàn hơn ở trên."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Abasebenzisi bamandla basenakho ukuhlola okanye ukukopa i-JSON esetwe kwangaphambili. Ukuhlela kwenzeka ngale ndlela ikhuselekileyo ingentla."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "מאַכט ניצערס קענען נאָך דורכקוקן אָדער נאָכמאַכן די דזשענערייטאַד פּריסעט JSON. עדיטינג כאַפּאַנז דורך די סאַפער פאָרעם אויבן."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Awọn olumulo agbara tun le ṣayẹwo tabi daakọ tito tẹlẹ ti ipilẹṣẹ JSON. Ṣatunkọ ṣẹlẹ nipasẹ awọn ailewu fọọmu loke."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高级用户仍然可以检查或复制生成的预设 JSON。编辑通过上面更安全的形式进行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "進階使用者仍然可以檢查或複製產生的預設 JSON。編輯透過上面更安全的形式進行。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Abasebenzisi bamandla basengakwazi ukuhlola noma ukukopisha okukhiqiziwe okusethiwe ngaphambilini kwe-JSON. Ukuhlela kwenzeka ngefomu eliphephile elingenhla."
          }
        }
      }
