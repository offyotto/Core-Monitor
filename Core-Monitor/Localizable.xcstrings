          "stringUnit": {
            "state": "translated",
            "value": "O le mata'ituina o mafaufauga e aofia ai le fa'aogaina o le RAM, fa'aogaina o le swap, ma le va'aiga o le mamafa o mafaufauga."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory monitoring inosanganisira kushandiswa kweRAM, kushandiswa kwekuchinjana, uye ndangariro kumanikidza kuona."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "La socodka xusuusta waxa ka mid ah isticmaalka RAM, is beddelka isticmaalka, iyo aragtida cadaadiska xusuusta."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitorimi i memories përfshin përdorimin e RAM-it, përdorimin e shkëmbimit dhe vizualizimin e presionit të kujtesës."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory monitoring includes RAM usage, swap usage, and memory pressure visualization."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Tlhokomelo ea memori e kenyelletsa ts'ebeliso ea RAM, ts'ebeliso ea phapanyetsano, le pono ea khatello ea mohopolo."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngawaskeun mémori kalebet pamakean RAM, pamakean swap, sareng visualisasi tekanan mémori."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Minnesövervakning inkluderar RAM-användning, swap-användning och visualisering av minnestryck."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Ufuatiliaji wa kumbukumbu hujumuisha matumizi ya RAM, matumizi ya kubadilishana, na taswira ya shinikizo la kumbukumbu."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "நினைவக கண்காணிப்பில் ரேம் பயன்பாடு, இடமாற்று பயன்பாடு மற்றும் நினைவக அழுத்த காட்சிப்படுத்தல் ஆகியவை அடங்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మెమరీ పర్యవేక్షణలో RAM వినియోగం, స్వాప్ వినియోగం మరియు మెమరీ ప్రెజర్ విజువలైజేషన్ ఉన్నాయి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторинги хотира истифодаи RAM, истифодаи своп ва визуализатсияи фишори хотираро дар бар мегирад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การตรวจสอบหน่วยความจำประกอบด้วยการใช้ RAM การใช้การสลับ และการแสดงภาพแรงดันหน่วยความจำ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bellek izleme, RAM kullanımını, takas kullanımını ve bellek basıncı görselleştirmesini içerir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Моніторинг пам'яті включає використання оперативної пам'яті, використання підкачки та візуалізацію тиску пам'яті."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "میموری کی نگرانی میں RAM کا استعمال، سویپ کا استعمال، اور میموری پریشر ویژولائزیشن شامل ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Xotira monitoringi RAMdan foydalanish, almashtirishdan foydalanish va xotira bosimini vizualizatsiya qilishni o'z ichiga oladi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giám sát bộ nhớ bao gồm việc sử dụng RAM, sử dụng trao đổi và hiển thị áp suất bộ nhớ."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukujongwa kwememori kubandakanya ukusetyenziswa kwe-RAM, ukusetyenziswa kokutshintsha, kunye nokubonwa koxinzelelo lwememori."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "זכּרון מאָניטאָרינג כולל באַראַן באַניץ, ויסבייַטן באַניץ און זכּרון דרוק וויזשוואַלאַזיישאַן."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Abojuto iranti pẹlu lilo Ramu, swap lilo, ati iwoye titẹ iranti."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内存监控包括 RAM 使用情况、交换使用情况和内存压力可视化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶體監控包括 RAM 使用情況、交換使用情況和記憶體壓力視覺化。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukuqapha inkumbulo kufaka phakathi ukusetshenziswa kwe-RAM, ukusetshenziswa kokushintshaniswa, nokubonwa kwengcindezi yenkumbulo."
          }
        }
      }
    },
