          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor loeb andureid AppleSMC kaudu. Fännide kirjutamiseks on vaja komplekti kuuluvat abistajat."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor AppleSMC bidez sentsoreak irakurtzen ditu. Zaleen idazketan bildutako laguntzailea behar da."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor حسگرها را از طریق AppleSMC می خواند. نوشته های طرفدار به کمک همراه نیاز دارد."
          }
        },
        "fi": {
