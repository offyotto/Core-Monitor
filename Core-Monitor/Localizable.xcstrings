        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ប្លង់នេះធំទូលាយពេកសម្រាប់ Touch Bar ពេញលេញ។ ប្រើការកំណត់ជាមុនតូចចង្អៀត ដើម្បីជៀសវាងធាតុក្រាហ្វិកដែលបានកាត់។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪೂರ್ಣ Touch Bar ಗೆ ಈ ಲೇಔಟ್ ತುಂಬಾ ವಿಸ್ತಾರವಾಗಿದೆ. ಕ್ಲಿಪ್ ಮಾಡಿದ ವಿಜೆಟ್‌ಗಳನ್ನು ತಪ್ಪಿಸಲು ಕಿರಿದಾದ ಪೂರ್ವನಿಗದಿಯನ್ನು ಬಳಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 레이아웃은 전체 Touch Bar에 비해 너무 넓습니다. 잘린 위젯을 방지하려면 더 좁은 사전 설정을 사용하세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Ev layout ji bo Touch Bar-a tevahî pir fireh e. Pêşniyarek tengtir bikar bînin da ku ji widgetên qutkirî dûr bixin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Бул схема толук Touch Bar үчүн өтө кенен. Кыскартылган виджеттерди болтурбоо үчүн алдын ала орнотууну тарыраак колдонуңуз."
          }
        },
        "la": {
          "stringUnit": {
