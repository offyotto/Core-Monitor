            "value": "Աջակցությա՞ն կամ օդափոխիչի վերահսկման անսարքությունների վերացման կարիք ե՞ք:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Butuh dukungan atau pemecahan masalah kontrol kipas?"
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Ị chọrọ nkwado ma ọ bụ nchọpụta nsogbu njikwa fan?"
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Þarftu stuðning eða bilanaleit við viftustýringu?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai bisogno di supporto o di risoluzione dei problemi relativi al controllo della ventola?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートやファン制御のトラブルシューティングが必要ですか?"
          }
