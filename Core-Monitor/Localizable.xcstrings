          "stringUnit": {
            "state": "translated",
            "value": "Kontrol panelinden ayrılmadan en son CPU, GPU, fan, güç, bellek, ağ ve takas geçmişi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Остання історія CPU, GPU, вентилятора, живлення, пам’яті, мережі та обміну, не виходячи з інформаційної панелі."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "حالیہ CPU، GPU، فین، پاور، میموری، نیٹ ورک، اور ڈیش بورڈ کو چھوڑے بغیر تبادلہ کی تاریخ۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Oxirgi CPU, GPU, fan, quvvat, xotira, tarmoq va almashtirish tarixi asboblar panelidan chiqmasdan."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lịch sử CPU, GPU, quạt, nguồn, bộ nhớ, mạng và trao đổi gần đây mà không cần rời khỏi bảng điều khiển."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "I-CPU yakutsha nje, i-GPU, fan, amandla, inkumbulo, inethiwekhi, kunye nembali yokutshintsha ngaphandle kokushiya ideshibhodi."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "לעצטע CPU, GPU, פאָכער, מאַכט, זכּרון, נעץ און ויסבייַטן געשיכטע אָן פאַרלאָזן די דאַשבאָרד."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU aipẹ, GPU, afẹfẹ, agbara, iranti, netiwọki, ati itan swap lai kuro ni dasibodu naa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最近的 CPU、GPU、风扇、电源、内存、网络和交换历史记录，无需离开仪表板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "最近的 CPU、GPU、風扇、電源、記憶體、網路和交換歷史記錄，無需離開儀表板。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "I-CPU yakamuva, i-GPU, ifeni, amandla, inkumbulo, inethiwekhi, nomlando wokushintsha ngaphandle kokushiya ideshibhodi."
          }
        }
      }
    },
