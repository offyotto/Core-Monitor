    "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Validasie kontroleer kurwe-ordening, drempelreekse, RPM-grense, gladmaak- en kragversterkingslimiete voordat Core Monitor probeer om enigiets toe te pas."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ማንኛውንም ነገር ለመተግበር ከመሞከሯ በፊት ማረጋገጫ የጥምዝ ማዘዣን፣ የመነሻ ክልሎችን፣ የRPM ወሰኖችን፣ ማለስለስን እና የኃይል ማበልጸጊያ ገደቦችን ይፈትሻል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتحقق عملية التحقق من صحة ترتيب المنحنى ونطاقات العتبة وحدود RPM والتجانس وحدود تعزيز الطاقة قبل أن يحاول Core Monitor تطبيق أي شيء."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrulama Core Monitor hər hansı bir şeyi tətbiq etməyə cəhd etməzdən əvvəl əyri sıralamasını, eşik diapazonlarını, RPM hüdudlarını, hamarlaşdırmanı və güc artırma limitlərini yoxlayır."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Праверка правярае парадак крывых, парогавыя дыяпазоны, межы RPM, згладжванне і абмежаванні павышэння магутнасці, перш чым Core Monitor паспрабуе прымяніць што-небудзь."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Валидирането проверява подреждането на кривите, диапазоните на праговете, границите на RPM, изглаждането и ограниченията за увеличаване на мощността, преди Core Monitor да се опита да приложи нещо."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor কিছু প্রয়োগ করার চেষ্টা করার আগে বৈধতা বক্ররেখার ক্রম, থ্রেশহোল্ড রেঞ্জ, RPM সীমা, মসৃণকরণ এবং পাওয়ার বুস্ট সীমা পরীক্ষা করে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Validacija provjerava redoslijed krivulja, raspone pragova, RPM granice, izglađivanje i ograničenja povećanja snage prije nego što Core Monitor pokuša bilo šta primijeniti."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La validació comprova l'ordre de la corba, els intervals de llindar, els límits de RPM, la suavització i els límits d'augment de potència abans que Core Monitor intenti aplicar qualsevol cosa."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang validation check curve ordering, threshold ranges, RPM bounds, smoothing, ug power boost limits sa dili pa ang Core Monitor mosulay sa paggamit sa bisan unsa."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "A validazione verifica l'ordine di curve, intervalli di soglia, limiti RPM, lisciatura è limiti di spinta di putenza prima chì Core Monitor prova à applicà qualcosa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Validace kontroluje řazení křivek, prahové rozsahy, meze RPM, vyhlazování a limity zvýšení výkonu, než se Core Monitor pokusí něco aplikovat."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae dilysu yn gwirio archebu cromlin, ystodau trothwy, terfynau RPM, llyfnu, a therfynau hwb pŵer cyn ceisio Core Monitor i gymhwyso unrhyw beth."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Validering kontrollerer kurverækkefølge, tærskelområder, RPM grænser, udjævning og power boost grænser, før Core Monitor forsøger at anvende noget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei der Validierung werden die Kurvenreihenfolge, die Schwellenwerte, die RPM-Grenzen, die Glättung und die Leistungssteigerungsgrenzen überprüft, bevor Core Monitor versucht, etwas anzuwenden."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η επικύρωση ελέγχει τη σειρά των καμπυλών, τα εύρη ορίων, τα όρια RPM, την εξομάλυνση και τα όρια ενίσχυσης ισχύος πριν το Core Monitor επιχειρήσει να εφαρμόσει οτιδήποτε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Valumado kontrolas kurban ordigon, sojlointervalojn, RPM-limojn, glatigon kaj potenco-akcelimojn antaŭ ol Core Monitor provas apliki ion ajn."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La validación verifica el orden de las curvas, los rangos de umbral, los límites de RPM, el suavizado y los límites de aumento de potencia antes de que Core Monitor intente aplicar algo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Valideerimine kontrollib kõverate järjestust, lävevahemikke, RPM piire, silumist ja võimsuse suurendamise piiranguid enne, kui Core Monitor proovib midagi rakendada."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Balidazioak egiaztatzen ditu kurbaren ordena, atalase-barrutiak, RPM mugak, leuntzea eta potentzia areagotzeko mugak Core Monitor ezer aplikatzen saiatu aurretik."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "قبل از اینکه Core Monitor هر چیزی را اعمال کند، اعتبارسنجی ترتیب منحنی ها، محدوده آستانه، مرزهای RPM، هموارسازی و محدودیت های افزایش توان را بررسی می کند."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Validointi tarkistaa käyrien järjestyksen, kynnysalueet, RPM-rajat, tasoituksen ja tehonlisäyksen rajat ennen kuin Core Monitor yrittää soveltaa mitään."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Sinusuri ng validation ang pag-order ng curve, mga saklaw ng threshold, mga hangganan ng RPM, pagpapakinis, at mga limitasyon ng power boost bago ang Core Monitor na sumubok na maglapat ng anuman."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La validation vérifie l'ordre des courbes, les plages de seuils, les limites du RPM, le lissage et les limites d'augmentation de puissance avant que le Core Monitor ne tente d'appliquer quoi que ce soit."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Validaasje kontrolearret krommebestelling, drompelberiken, RPM-grinzen, glêdens, en krêftfergruttingsgrinzen foardat Core Monitor besiket wat ta te passen."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Seiceálann bailíochtú ordú cuar, raonta tairsí, teorainneacha RPM, smúdála, agus teorainneacha treisithe cumhachta sula ndéanann Core Monitor iarracht aon rud a chur i bhfeidhm."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Bidh dearbhadh a’ sgrùdadh òrdugh lùbte, raointean stairsnich, crìochan RPM, rèidh, agus crìochan àrdachadh cumhachd mus feuch Core Monitor ri dad a chuir an sàs."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "A validación comproba a orde das curvas, os intervalos de limiares, os límites de RPM, o suavizado e os límites de aumento de potencia antes de que Core Monitor intente aplicar algo."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor કંઈપણ લાગુ કરવાનો પ્રયાસ કરે તે પહેલાં માન્યતા કર્વ ઓર્ડરિંગ, થ્રેશોલ્ડ રેન્જ, RPM બાઉન્ડ્સ, સ્મૂથિંગ અને પાવર બૂસ્ટ મર્યાદા તપાસે છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Tabbatarwa yana bincika oda mai lankwasa, jeri na kofa, iyakoki RPM, santsi, da iyakan haɓaka ƙarfin wuta kafin Core Monitor yayi ƙoƙarin amfani da komai."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Nānā ka hōʻoia ʻana i ka hoʻonohonoho ʻana i ka pihi, nā pae paepae, nā palena RPM, ka hoʻomaʻamaʻa, a me nā palena hoʻonui mana ma mua o ka hoʻāʻo ʻana o Core Monitor e hoʻopili i kekahi mea."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "האימות בודק את סדר העקומה, טווחי הסף, גבולות RPM, החלקה ומגבלות חיזוק הכוח לפני ש-Core Monitor מנסה ליישם משהו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor द्वारा कुछ भी लागू करने का प्रयास करने से पहले सत्यापन वक्र क्रम, थ्रेशोल्ड रेंज, RPM सीमाएं, स्मूथिंग और पावर बूस्ट सीमा की जांच करता है।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits ua ntej Core Monitor sim siv dab tsi."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Validacija provjerava redoslijed krivulja, raspone pragova, granice RPM, izglađivanje i ograničenja povećanja snage prije nego što Core Monitor pokuša bilo što primijeniti."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Validasyon tcheke lòd koub, ranje papòt, limit RPM, atenuasyon, ak limit pou ranfòse pouvwa anvan Core Monitor eseye aplike anyen."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az érvényesítés ellenőrzi a görbék sorrendjét, a küszöbtartományokat, a RPM határokat, a simítást és a teljesítménynövelési határértékeket, mielőtt a Core Monitor bármit is alkalmazni próbálna."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Վավերացումը ստուգում է կորերի դասավորությունը, շեմերի միջակայքերը, RPM սահմանները, հարթեցումը և հզորության ավելացման սահմանները, նախքան Core Monitor-ը կփորձի որևէ բան կիրառել:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Validasi memeriksa pengurutan kurva, rentang ambang batas, batas RPM, penghalusan, dan batas peningkatan daya sebelum Core Monitor mencoba menerapkan apa pun."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Nkwado na-enyocha usoro usoro ụzọ, oke ọnụ ụzọ, oke RPM, ire ụtọ na oke nkwalite ike tupu Core Monitor nwaa itinye ihe ọ bụla."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Löggilding athugar ferilröðun, þröskuldasvið, RPM mörk, jöfnun og aflhækkunarmörk áður en Core Monitor reynir að beita einhverju."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La convalida controlla l'ordine delle curve, gli intervalli di soglia, i limiti RPM, il livellamento e i limiti di aumento di potenza prima che Core Monitor tenti di applicare qualsiasi cosa."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証では、Core Monitor が何かを適用しようとする前に、曲線の順序、しきい値範囲、RPM 境界、平滑化、およびパワーブースト制限をチェックします。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Validasi mriksa urutan kurva, kisaran ambang, wates RPM, smoothing, lan watesan ngedongkrak daya sadurunge Core Monitor nyoba ngetrapake apa wae."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ვალიდაცია ამოწმებს მრუდის შეკვეთას, ზღურბლთა დიაპაზონს, RPM საზღვრებს, გამარტივებას და სიმძლავრის გაზრდის ლიმიტებს, სანამ Core Monitor რაიმეს გამოყენებას შეეცდება."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тексеру Core Monitor кез келген әрекетті қолданбас бұрын қисық ретін, шекті диапазондарды, RPM шекараларын, тегістеуді және қуатты арттыру шектеулерін тексереді."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "សុពលភាពពិនិត្យមើលការបញ្ជាទិញខ្សែកោង ជួរកម្រិតកំណត់ ព្រំដែន RPM ការធ្វើឱ្យរលូន និងដែនកំណត់បង្កើនថាមពល មុនពេល Core Monitor ព្យាយាមអនុវត្តអ្វីទាំងអស់។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ಯಾವುದನ್ನಾದರೂ ಅನ್ವಯಿಸಲು ಪ್ರಯತ್ನಿಸುವ ಮೊದಲು ಮೌಲ್ಯೀಕರಣವು ಕರ್ವ್ ಆರ್ಡರ್, ಥ್ರೆಶೋಲ್ಡ್ ಶ್ರೇಣಿಗಳು, RPM ಗಡಿಗಳು, ಸುಗಮಗೊಳಿಸುವಿಕೆ ಮತ್ತು ಪವರ್ ಬೂಸ್ಟ್ ಮಿತಿಗಳನ್ನು ಪರಿಶೀಲಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유효성 검사에서는 Core Monitor가 적용을 시도하기 전에 곡선 순서, 임계값 범위, RPM 경계, 평활화 및 전력 부스트 제한을 확인합니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Verastkirin fermana kevçîyê, rêzikên tixûbê, sînorên RPM, sivikkirin, û sînorên zêdekirina hêzê kontrol dike berî ku Core Monitor hewl bide ku tiştek bicîh bîne."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Текшерүү Core Monitor кандайдыр бир нерсени колдонууга аракет кылганга чейин ийри сызыктын иретин, босого диапазондорун, RPM чектерин, текшилөөнү жана кубаттуулукту жогорулатуу чектерин текшерет."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Validatio curva ordinatio coercet, iugis limen, fines RPM, delenimenta, et limites boost potentia antequam Core Monitor aliquid adhibere conatur."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "D'Validatioun kontrolléiert d'Kurvebestellung, d'Schwellbereich, d'RPM Grenzen, d'Glätterung, an d'Kraaft-Boost-Limiten ier Core Monitor probéiert eppes anzesetzen."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ການກວດສອບຄວາມຖືກຕ້ອງຈະກວດສອບການຈັດລໍາດັບເສັ້ນໂຄ້ງ, ຂອບເຂດເກນ, ຂອບເຂດ RPM, ການເຮັດໃຫ້ລຽບ, ແລະຂີດຈຳກັດການເພີ່ມພະລັງງານກ່ອນ Core Monitor ພະຍາຍາມນຳໃຊ້ອັນໃດນຶ່ງ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Patvirtinimas patikrina kreivės išdėstymą, slenksčių diapazonus, RPM ribas, išlyginimą ir galios padidinimo ribas prieš Core Monitor bandant ką nors pritaikyti."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Validācija pārbauda līkņu secību, sliekšņu diapazonus, RPM robežas, izlīdzināšanu un jaudas palielināšanas ierobežojumus, pirms Core Monitor mēģina kaut ko piemērot."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ny fanamarinana dia manamarina ny filaharan'ny curve, ny fetran'ny tokonam-baravarana, ny fetra RPM, ny fanamafisam-peo, ary ny fetran'ny fampitomboana hery alohan'ny Core Monitor manandrana mampihatra na inona na inona."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ka tirotirohia e te whakamanatanga te raupapatanga ānau, te awhe paepae, te rohenga RPM, te whakaene, me nga rohe whakanui hiko i mua i te ngana a Core Monitor ki te tono i tetahi mea."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Валидацијата го проверува редоследот на кривите, опсегот на праговите, границите RPM, измазнувањето и ограничувањата за зголемување на моќноста пред Core Monitor да се обиде да примени нешто."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor എന്തും പ്രയോഗിക്കാൻ ശ്രമിക്കുന്നതിന് മുമ്പ് കർവ് ഓർഡറിംഗ്, ത്രെഷോൾഡ് ശ്രേണികൾ, RPM ബൗണ്ടുകൾ, സ്മൂത്തിംഗ്, പവർ ബൂസ്റ്റ് പരിധികൾ എന്നിവ പരിശോധിക്കുന്നു."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Баталгаажуулалт нь Core Monitor ямар нэгэн зүйл хэрэглэхийг оролдохоос өмнө муруйн эрэмбэ, босго хязгаар, RPM хязгаар, тэгшитгэх, хүчийг нэмэгдүүлэх хязгаарыг шалгадаг."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor काहीही लागू करण्याचा प्रयत्न करण्यापूर्वी प्रमाणीकरण वक्र क्रम, थ्रेशोल्ड श्रेणी, RPM सीमा, स्मूथिंग आणि पॉवर बूस्ट मर्यादा तपासते."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengesahan menyemak susunan lengkung, julat ambang, had RPM, pelicinan dan had rangsangan kuasa sebelum Core Monitor cuba menggunakan apa-apa."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Il-validazzjoni tikkontrolla l-ordni tal-kurva, il-firxiet tal-limitu, il-limiti ta 'RPM, l-illixxar, u l-limiti ta' spinta tal-qawwa qabel Core Monitor jipprova japplika xi ħaġa."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "အတည်ပြုချက်သည် Core Monitor မည်သည့်အရာကိုမျှ အသုံးချရန် မကြိုးစားမီတွင် မျဉ်းကွေးအဆင့်သတ်မှတ်ချက်များ၊ RPM ဘောင်များ၊ ချောမွေ့ခြင်းနှင့် ပါဝါမြှင့်တင်ခြင်းကန့်သတ်ချက်များကို စစ်ဆေးသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Validering sjekker kurvebestilling, terskelområder, RPM-grenser, utjevning og kraftforsterkningsgrenser før Core Monitor forsøker å bruke noe."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रमाणीकरणले Core Monitor ले कुनै पनि कुरा लागू गर्ने प्रयास गर्नु अघि कर्भ अर्डरिङ, थ्रेसहोल्ड दायराहरू, RPM सीमाहरू, स्मूथिङ, र पावर बूस्ट सीमाहरू जाँच गर्दछ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Validatie controleert de volgorde van de curven, drempelbereiken, RPM-grenzen, afvlakking en vermogensboostlimieten voordat Core Monitor iets probeert toe te passen."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Kutsimikizira kumayang'ana kuyitanitsa kokhotakhota, mipata, malire a RPM, kusalaza, ndi malire owonjezera mphamvu Core Monitor isanayambe kuyesa kugwiritsa ntchito chilichonse."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ਦੁਆਰਾ ਕਿਸੇ ਵੀ ਚੀਜ਼ ਨੂੰ ਲਾਗੂ ਕਰਨ ਦੀ ਕੋਸ਼ਿਸ਼ ਕਰਨ ਤੋਂ ਪਹਿਲਾਂ ਪ੍ਰਮਾਣਿਕਤਾ ਕਰਵ ਆਰਡਰਿੰਗ, ਥ੍ਰੈਸ਼ਹੋਲਡ ਰੇਂਜ, RPM ਸੀਮਾਵਾਂ, ਸਮੂਥਿੰਗ, ਅਤੇ ਪਾਵਰ ਬੂਸਟ ਸੀਮਾਵਾਂ ਦੀ ਜਾਂਚ ਕਰਦੀ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Walidacja sprawdza kolejność krzywych, zakresy progów, granice RPM, wygładzanie i limity zwiększania mocy, zanim Core Monitor spróbuje zastosować cokolwiek."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "اعتبار د Core Monitor د هر څه پلي کولو هڅه کولو دمخه د وکر ترتیب کول ، د حد حدونه ، د RPM حدود ، هموار کول ، او د بریښنا وده محدودیتونه چیک کوي."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A validação verifica a ordem da curva, intervalos de limite, limites de RPM, suavização e limites de aumento de potência antes que Core Monitor tente aplicar qualquer coisa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Validarea verifică ordinea curbei, intervalele de prag, limitele RPM, netezirea și limitele de creștere a puterii înainte ca Core Monitor să încerce să aplice ceva."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При валидации проверяется порядок кривых, пороговые диапазоны, границы RPM, сглаживание и пределы повышения мощности, прежде чем Core Monitor попытается что-либо применить."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ڪنهن به شيءِ کي لاڳو ڪرڻ جي ڪوشش ڪرڻ کان اڳ تصديق وکر آرڊرنگ، حد جي حد، RPM حدون، هموار ڪرڻ، ۽ طاقت جي واڌاري جي حدن جي جانچ ڪري ٿي."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "වලංගුකරණය Core Monitor ඕනෑම දෙයක් යෙදීමට උත්සාහ කිරීමට පෙර වක්‍ර ඇණවුම, එළිපත්ත පරාස, RPM සීමාවන්, සුමට කිරීම සහ බලය වැඩි කිරීමේ සීමාවන් පරීක්ෂා කරයි."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Validácia kontroluje poradie kriviek, prahové rozsahy, hranice RPM, vyhladzovanie a limity zvýšenia výkonu predtým, ako sa Core Monitor pokúsi niečo aplikovať."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Validacija preveri vrstni red krivulj, obsege pragov, meje RPM, glajenje in meje povečanja moči, preden Core Monitor poskusi karkoli uporabiti."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Su'e fa'amaonia le fa'atonuga o le pi'o, va'ava'a, laina RPM, fa'alelei, ma tapula'a fa'aola malosi a'o le'i taumafai le Core Monitor e fa'aoga so'o se mea."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Kusimbiswa kunoongorora kurongeka kwecurve, zvikumbaridzo, RPM miganhu, kutsvedzerera, uye masimba ekuwedzera masimba Core Monitor isati yaedza kushandisa chero chinhu."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Xaqiijinta waxay hubisaa dalbashada qalooca, kala duwanaanshaha marinka, xuduudaha RPM, fududaynta, iyo xadadka korantada ka hor inta aysan Core Monitor isku dayin in uu wax isticmaalo."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifikimi kontrollon renditjen e kurbave, diapazonin e pragut, kufijtë e RPM, zbutjen dhe kufijtë e rritjes së fuqisë përpara se Core Monitor të përpiqet të zbatojë ndonjë gjë."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Validation checks curve ordering, threshold ranges, RPM bounds, smoothing, and power boost limits before Core Monitor attempts to apply anything."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Ho netefatsa ho lekola tatellano ea li-curve, mekhahlelo ea menyako, meeli ea RPM, boreleli, le meeli ea matlafatso ea matla pele Core Monitor e leka ho sebelisa eng kapa eng."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Validasi pariksa urutan kurva, rentang bangbarung, RPM wates, smoothing, sarta wates dorongan kakuatan saméméh Core Monitor nyoba nerapkeun nanaon."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Validering kontrollerar kurvordning, tröskelintervall, RPM-gränser, utjämning och effektförstärkningsgränser innan Core Monitor försöker tillämpa någonting."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Uthibitishaji hukagua uagizaji wa curve, viwango vya juu, mipaka ya RPM, kulainisha, na vikomo vya kuongeza nguvu kabla ya Core Monitor kujaribu kutumia chochote."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor எதையும் பயன்படுத்த முயற்சிக்கும் முன், சரிபார்ப்பு வளைவு வரிசைப்படுத்தல், வரம்பு வரம்புகள், RPM எல்லைகள், மென்மையாக்குதல் மற்றும் பவர் பூஸ்ட் வரம்புகளைச் சரிபார்க்கிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor ఏదైనా వర్తింపజేయడానికి ప్రయత్నించే ముందు వక్రత క్రమం, థ్రెషోల్డ్ పరిధులు, RPM హద్దులు, సున్నితంగా మరియు పవర్ బూస్ట్ పరిమితులను ధృవీకరణ తనిఖీ చేస్తుంది."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Санҷиш тартиби каҷ, диапазонҳои ҳадди ниҳоӣ, ҳудуди RPM, ҳамворкунӣ ва маҳдудиятҳои афзоиши нерӯро пеш аз кӯшиши Core Monitor барои татбиқи ягон чиз тафтиш мекунад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การตรวจสอบความถูกต้องจะตรวจสอบการเรียงลำดับเส้นโค้ง ช่วงเกณฑ์ ขอบเขต RPM การปรับให้เรียบ และขีดจำกัดการเพิ่มพลังงานก่อนที่ Core Monitor จะพยายามใช้สิ่งใดๆ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Doğrulama, Core Monitor herhangi bir şeyi uygulamaya çalışmadan önce eğri sıralamasını, eşik aralıklarını, RPM sınırlarını, yumuşatmayı ve güç artırma sınırlarını kontrol eder."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перевірка перевіряє порядок кривих, порогові діапазони, межі RPM, згладжування та обмеження підвищення потужності, перш ніж Core Monitor спробує щось застосувати."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Core Monitor کسی بھی چیز کو لاگو کرنے کی کوشش کرنے سے پہلے توثیق کریو آرڈرنگ، تھریشولڈ رینجز، RPM باؤنڈز، ہموار کرنے، اور پاور بوسٹ کی حدوں کو چیک کرتی ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Tasdiqlash Core Monitor biror narsani qoʻllashga urinishdan oldin egri chiziq tartibini, chegara diapazonlarini, RPM chegaralarini, tekislash va quvvatni oshirish chegaralarini tekshiradi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xác thực kiểm tra thứ tự đường cong, phạm vi ngưỡng, giới hạn RPM, làm mịn và giới hạn tăng công suất trước khi Core Monitor cố gắng áp dụng bất cứ điều gì."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukuqinisekiswa kuhlola i-odolo ye-curve, i-threshold ranges, i-RPM imida, i-smooth, kunye nemida yokunyusa amandla ngaphambi kokuba i-Core Monitor izame ukusebenzisa nantoni na."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "וואַלאַדיישאַן טשעקס ויסבייג אָרדערינג, שוועל ריינדזשאַז, RPM גווול, סמודינג און מאַכט בוסט לימאַץ איידער Core Monitor פרווון צו צולייגן עפּעס."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Afọwọsi sọwedowo tito tẹ, awọn sakani ẹnu-ọna, awọn aala RPM, didan, ati awọn opin igbelaruge agbara ṣaaju igbiyanju Core Monitor lati lo ohunkohun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Core Monitor 尝试应用任何内容之前，验证会检查曲线排序、阈值范围、RPM 边界、平滑和功率提升限制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Core Monitor 嘗試應用任何內容之前，驗證會檢查曲線排序、閾值範圍、RPM 邊界、平滑和功率提升限制。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukuqinisekisa kuhlola uku-oda kwejika, ububanzi be-threshold, i-RPM imingcele, ukushelela, kanye nemikhawulo yokukhulisa amandla ngaphambi kokuthi i-Core Monitor izame ukusebenzisa noma yini."
          }
        }
      }
    },
