    "Memory monitoring includes RAM usage, swap usage, and memory pressure visualization.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Geheuemonitering sluit RAM-gebruik, ruilgebruik en geheuedrukvisualisering in."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የማህደረ ትውስታ ክትትል የ RAM አጠቃቀምን፣ የመቀያየር አጠቃቀምን እና የማህደረ ትውስታ ግፊት እይታን ያካትታል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتضمن مراقبة الذاكرة استخدام ذاكرة الوصول العشوائي (RAM)، واستخدام المبادلة، وتصور ضغط الذاكرة."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory monitoring includes RAM usage, swap usage, and memory pressure visualization."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Memory monitoring includes RAM usage, swap usage, and memory pressure visualization."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
