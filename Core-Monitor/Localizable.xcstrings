        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ակտիվ վիջեթների կույտը ավելի լայն է, քան ամբողջական Touch Bar-ը: Կտրեք կամ վերադասավորեք վիջեթները՝ կտրումից խուսափելու համար:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tumpukan widget aktif lebih lebar dari Touch Bar penuh. Pangkas atau susun ulang widget untuk menghindari kliping."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngwakọta wijetị nọ n'ọrụ sara mbara karịa Touch Bar zuru ezu. Kpatụ ma ọ bụ degharịa wijetị ka ịzena ibibi."
