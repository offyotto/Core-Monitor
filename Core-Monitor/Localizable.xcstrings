    "Drag anywhere inside the arena to move your paddle. Best rally persists between launches.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep enige plek binne die arena om jou paddle te beweeg. Beste tydren duur voort tussen bekendstellings."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "መቅዘፊያዎን ለማንቀሳቀስ በመድረኩ ውስጥ የትኛውም ቦታ ይጎትቱ። ምርጥ ሰልፍ በጅማሬዎች መካከል ይቀጥላል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب إلى أي مكان داخل الساحة لتحريك مجدافك. يستمر أفضل تجمع بين عمليات الإطلاق."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Avarınızı hərəkət etdirmək üçün arena daxilində istənilən yerə sürükləyin. Ən yaxşı mitinq buraxılışlar arasında davam edir."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Перацягніце ў любое месца на арэне, каб перамясціць вясло. Лепшае ралі захоўваецца паміж запускамі."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Плъзнете навсякъде в арената, за да преместите греблото си. Най-доброто рали продължава между изстрелванията."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার প্যাডেল সরাতে মাঠের ভিতরে যে কোনও জায়গায় টেনে আনুন। লঞ্চের মধ্যে সেরা সমাবেশ অব্যাহত থাকে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Povucite bilo gdje unutar arene da pomjerite veslo. Najbolji reli traje između lansiranja."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrossegueu a qualsevol lloc de l'arena per moure la vostra paleta. El millor rally persisteix entre llançaments."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pag-drag bisan asa sulod sa arena aron ibalhin ang imong paddle. Ang labing maayo nga rally nagpadayon tali sa mga paglansad."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascinate in ogni locu in l'arena per spustà a vostra pagaia. U megliu rallye persiste trà i lanci."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přetažením kamkoli do arény přesunete pádlo. Nejlepší rally přetrvává mezi starty."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Llusgwch unrhyw le y tu mewn i'r arena i symud eich padl. Rali orau yn parhau rhwng lansiadau."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Træk hvor som helst indenfor i arenaen for at flytte din pagaj. Bedste rally fortsætter mellem lanceringer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen Sie eine beliebige Stelle in der Arena, um Ihr Paddel zu bewegen. Die beste Rallye bleibt zwischen den Starts bestehen."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σύρετε οπουδήποτε μέσα στην αρένα για να μετακινήσετε το κουπί σας. Το καλύτερο ράλι επιμένει μεταξύ των εκτοξεύσεων."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Trenu ie ajn en la arenon por movi vian padelon. Plej bona amaskunveno daŭras inter lanĉoj."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra a cualquier lugar dentro de la arena para mover tu remo. El mejor repunte persiste entre lanzamientos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Aeru liigutamiseks lohistage areenil ükskõik kuhu. Parim ralli püsib startide vahel."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastatu arena barruko edozein tokira zure pala mugitzeko. Rally onena irauten du abian jarri artean."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای حرکت دادن پارو خود را به هر جایی در داخل میدان بکشید. بهترین رالی بین راه اندازی ها ادامه دارد."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Siirrä melaa vetämällä minne tahansa areenan sisällä. Paras ralli jatkuu laukaisujen välillä."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "I-drag kahit saan sa loob ng arena para ilipat ang iyong paddle. Nagpapatuloy ang pinakamahusay na rally sa pagitan ng mga paglulunsad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser n'importe où dans l'arène pour déplacer votre pagaie. Le meilleur rallye persiste entre les lancements."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep oeral yn 'e arena om jo paddle te ferpleatsen. De bêste rally bliuwt tusken lansearringen."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarraing áit ar bith taobh istigh den réimse chun do stuáil a bhogadh. Maireann an railí is fearr idir na seolta."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Slaod àite sam bith taobh a-staigh an raon gus do pleadhag a ghluasad. Tha an rally as fheàrr a’ leantainn eadar cuirmean air bhog."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra a calquera parte da area para mover a túa remo. O mellor rally persiste entre os lanzamentos."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તમારા ચપ્પુને ખસેડવા માટે એરેનાની અંદર ગમે ત્યાં ખેંચો. શ્રેષ્ઠ રેલી લોન્ચ વચ્ચે ચાલુ રહે છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Jawo ko'ina a cikin fage don matsar da filafin ku. Mafi kyawun gangami yana ci gaba tsakanin ƙaddamarwa."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Kauō ma nā wahi a pau i loko o ke kahua pāʻani e hoʻoneʻe i kāu hoe. Hoʻomau ka hui maikaʻi ma waena o nā hoʻomaka."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "גרור לכל מקום בתוך הזירה כדי להזיז את ההנעה שלך. העצרת הטובה ביותר נמשכת בין ההשקה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने पैडल को हिलाने के लिए मैदान के अंदर कहीं भी खींचें। लॉन्च के बीच सर्वश्रेष्ठ रैली बनी रहती है।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Luag nyob qhov twg hauv lub arena txav koj paddle. Qhov zoo tshaj plaws rally tseem nyob nruab nrab ntawm kev xa tawm."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Povucite bilo gdje unutar arene da pomaknete veslo. Najbolji porast traje između lansiranja."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Trennen nenpòt kote andedan tèren an pou deplase pedal ou. Pi bon rasanbleman pèsiste ant lansman."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A lapát mozgatásához húzza bárhová az arénában. A legjobb rally az indítások között is fennáll."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Քաշեք արենայի ներսում ցանկացած տեղ՝ ձեր թիակը տեղափոխելու համար: Լավագույն հանրահավաքը պահպանվում է մեկնարկների միջև:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret ke mana saja di dalam arena untuk menggerakkan dayung Anda. Reli terbaik tetap ada di antara peluncuran."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Dọrọ ebe ọ bụla n'ime ogige ahụ ka ịkwaga paddle gị. Mgbakọta kacha mma na-aga n'ihu n'etiti mmalite."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Dragðu hvert sem er innan leikvangsins til að hreyfa róðurinn þinn. Besta rallið heldur áfram á milli sjósetningar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascina ovunque all'interno dell'arena per muovere la racchetta. Il miglior rally persiste tra i lanci."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アリーナ内の任意の場所をドラッグしてパドルを動かします。最高のラリーは発射と発射の間で持続します。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret menyang ngendi wae ing arena kanggo mindhah dayung. Rali paling apik tetep ana ing antarane peluncuran."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "გადაათრიეთ არენის შიგნით სადმე, რომ გადაიტანოთ თქვენი პალი. საუკეთესო რალი გრძელდება გაშვებებს შორის."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қалақшаңызды жылжыту үшін аренаның кез келген жеріне сүйреңіз. Ең жақсы ралли ұшыру арасында сақталады."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "អូសកន្លែងណាមួយនៅក្នុងសង្វៀន ដើម្បីផ្លាស់ទីក្តាររបស់អ្នក។ ការប្រមូលផ្តុំដ៏ល្អបំផុតនៅតែបន្តរវាងការបាញ់បង្ហោះ។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ನಿಮ್ಮ ಪ್ಯಾಡಲ್ ಅನ್ನು ಸರಿಸಲು ಅಖಾಡದ ಒಳಗೆ ಎಲ್ಲಿಯಾದರೂ ಎಳೆಯಿರಿ. ಉಡಾವಣೆಗಳ ನಡುವೆ ಅತ್ಯುತ್ತಮ ರ್ಯಾಲಿ ಮುಂದುವರಿಯುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "패들을 움직이려면 경기장 내부의 아무 곳이나 드래그하세요. 출시 사이에 최고의 랠리가 지속됩니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaş bikin li her deverê di hundurê arene de da ku pêlava xwe biguhezînin. Rallya çêtirîn di navbera destpêkirinan de berdewam dike."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Калакты жылдыруу үчүн аренада каалаган жерге сүйрөңүз. Мыкты митинг ишке киргизүү ортосунда сакталат."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Trahunt usquam intra arenam ad movendum tuum paxillum. Optima soeio persistit inter immittit."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag iergendwou an der Arena fir Äert Paddel ze beweegen. Beschte Rally bestoe tëscht lancéiert."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ລາກບ່ອນໃດກໍໄດ້ພາຍໃນສະຫນາມກິລາເພື່ອຍ້າຍ paddle ຂອງທ່ານ. ການຊຸມນຸມທີ່ດີທີ່ສຸດຍັງຄົງຢູ່ລະຫວ່າງການເປີດຕົວ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vilkite bet kur arenos viduje, kad perkeltumėte irklą. Geriausias ralis išlieka tarp startų."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Velciet jebkurā vietā arēnā, lai pārvietotu lāpstiņu. Labākais rallijs turpinās starp startiem."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Tariho na aiza na aiza ao anatin'ny kianja mba hamindra ny fivoy. Ny famoriam-bahoaka tsara indrindra dia mitohy eo anelanelan'ny fandefasana."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Toia ki nga waahi katoa ki roto i te waahi hei nuku i to hoe. Ka mau tonu te huihuinga pai i waenga i nga whakarewatanga."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Повлечете каде било внатре во арената за да го поместите лопатката. Најдоброто рели опстојува помеѓу лансирањето."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "നിങ്ങളുടെ പാഡിൽ നീക്കാൻ അരീനയ്ക്കുള്ളിൽ എവിടെയും വലിച്ചിടുക. ലോഞ്ചുകൾക്കിടയിൽ മികച്ച റാലി നിലനിൽക്കുന്നു."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Сэлүүрээ хөдөлгөхийн тулд талбайн аль ч хэсэгт чирнэ үү. Хамгийн сайн ралли нь хөөргөх хооронд үргэлжилдэг."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "तुमचे पॅडल हलविण्यासाठी रिंगणात कुठेही ड्रॅग करा. सर्वोत्कृष्ट रॅली लॉन्च दरम्यान टिकून राहते."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret ke mana-mana sahaja di dalam arena untuk menggerakkan dayung anda. Perhimpunan terbaik berterusan antara pelancaran."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Iddreggja kullimkien ġewwa l-arena biex iċċaqlaq il-qadfa tiegħek. L-aħjar rally jippersisti bejn it-tnedija."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "သင်၏လှော်တက်ကိုရွှေ့ရန် ကွင်းအတွင်း မည်သည့်နေရာကိုမဆို ဆွဲယူပါ။ ပစ်လွှတ်မှုများကြားတွင် အကောင်းဆုံး စုဝေးမှုများ ဆက်လက်ရှိနေပါသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dra hvor som helst innenfor arenaen for å flytte åren. Beste rally vedvarer mellom lanseringer."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "आफ्नो प्याडल सार्न एरेना भित्र कहीं तान्नुहोस्। उत्तम रैली प्रक्षेपण बीच रहन्छ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep ergens in de arena om je peddel te verplaatsen. De beste rally blijft bestaan ​​tussen lanceringen."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Kokani kulikonse mkati mwabwalo kuti musunthe chopalasa chanu. Msonkhano wabwino kwambiri umapitilirabe pakati pa kukhazikitsidwa."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਆਪਣੇ ਪੈਡਲ ਨੂੰ ਹਿਲਾਉਣ ਲਈ ਅਖਾੜੇ ਦੇ ਅੰਦਰ ਕਿਤੇ ਵੀ ਖਿੱਚੋ। ਸਭ ਤੋਂ ਵਧੀਆ ਰੈਲੀ ਲਾਂਚ ਦੇ ਵਿਚਕਾਰ ਬਣੀ ਰਹਿੰਦੀ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeciągnij w dowolne miejsce na arenie, aby przesunąć wiosło. Najlepszy rajd utrzymuje się pomiędzy startami."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "خپل پیډل حرکت کولو لپاره د میدان دننه هرچیرې کش کړئ. غوره ریلی د لانچونو ترمینځ دوام لري."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste para qualquer lugar dentro da arena para mover sua raquete. A melhor recuperação persiste entre os lançamentos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Trageți oriunde în interiorul arenei pentru a vă muta paleta. Cel mai bun raliu persistă între lansări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите весло в любое место арены, чтобы переместить весло. Лучшее ралли сохраняется между запусками."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "پنھنجي پيڊل کي ھلائڻ لاءِ ميدان جي اندر ڪٿي به ڇڪيو. بهترين ريلي لانچ جي وچ ۾ جاري رهي ٿي."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඔබේ පැඩලය චලනය කිරීමට පිටියේ ඕනෑම තැනකට අදින්න. දියත් කිරීම් අතර හොඳම රැලිය පවතී."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Potiahnite kamkoľvek do arény, aby ste posunuli pádlo. Najlepšia rally pretrváva medzi štartmi."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Povlecite kamor koli znotraj arene, da premaknete veslo. Najboljši rally traja med izstrelitvami."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Toso so'o se mea i totonu ole malae e fa'agaoioi lau foe. Fa'atasiga sili ona lelei e fa'aauau i le va o fa'alauiloa."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Dhonza chero mukati menhandare kuti ufambise paddle yako. Yakanakisa rally inoenderera pakati pekutanga."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Jiid meel kasta oo gudaha garoonka ah si aad u dhaqaajiso suufkaaga. Isu soo baxa ugu fiican ayaa socda inta u dhaxaysa furitaanka"
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvarritni kudo brenda arenës për të lëvizur vozitën tuaj. Tubimi më i mirë vazhdon midis nisjeve."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag anywhere inside the arena to move your paddle. Best rally persists between launches."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Hula kae kapa kae ka har'a lebala ho tsamaisa paddle ea hau. Likopano tse ntle ka ho fetisisa li tsoela pele lipakeng tsa ho qala."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Séred ka mana waé di jero arena pikeun mindahkeun dayeuh anjeun. Rally pangalusna persists antara peluncuran."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dra vart som helst inom arenan för att flytta din paddel. Bästa rallyt kvarstår mellan lanseringarna."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Buruta popote ndani ya uwanja ili kusogeza kasia yako. Mkutano bora zaidi unaendelea kati ya uzinduzi."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் துடுப்பை நகர்த்த, அரங்கின் உள்ளே எங்கு வேண்டுமானாலும் இழுக்கவும். ஏவுதல்களுக்கு இடையே சிறந்த பேரணி நீடிக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ తెడ్డును తరలించడానికి అరేనా లోపల ఎక్కడికైనా లాగండి. లాంచీల మధ్య అత్యుత్తమ ర్యాలీ కొనసాగుతుంది."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Барои ҳаракат додани бели худ ба ягон ҷое дар дохили арена кашед. Митинги беҳтарин дар байни оғозёбӣ боқӣ мемонад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลากไปที่ใดก็ได้ภายในอารีน่าเพื่อขยับไม้พายของคุณ การชุมนุมที่ดีที่สุดยังคงมีอยู่ระหว่างการเปิดตัว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raketinizi hareket ettirmek için arenada herhangi bir yere sürükleyin. En iyi ralli lansmanlar arasında devam ediyor."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетягніть будь-куди всередині арени, щоб перемістити весло. Найкраще ралі зберігається між запусками."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے پیڈل کو حرکت دینے کے لیے میدان کے اندر کہیں بھی گھسیٹیں۔ بہترین ریلی لانچوں کے درمیان برقرار رہتی ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Eshkak eshish uchun arenaning istalgan joyiga torting. Eng yaxshi miting startlar orasida davom etadi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kéo bất cứ nơi nào trong đấu trường để di chuyển mái chèo của bạn. Cuộc biểu tình tốt nhất vẫn tồn tại giữa các lần ra mắt."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Tsala naphina ngaphakathi kwebala ukuhambisa iphini lokubheqa. Eyona rally iyaqhubeka phakathi kokuqaliswa."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "שלעפּן ערגעץ אין די ארענע צו מאַך דיין רודער. בעסטער מיטינג בלייַבט צווישן לאָנטשיז."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Fa nibikibi ninu gbagede lati gbe paddle rẹ. Apejọ ti o dara julọ wa laarin awọn ifilọlẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动竞技场内的任意位置即可移动球拍。两次发射之间的最佳反弹持续存在。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖曳競技場內的任意位置即可移動球拍。兩次發射之間的最佳反彈持續存在。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hudula noma yikuphi ngaphakathi kwenkundla ukuze uhambise i-paddle yakho. I-rally ehamba phambili iyaqhubeka phakathi kokuqaliswa."
          }
        }
      }
    },
