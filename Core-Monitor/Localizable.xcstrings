    "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen hulpafdelings pas by \"%@\" nie. Probeer terme soos helper, weer, aanmelditems, kieslysbalk of Touch Bar."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ከ\"%@\" ጋር የሚዛመዱ ምንም የእገዛ ክፍሎች የሉም። እንደ አጋዥ፣ የአየር ሁኔታ፣ የመግቢያ ንጥሎች፣ ምናሌ አሞሌ ወይም Touch Bar ያሉ ቃላትን ይሞክሩ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد أقسام مساعدة تطابق \"%@\". جرب مصطلحات مثل المساعد أو الطقس أو عناصر تسجيل الدخول أو شريط القائمة أو Touch Bar."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ilə uyğun gələn yardım bölmələri yoxdur. Köməkçi, hava, giriş elementləri, menyu paneli və ya Touch Bar kimi şərtləri sınayın."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Няма раздзелаў даведкі, якія адпавядаюць \"%@\". Паспрабуйце такія тэрміны, як памочнік, надвор'е, элементы ўваходу, радок меню або Touch Bar."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Няма помощни секции, съответстващи на „%@“. Опитайте термини като помощник, време, елементи за влизане, лента с менюта или Touch Bar."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" এর সাথে মেলেনি কোনো সহায়তা বিভাগ। হেল্পার, আবহাওয়া, লগইন আইটেম, মেনু বার, বা Touch Bar এর মত শব্দ ব্যবহার করে দেখুন।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nijedan odjeljak pomoći ne odgovara \"%@\". Isprobajte termine kao što su pomoćnik, vrijeme, stavke za prijavu, traka menija ili Touch Bar."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No hi ha cap secció d'ajuda que coincideixi amb \"%@\". Proveu termes com ajuda, temps, elements d'inici de sessió, barra de menú o Touch Bar."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Walay tabang nga mga seksyon nga motugma sa \"%@\". Sulayi ang mga termino sama sa katabang, panahon, mga butang sa pag-login, menu bar, o Touch Bar."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Nisuna sezione d'aiutu currisponde à \"%@\". Pruvate termini cum'è helper, meteo, elementi di login, menu bar, o Touch Bar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádné sekce nápovědy neodpovídají \"%@\". Vyzkoušejte výrazy jako pomocník, počasí, přihlašovací položky, panel nabídek nebo Touch Bar."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Dim adrannau cymorth yn cyfateb i \"%@\". Rhowch gynnig ar dermau fel helpwr, tywydd, eitemau mewngofnodi, bar dewislen, neu Touch Bar."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen hjælpesektioner matchede \"%@\". Prøv udtryk som hjælper, vejr, login-elementer, menulinje eller Touch Bar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Hilfeabschnitte stimmten mit „%@“ überein. Probieren Sie Begriffe wie Helfer, Wetter, Anmeldeelemente, Menüleiste oder Touch Bar aus."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχουν ενότητες βοήθειας που να αντιστοιχούν στο \"%@\". Δοκιμάστε όρους όπως βοηθός, καιρός, στοιχεία σύνδεσης, γραμμή μενού ή Touch Bar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Neniuj helpsekcioj kongruis kun \"%@\". Provu terminojn kiel helpanto, vetero, ensalutaĵoj, menubreto aŭ Touch Bar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ninguna sección de ayuda coincide con \"%@\". Pruebe términos como ayuda, clima, elementos de inicio de sesión, barra de menú o Touch Bar."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ükski abijaotis ei vasta \"%@\". Proovige selliseid termineid nagu abimees, ilm, sisselogimisüksused, menüüriba või Touch Bar."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez dago \"%@\" bat datorren laguntza-atalik. Probatu laguntzailea, eguraldia, saioa hasteko elementuak, menu-barra edo Touch Bar bezalako terminoak."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "هیچ بخش راهنما با \"%@\" مطابقت ندارد. عباراتی مانند helper، آب و هوا، موارد ورود به سیستم، نوار منو یا Touch Bar را امتحان کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yksikään ohjeosio ei vastaa hakusanaa \"%@\". Kokeile termejä, kuten apulainen, sää, kirjautumiskohdat, valikkopalkki tai Touch Bar."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Walang mga seksyon ng tulong na tumugma sa \"%@\". Subukan ang mga termino tulad ng helper, panahon, mga item sa pag-log in, menu bar, o Touch Bar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune section d'aide ne correspond à \"%@\". Essayez des termes tels que assistant, météo, éléments de connexion, barre de menus ou Touch Bar."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjin helpseksjes oerienkomme mei \"%@\". Besykje termen lykas helper, waar, oanmelde items, menubalke, of Touch Bar."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Ní raibh aon rannán cabhrach ag teacht le \"%@\". Bain triail as téarmaí ar nós cúntóir, aimsir, míreanna logála isteach, barra roghchláir, nó Touch Bar."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Cha robh earrannan cuideachaidh a' maidseadh \"%@\". Feuch ri teirmean mar neach-cuideachaidh, aimsir, nithean logadh a-steach, bàr clàr-taice, no Touch Bar."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Non hai seccións de axuda que coincidan con \"%@\". Proba termos como axudante, tempo, elementos de inicio de sesión, barra de menú ou Touch Bar."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "No help sections matched \"%@\". Try terms like helper, weather, login items, menu bar, or Touch Bar."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "કોઈ સહાય વિભાગો \"%@\" સાથે મેળ ખાતા નથી. સહાયક, હવામાન, લૉગિન આઇટમ્સ, મેનૂ બાર અથવા Touch Bar જેવા શબ્દો અજમાવો."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Babu sassan taimako da suka dace da \"%@\". Gwada sharuɗɗan kamar mataimaki, yanayi, abubuwan shiga, mashaya menu, ko Touch Bar."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "ʻAʻohe ʻāpana kōkua i pili \"%@\". E ho'āʻo i nā huaʻōlelo e like me ke kōkua, ka wā, nā mea komo, ka papa kuhikuhi, a i ʻole Touch Bar."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אין קטעי עזרה שתואמים את \"%@\". נסה מונחים כמו עוזר, מזג אוויר, פריטי כניסה, שורת תפריטים או Touch Bar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई सहायता अनुभाग \"%@\" से मेल नहीं खाता। सहायक, मौसम, लॉगिन आइटम, मेनू बार, या Touch Bar जैसे शब्द आज़माएँ।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Tsis muaj cov kev pab cuam txuam \"%@\". Sim cov ntsiab lus xws li tus pab, huab cua, cov khoom nkag, ntawv qhia zaub mov, lossis Touch Bar."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nijedan odjeljak pomoći ne odgovara \"%@\". Isprobajte pojmove kao što su pomoćnik, vrijeme, stavke za prijavu, traka izbornika ili Touch Bar."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Pa gen seksyon èd ki matche \"%@\". Eseye tèm tankou asistan, move tan, atik konekte, ba meni, oswa Touch Bar."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egyetlen súgórész sem felel meg a „%@” kifejezésnek. Próbáljon ki olyan kifejezéseket, mint a segítő, időjárás, bejelentkezési elemek, menüsor vagy Touch Bar."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@»-ին համապատասխան օգնության բաժիններ չկան: Փորձեք այնպիսի տերմիններ, ինչպիսիք են օգնականը, եղանակը, մուտքի տարրերը, ընտրացանկի գոտին կամ Touch Bar:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada bagian bantuan yang cocok dengan \"%@\". Coba istilah seperti pembantu, cuaca, item login, bilah menu, atau Touch Bar."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Enweghị ngalaba enyemaka dabara na \"%@\". Gbalịa okwu dị ka onye inyeaka, ihu igwe, ihe nbanye, mmanya menu, ma ọ bụ Touch Bar."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Engir hjálparhlutar passa við \"%@\". Prófaðu hugtök eins og hjálpar, veður, innskráningaratriði, valmyndarstiku eða Touch Bar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna sezione della guida corrispondente a \"%@\". Prova termini come aiuto, meteo, elementi di accesso, barra dei menu o Touch Bar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」に一致するヘルプ セクションはありません。ヘルパー、天気、ログイン項目、メニュー バー、Touch Bar などの用語を試してください。"
          }
