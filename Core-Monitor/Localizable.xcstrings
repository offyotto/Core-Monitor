    "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Hou ten minste een menubalkitem sigbaar, of aktiveer die dashboardkortpad as 'n terugval."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ቢያንስ አንድ የምናሌ አሞሌ ንጥል ነገር እንዲታይ ያቆዩ ወይም የዳሽቦርድ አቋራጭን እንደ መውደቅ ያንቁ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتفظ بعنصر واحد على الأقل في شريط القائمة مرئيًا، أو قم بتمكين اختصار لوحة المعلومات كإجراء احتياطي."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Ən azı bir menyu çubuğu elementini görünən saxlayın və ya idarəetmə paneli qısayolunu ehtiyat kimi aktivləşdirin."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Захоўвайце хаця б адзін пункт радка меню бачным або ўключыце ярлык на прыборнай панэлі ў якасці рэзервовага варыянту."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддържайте видим поне един елемент от лентата с менюта или активирайте прекия път на таблото като резервен вариант."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "অন্তত একটি মেনু বার আইটেম দৃশ্যমান রাখুন, অথবা ফলব্যাক হিসাবে ড্যাশবোর্ড শর্টকাট সক্ষম করুন৷"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Neka barem jedna stavka na traci menija bude vidljiva ili omogućite prečicu na kontrolnoj tabli kao zamjenu."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Manteniu com a mínim un element de la barra de menú visible o activeu la drecera del tauler com a alternativa."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ipadayon ang labing menos usa ka butang sa menu bar nga makita, o i-enable ang shortcut sa dashboard isip fallback."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantene almenu un articulu di a barra di menu visibile, o attivate u shortcut di u dashboard cum'è fallback."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponechte viditelnou alespoň jednu položku na panelu nabídek nebo povolte zástupce řídicího panelu jako záložní."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Cadwch o leiaf un eitem bar dewislen yn weladwy, neu galluogwch lwybr byr y dangosfwrdd fel wrth gefn."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold mindst ét menulinjeelement synligt, eller aktiver dashboard-genvejen som et alternativ."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie mindestens ein Menüleistenelement sichtbar oder aktivieren Sie die Dashboard-Verknüpfung als Ersatz."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διατηρήστε τουλάχιστον ένα στοιχείο της γραμμής μενού ορατό ή ενεργοποιήστε τη συντόμευση του πίνακα εργαλείων ως εναλλακτική."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep at least one menu bar item visible, or enable the dashboard shortcut as a fallback."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Konservu almenaŭ unu menubreton videbla, aŭ ebligu la ŝparvojon de panelo kiel rezervilon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenga visible al menos un elemento de la barra de menú o habilite el acceso directo del panel como alternativa."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoidke vähemalt üks menüüriba üksus nähtaval või lubage armatuurlaua otsetee tagavarana."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantendu gutxienez menu-barrako elementu bat ikusgai, edo gaitu paneleko lasterbidea ordezko gisa."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "حداقل یک مورد از نوار منو را قابل مشاهده نگه دارید یا میانبر داشبورد را به عنوان جایگزین فعال کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä vähintään yksi valikkopalkin kohde näkyvissä tai ota hallintapaneelin pikakuvake käyttöön varavaihtoehtona."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Panatilihin ang hindi bababa sa isang item sa menu bar na nakikita, o paganahin ang dashboard shortcut bilang isang fallback."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
