        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ਨਾਲ ਮੇਲ ਖਾਂਦਾ ਕੋਈ ਮਦਦ ਸੈਕਸ਼ਨ ਨਹੀਂ। ਸਹਾਇਕ, ਮੌਸਮ, ਲੌਗਇਨ ਆਈਟਮਾਂ, ਮੀਨੂ ਬਾਰ, ਜਾਂ Touch Bar ਵਰਗੇ ਸ਼ਬਦਾਂ ਦੀ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żadne sekcje pomocy nie pasują do „%@”. Wypróbuj terminy takie jak pomocnik, pogoda, elementy logowania, pasek menu lub Touch Bar."
