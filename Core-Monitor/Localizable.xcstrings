          "stringUnit": {
            "state": "translated",
            "value": "ប្រើផ្ទាំង 'អ្នកគាំទ្រ' ដើម្បីប្តូរទម្រង់ ឬកែតម្រូវការកំណត់។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪ್ರೊಫೈಲ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಲು ಅಥವಾ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಹೊಂದಿಸಲು `ಅಭಿಮಾನಿಗಳು` ಟ್ಯಾಬ್ ಬಳಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'팬' 탭을 사용하여 프로필을 전환하거나 설정을 조정하세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Tabloya `Fans` bikar bînin da ku profîlan biguhezînin an mîhengan biguherînin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Профильдерди которуштуруу же жөндөөлөрдү тууралоо үчүн \"Күйөрмандар\" өтмөгүн колдонуңуз."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "`Fans` tab utere ut profiles mutandae vel occasus accommodent."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Benotzt den Tab \"Fans\" fir Profiler ze wiesselen oder Astellungen unzepassen."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ໃຊ້ແຖບ 'ແຟນ' ເພື່ອສະຫຼັບໂປຣໄຟລ໌ ຫຼືປັບການຕັ້ງຄ່າ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Norėdami perjungti profilius arba koreguoti nustatymus, naudokite skirtuką „Ventiliatoriai“."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izmantojiet cilni Fani, lai pārslēgtu profilus vai pielāgotu iestatījumus."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ampiasao ny tabilao `Fans` hanovana ny mombamomba na hanitsiana ny fanovana."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Whakamahia te ripa `Fans` ki te huri i nga korero, ki te whakatika ranei i nga tautuhinga."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Користете го табулаторот „Фанови“ за да менувате профили или да ги приспособите поставките."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പ്രൊഫൈലുകൾ മാറുന്നതിനോ ക്രമീകരണങ്ങൾ ക്രമീകരിക്കുന്നതിനോ `ഫാൻസ്' ടാബ് ഉപയോഗിക്കുക."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Профайл сэлгэх эсвэл тохиргоог тохируулахын тулд \"Фэнүүд\" табыг ашиглана уу."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रोफाइल स्विच करण्यासाठी किंवा सेटिंग्ज समायोजित करण्यासाठी `चाहते` टॅब वापरा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan tab `Peminat` untuk menukar profil atau melaraskan tetapan."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Uża t-tab \"Fansijiet\" biex taqleb il-profili jew taġġusta s-settings."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ပရိုဖိုင်များကို ပြောင်းရန် သို့မဟုတ် ဆက်တင်များကို ချိန်ညှိရန် 'ပရိသတ်များ' တက်ဘ်ကို အသုံးပြုပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk fanen for å bytte profil eller justere innstillinger."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रोफाइलहरू स्विच गर्न वा सेटिङहरू समायोजन गर्न 'फ्यान्स' ट्याब प्रयोग गर्नुहोस्।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik het tabblad 'Fans' om van profiel te wisselen of instellingen aan te passen."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Gwiritsani ntchito tabu ya `Fans` kusintha mbiri kapena kusintha makonda."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the `Fans` tab to switch profiles or adjust settings."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪ੍ਰੋਫਾਈਲਾਂ ਨੂੰ ਬਦਲਣ ਜਾਂ ਸੈਟਿੰਗਾਂ ਨੂੰ ਵਿਵਸਥਿਤ ਕਰਨ ਲਈ 'ਪ੍ਰਸ਼ੰਸਕਾਂ' ਟੈਬ ਦੀ ਵਰਤੋਂ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj zakładki „Wentylatory”, aby przełączać profile lub dostosowywać ustawienia."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د پروفایلونو بدلولو یا تنظیماتو تنظیم کولو لپاره د 'Fans' ټب وکاروئ."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a guia `Fãs` para alternar perfis ou ajustar configurações."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizați fila „Ventilatori” pentru a schimba profilurile sau pentru a ajusta setările."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте вкладку «Поклонники» для переключения профилей или настройки параметров."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the `Fans` tab to switch profiles or adjust settings."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "پروفائل کي تبديل ڪرڻ يا سيٽنگون ترتيب ڏيڻ لاء 'Fans' ٽيب استعمال ڪريو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "පැතිකඩ මාරු කිරීමට හෝ සැකසීම් සීරුමාරු කිරීමට `ෆෑන්ස්' ටැබය භාවිත කරන්න."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomocou karty „Fanúšikovia“ môžete prepínať profily alebo upravovať nastavenia."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Za menjavo profilov ali prilagajanje nastavitev uporabite zavihek `Fans`."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Fa'aoga le 'Fans' tab e sui ai fa'amatalaga po'o fetu'una'i tulaga."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Shandisa iyo `Fans` tab kuchinja maprofile kana kugadzirisa marongero."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Isticmaal tab 'Taageerayaasha' si aad u bedesho profile-yada ama u hagaajiso dejinta."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Përdorni skedën \"Tifozët\" për të ndërruar profilet ose për të rregulluar cilësimet."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the `Fans` tab to switch profiles or adjust settings."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebelisa tab ea `Fans` ho chencha liprofaele kapa ho lokisa li-setting."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Pake tab `Fans` pikeun pindah propil atawa nyaluyukeun setelan."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd fliken \"Fans\" för att byta profil eller justera inställningar."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Tumia kichupo cha `Mashabiki` kubadili wasifu au kurekebisha mipangilio."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "சுயவிவரங்களை மாற்ற அல்லது அமைப்புகளைச் சரிசெய்ய `ரசிகர்கள்' தாவலைப் பயன்படுத்தவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రొఫైల్‌లను మార్చడానికి లేదా సెట్టింగ్‌లను సర్దుబాటు చేయడానికి `ఫ్యాన్స్` ట్యాబ్‌ని ఉపయోగించండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Барои иваз кардани профилҳо ё танзим кардани танзимот, ҷадвали 'Мухлисони'-ро истифода баред."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้แท็บ \"แฟนๆ\" เพื่อสลับโปรไฟล์หรือปรับการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilleri değiştirmek veya ayarları düzenlemek için \"Hayranlar\" sekmesini kullanın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте вкладку «Прихильники», щоб перемикати профілі або регулювати налаштування."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پروفائلز کو تبدیل کرنے یا ترتیبات کو ایڈجسٹ کرنے کے لیے 'فینز' ٹیب کا استعمال کریں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Profillarni almashtirish yoki sozlamalarni o‘zgartirish uchun “Muxlislar” yorlig‘idan foydalaning."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng tab `Người hâm mộ` để chuyển cấu hình hoặc điều chỉnh cài đặt."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebenzisa ithebhu ethi `Abalandeli` ukutshintsha iinkangeleko okanye ukulungisa useto."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "ניצן די 'פאַנס' קוויטל צו באַשטימען פּראָופיילז אָדער סטרויערן סעטטינגס."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo taabu `Awọn onijakidijagan` lati yi awọn profaili pada tabi ṣatunṣe awọn eto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用“粉丝”选项卡切换配置文件或调整设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用“粉絲”選項卡切換設定檔或調整設定。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebenzisa ithebhu `Abalandeli` ukushintsha amaphrofayili noma ukulungisa izilungiselelo."
          }
        }
      }
    },
