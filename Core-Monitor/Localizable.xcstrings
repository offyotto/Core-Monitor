            "value": "Uygulamadan ayrılmadan kontrol panelini herhangi bir paket yerelleştirmeye değiştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перемикайте інформаційну панель на будь-яку включену локалізацію, не виходячи з програми."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایپ کو چھوڑے بغیر ڈیش بورڈ کو کسی بھی بنڈل لوکلائزیشن پر سوئچ کریں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilovadan chiqmasdan asboblar panelini istalgan to‘plamli lokalizatsiyaga o‘tkazing."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển bảng điều khiển sang bất kỳ bản địa hóa gói nào mà không cần rời khỏi ứng dụng."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Tshintshela ideshbhodi kuyo nayiphi na inyanda yasekuhlaleni ngaphandle kokushiya i-app."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "באַשטימען די דאַשבאָרד צו קיין באַנדאַלד לאָוקאַלאַזיישאַן אָן פאַרלאָזן די אַפּ."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Yipada dasibodu si eyikeyi isọdi-dipọ lai fi ohun elo naa silẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需离开应用程序即可将仪表板切换到任何捆绑的本地化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無需離開應用程式即可將儀表板切換到任何捆綁的本地化。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Shintshela ideshibhodi kunoma yikuphi ukwenza kwasendaweni okuyinqwaba ngaphandle kokushiya uhlelo lokusebenza."
          }
        }
      }
    },
