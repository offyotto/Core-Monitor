        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Немає розділів довідки, які б відповідали \"%@\". Спробуйте такі терміни, як помічник, погода, елементи входу, рядок меню або Touch Bar."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" سے مماثل کوئی مدد سیکشن نہیں ہے۔ مددگار، موسم، لاگ ان آئٹمز، مینو بار، یا Touch Bar جیسی اصطلاحات آزمائیں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”ga mos keladigan yordam bo‘limlari topilmadi. Yordamchi, ob-havo, kirish elementlari, menyu paneli yoki Touch Bar kabi shartlarni sinab ko'ring."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có phần trợ giúp nào khớp với \"%@\". Hãy thử các thuật ngữ như trợ giúp, thời tiết, mục đăng nhập, thanh menu hoặc Touch Bar."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Akukho candelo loncedo elihambelanayo \"%@\". Zama amagama afana nomncedisi, imozulu, izinto zokungena, ibha yemenyu, okanye Touch Bar."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "קיין הילף סעקשאַנז מאַטשט \"%@\". פּרוּווט טערמינען ווי העלפּער, וועטער, לאָגין זאכן, מעניו באַר אָדער Touch Bar."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko si awọn apakan iranlọwọ ti o baamu \"%@\". Gbiyanju awọn ofin bii oluranlọwọ, oju ojo, awọn ohun iwọle, ọpa akojọ aṣayan, tabi Touch Bar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有与“%@”匹配的帮助部分。尝试使用帮助程序、天气、登录项、菜单栏或 Touch Bar 等术语。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有與“%@”相符的幫助部分。嘗試使用幫助程式、天氣、登入項目、功能表列或 Touch Bar 等術語。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Azikho izigaba zosizo ezifaniswe ne-\"%@\". Zama amagama afana nomsizi, isimo sezulu, izinto zokungena, ibha yemenyu, noma Touch Bar."
          }
        }
      }
    },
