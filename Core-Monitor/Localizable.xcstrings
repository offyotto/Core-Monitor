        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma widget omwe akugwira ntchito ndi okulirapo kuposa Touch Bar yathunthu. Chepetsani kapena sinthaninso ma widget kuti musadule."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "The active widget stack is wider than a full Touch Bar. Trim or reorder widgets to avoid clipping."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਕਿਰਿਆਸ਼ੀਲ ਵਿਜੇਟ ਸਟੈਕ ਪੂਰੇ Touch Bar ਨਾਲੋਂ ਚੌੜਾ ਹੈ। ਕਲਿੱਪਿੰਗ ਤੋਂ ਬਚਣ ਲਈ ਵਿਜੇਟਸ ਨੂੰ ਕੱਟੋ ਜਾਂ ਮੁੜ ਕ੍ਰਮਬੱਧ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktywny stos widżetów jest szerszy niż pełny Touch Bar. Przytnij lub zmień kolejność widżetów, aby uniknąć przycinania."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د فعال ویجټ سټیک د بشپړ Touch Bar څخه پراخه دی. د کلپ کولو څخه مخنیوي لپاره ویجټونه ټرم یا تنظیم کړئ."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A pilha de widgets ativa é maior que um Touch Bar completo. Corte ou reordene os widgets para evitar cortes."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Stiva de widget-uri active este mai larg decât un Touch Bar complet. Tăiați sau reordonați widget-urile pentru a evita tăierea."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стек активных виджетов шире, чем полный Touch Bar. Обрезайте или меняйте порядок виджетов, чтобы избежать обрезки."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "The active widget stack is wider than a full Touch Bar. Trim or reorder widgets to avoid clipping."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "فعال ويجيٽ اسٽيڪ مڪمل Touch Bar کان وڌيڪ وسيع آهي. ڪلپنگ کان بچڻ لاءِ ويجيٽس کي ٽرم يا وري ترتيب ڏيو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "සක්‍රිය විජට් තොගය සම්පූර්ණ Touch Bar එකකට වඩා පුළුල් වේ. ක්ලිප් කිරීම වළක්වා ගැනීමට විජට් කප්පාදු කරන්න හෝ නැවත ඇණවුම් කරන්න."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zásobník aktívnych miniaplikácií je širší ako celý Touch Bar. Orezajte alebo zmeňte poradie miniaplikácií, aby ste predišli orezaniu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sklad aktivnih pripomočkov je širši od celotnega Touch Bar. Obrežite ali preuredite pripomočke, da se izognete izrezovanju."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Ole fa'aputuga widget galue e lautele atu nai lo le Touch Bar atoa. 'Oti pe toe fa'atonu widget e 'alofia ai le tipiina."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Iyo inoshanda widget stack yakakura kupfuura yakazara Touch Bar. Cheka kana kurodha majeti kuti udzivise kuchekerera."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Xirmada widget-ka firfircoon ayaa ka ballaaran Touch Bar buuxa. Jar ama dib u habbee widgets si aad uga fogaato goynta."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Stafi i miniaplikacioneve aktive është më i gjerë se një Touch Bar e plotë. Pritini ose rirenditni miniaplikacionet për të shmangur prerjen."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "The active widget stack is wider than a full Touch Bar. Trim or reorder widgets to avoid clipping."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebaka sa widget se sebetsang se pharalletse ho feta Touch Bar e felletseng. Fokotsa kapa u hlophise bocha li-widget ho qoba ho sekoa."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Tumpukan widget aktip leuwih lega ti Touch Bar pinuh. Motong atanapi susun ulang widget pikeun nyegah clipping."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den aktiva widgetstacken är bredare än en full Touch Bar. Trimma eller ändra ordning på widgets för att undvika klippning."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Rafu ya wijeti inayotumika ni pana kuliko Touch Bar kamili. Punguza au upange upya wijeti ili kuzuia kukatwa."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "செயலில் உள்ள விட்ஜெட் அடுக்கு முழு Touch Bar ஐ விட அகலமானது. கிளிப்பிங்கைத் தவிர்க்க விட்ஜெட்களை ஒழுங்கமைக்கவும் அல்லது மறுவரிசைப்படுத்தவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "సక్రియ విడ్జెట్ స్టాక్ పూర్తి Touch Bar కంటే వెడల్పుగా ఉంది. క్లిప్పింగ్‌ను నివారించడానికి విడ్జెట్‌లను ట్రిమ్ చేయండి లేదా క్రమాన్ని మార్చండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Стеки виджетҳои фаъол нисбат ба пурраи Touch Bar васеътар аст. Виҷетҳоро буред ё аз нав тартиб диҳед, то бурида нашавед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สแต็กวิดเจ็ตที่ใช้งานอยู่กว้างกว่า Touch Bar แบบเต็ม ตัดหรือจัดลำดับวิดเจ็ตใหม่เพื่อหลีกเลี่ยงการคลิป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktif widget yığını tam Touch Bar'den daha geniştir. Kırpılmayı önlemek için widget'ları kırpın veya yeniden sıralayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Стек активних віджетів ширший, ніж повний Touch Bar. Обріжте або змініть порядок віджетів, щоб уникнути обрізання."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "فعال ویجیٹ اسٹیک مکمل Touch Bar سے زیادہ وسیع ہے۔ تراشنے سے بچنے کے لیے ویجٹ کو تراشیں یا دوبارہ ترتیب دیں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Faol vidjetlar to‘plami to‘liq Touch Bar dan kengroq. Kesishni oldini olish uchun vidjetlarni qisqartiring yoki qayta tartiblang."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngăn xếp tiện ích đang hoạt động rộng hơn Touch Bar đầy đủ. Cắt bớt hoặc sắp xếp lại các vật dụng để tránh bị cắt bớt."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Isitaki sewijethi esebenzayo ibanzi kune-Touch Bar epheleleyo. Sika okanye uhlengahlengise iiwijethi ukunqanda ukucofa."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "די אַקטיוו ווידזשיט סטאַק איז ברייט ווי אַ פול Touch Bar. טרים אָדער ריאָרדער ווידזשיץ צו ויסמיידן קליפּינג."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Akopọ ẹrọ ailorukọ ti nṣiṣe lọwọ gbooro ju Touch Bar ni kikun. Gee tabi tunto awọn ẹrọ ailorukọ lati yago fun gige gige."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动小部件堆栈比完整的 Touch Bar 更宽。修剪或重新排序小部件以避免剪辑。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "活動小部件堆疊比完整的 Touch Bar 更寬。修剪或重新排序小部件以避免剪輯。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Isitaki sewijethi esebenzayo sikhulu kune-Touch Bar ephelele. Sika noma uhlele kabusha amawijethi ukuze ugweme ukusika."
          }
        }
      }
    },
    "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Die voorskou wys waaierspoed persentasie teenoor effektiewe temperatuur. Power Boost verhoog die effektiewe temperatuur onder volgehoue ​​watt-trekking voordat die kurwe geëvalueer word."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ቅድመ እይታው የደጋፊዎች ፍጥነት መቶኛ ውጤታማ በሆነ የሙቀት መጠን ላይ ያሳያል። የኃይል ማበልጸጊያ ኩርባው ከመገመቱ በፊት በቋሚ ዋት ስእል ስር ውጤታማውን የሙቀት መጠን ከፍ ያደርገዋል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعرض المعاينة النسبة المئوية لسرعة المروحة مقابل درجة الحرارة الفعالة. يعمل Power Boost على رفع درجة الحرارة الفعالة في ظل سحب مستمر للواط قبل تقييم المنحنى."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Önizləmə effektiv temperatura qarşı fan sürətinin faizini göstərir. Güc Artırma əyri qiymətləndirilməzdən əvvəl davamlı vatt çəkilişi altında effektiv temperaturu artırır."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Папярэдні прагляд паказвае працэнт хуткасці вентылятара ад эфектыўнай тэмпературы. Power Boost павышае эфектыўную тэмпературу пры ўстойлівым спажыванні ват перад ацэнкай крывой."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Визуализацията показва процента на скоростта на вентилатора спрямо ефективната температура. Power Boost повишава ефективната температура при продължително потребление на вата, преди кривата да бъде оценена."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রিভিউ কার্যকর তাপমাত্রার বিপরীতে ফ্যানের গতি শতাংশ দেখায়। বক্ররেখা মূল্যায়ন করার আগে পাওয়ার বুস্ট টেকসই ওয়াট ড্রয়ের অধীনে কার্যকর তাপমাত্রা বাড়ায়।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pregled pokazuje procenat brzine ventilatora u odnosu na efektivnu temperaturu. Power Boost podiže efektivnu temperaturu pod stalnim potrošnjom vata prije nego što se procijeni kriva."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La vista prèvia mostra el percentatge de velocitat del ventilador en funció de la temperatura efectiva. Power Boost augmenta la temperatura efectiva sota un consum de watts sostingut abans que s'avaluï la corba."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang preview nagpakita sa fan speed percentage batok sa epektibong temperatura. Ang Power Boost mopataas sa epektibong temperatura ubos sa sustained watt draw sa dili pa ma-evaluate ang curve."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "L'anteprima mostra u percentualità di a velocità di u fan contr'à a temperatura efficace. Power Boost aumenta a temperatura efficace sottu un tiratu di watt sustinutu prima chì a curva hè evaluata."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Náhled ukazuje procento rychlosti ventilátoru vzhledem k efektivní teplotě. Power Boost zvyšuje efektivní teplotu při trvalém odběru wattů před vyhodnocením křivky."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae'r rhagolwg yn dangos canran cyflymder y gefnogwr yn erbyn tymheredd effeithiol. Mae Power Boost yn codi'r tymheredd effeithiol o dan luniad wat parhaus cyn gwerthuso'r gromlin."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Forhåndsvisningen viser blæserhastighedsprocent i forhold til effektiv temperatur. Power Boost hæver den effektive temperatur under vedvarende watttræk, før kurven evalueres."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Vorschau zeigt den Prozentsatz der Lüftergeschwindigkeit im Vergleich zur effektiven Temperatur. Power Boost erhöht die effektive Temperatur bei anhaltender Wattaufnahme, bevor die Kurve ausgewertet wird."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η προεπισκόπηση δείχνει το ποσοστό ταχύτητας ανεμιστήρα σε σχέση με την ενεργή θερμοκρασία. Το Power Boost αυξάνει την ενεργή θερμοκρασία υπό παρατεταμένη έλξη watt πριν από την αξιολόγηση της καμπύλης."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "La antaŭvido montras ventumilan rapidprocenton kontraŭ efika temperaturo. Power Boost altigas la efikan temperaturon sub daŭra vata remizo antaŭ ol la kurbo estas taksita."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La vista previa muestra el porcentaje de velocidad del ventilador frente a la temperatura efectiva. Power Boost eleva la temperatura efectiva bajo consumo sostenido de vatios antes de que se evalúe la curva."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Eelvaade näitab ventilaatori kiiruse protsenti efektiivse temperatuuri suhtes. Power Boost tõstab enne kõvera hindamist efektiivset temperatuuri püsiva vatitarbimise korral."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Aurrebistak haizagailuaren abiaduraren ehunekoa erakusten du tenperatura eraginkorrarekin alderatuta. Power Boost-ek tenperatura eraginkorra igotzen du watt-en kontsumo iraunkorrean kurba ebaluatu aurretik."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش نمایش درصد سرعت فن را در برابر دمای موثر نشان می دهد. Power Boost قبل از ارزیابی منحنی، دمای موثر را تحت کشش پایدار وات افزایش می دهد."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Esikatselu näyttää tuulettimen nopeuden prosentteina tehollisen lämpötilan suhteen. Power Boost nostaa tehollista lämpötilaa jatkuvalla watinkulutuksella ennen käyrän arviointia."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ipinapakita ng preview ang porsyento ng bilis ng fan laban sa epektibong temperatura. Pinapataas ng Power Boost ang epektibong temperatura sa ilalim ng sustained watt draw bago masuri ang curve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'aperçu affiche le pourcentage de vitesse du ventilateur par rapport à la température effective. Power Boost augmente la température effective en cas de consommation de watts soutenue avant que la courbe ne soit évaluée."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "De foarbyld toant fan snelheid persintaazje tsjin effektive temperatuer. Power Boost ferheget de effektive temperatuer ûnder oanhâldende watt-tekening foardat de kromme wurdt evaluearre."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Taispeánann an réamhamharc céatadán luas an lucht leanúna i gcoinne teocht éifeachtach. Ardaíonn Power Boost an teocht éifeachtach faoi tharraingt marthanach vata sula ndéantar an cuar a mheas."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Tha an ro-shealladh a’ sealltainn ceudad astar luchd-leantainn an aghaidh teòthachd èifeachdach. Bidh Power Boost ag àrdachadh an teòthachd èifeachdach fo tharraing watt seasmhach mus tèid an lùb a mheasadh."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "A vista previa mostra a porcentaxe de velocidade do ventilador fronte á temperatura efectiva. Power Boost aumenta a temperatura efectiva baixo un consumo de watts sostido antes de que se avalie a curva."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "પૂર્વાવલોકન અસરકારક તાપમાન સામે પંખાની ઝડપની ટકાવારી બતાવે છે. વળાંકનું મૂલ્યાંકન કરવામાં આવે તે પહેલાં પાવર બૂસ્ટ ટકાઉ વોટ ડ્રો હેઠળ અસરકારક તાપમાનમાં વધારો કરે છે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Samfotin yana nuna yawan saurin fan akan ingantaccen zafin jiki. Ƙarfafawar wutar lantarki yana ɗaga ingantaccen zafin jiki a ƙarƙashin dorewar watt zane kafin a kimanta lanƙwasa."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hōʻike ka manaʻo i ka pākēneka o ka wikiwiki o ka peʻahi i ka wela kūpono. Hoʻokiʻekiʻe ka Power Boost i ka wela kūpono ma lalo o ke kaha kiʻi watt ma mua o ka loiloi ʻia ʻana o ka pihi."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התצוגה המקדימה מציגה את אחוז מהירות המאוורר מול הטמפרטורה האפקטיבית. Power Boost מעלה את הטמפרטורה האפקטיבית תחת צריכת וואט מתמשכת לפני הערכת העקומה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्वावलोकन प्रभावी तापमान के विरुद्ध पंखे की गति का प्रतिशत दिखाता है। पावर बूस्ट वक्र का मूल्यांकन करने से पहले निरंतर वाट ड्रॉ के तहत प्रभावी तापमान बढ़ाता है।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Kev saib ua ntej qhia cov kiv cua nrawm feem pua ​​ntawm qhov kub thiab txias. Fais fab Boost nce qhov kub zoo hauv qab watt kos ua ntej qhov nkhaus raug ntsuas."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pregled pokazuje postotak brzine ventilatora u odnosu na efektivnu temperaturu. Power Boost podiže efektivnu temperaturu pod trajnom potrošnjom vata prije nego što se krivulja procijeni."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview a montre pousantaj vitès fanatik kont tanperati efikas. Pouvwa Boost ogmante tanperati efikas anba watt soutni trase anvan koub la evalye."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az előnézet a ventilátor sebességének százalékos arányát mutatja az effektív hőmérséklet függvényében. A Power Boost növeli az effektív hőmérsékletet tartós wattfelvétel mellett, mielőtt kiértékelné a görbét."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Նախադիտումը ցույց է տալիս օդափոխիչի արագության տոկոսը արդյունավետ ջերմաստիճանի նկատմամբ: Power Boost-ը բարձրացնում է արդյունավետ ջերմաստիճանը կայուն վտ գծով մինչև կորի գնահատումը:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratinjau menunjukkan persentase kecepatan kipas terhadap suhu efektif. Power Boost meningkatkan suhu efektif dengan konsumsi watt yang berkelanjutan sebelum kurva dievaluasi."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihe nhụchalụ na-egosi pasenti ọsọ fan megide okpomọkụ dị irè. Nkwalite ike na-ebuli okpomọkụ dị irè n'okpuru eserese watt na-adịgide adịgide tupu enyocha usoro ahụ."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Forskoðunin sýnir hlutfall viftuhraða á móti virku hitastigi. Power Boost hækkar virkan hitastig við viðvarandi wattadrátt áður en ferillinn er metinn."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'anteprima mostra la percentuale della velocità della ventola rispetto alla temperatura effettiva. Power Boost aumenta la temperatura effettiva in caso di assorbimento di watt prolungato prima che la curva venga valutata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレビューには、実効温度に対するファン速度の割合が表示されます。 Power Boost は、曲線が評価される前に、持続的なワット消費の下で実効温度を上昇させます。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratinjau nuduhake persentase kacepetan penggemar nglawan suhu efektif. Power Boost ngunggahake suhu efektif ing watt sing terus-terusan sadurunge kurva dievaluasi."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "გადახედვა აჩვენებს ვენტილატორის სიჩქარის პროცენტს ეფექტური ტემპერატურის მიმართ. სიმძლავრის გაძლიერება ზრდის ეფექტურ ტემპერატურას მუდმივი ვატის გაყვანის პირობებში, სანამ მრუდი შეფასდება."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Алдын ала қарау тиімді температураға қарсы желдеткіш жылдамдығының пайызын көрсетеді. Қуатты күшейту қисық бағаланбай тұрып тұрақты ватт тарту кезінде тиімді температураны көтереді."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ការមើលជាមុនបង្ហាញពីភាគរយល្បឿនកង្ហារធៀបនឹងសីតុណ្ហភាពដែលមានប្រសិទ្ធភាព។ Power Boost បង្កើនសីតុណ្ហភាពប្រកបដោយប្រសិទ្ធភាពក្រោមការអូសទាញវ៉ាត់ដែលមាននិរន្តរភាព មុនពេលខ្សែកោងត្រូវបានវាយតម្លៃ។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪೂರ್ವವೀಕ್ಷಣೆ ಪರಿಣಾಮಕಾರಿ ತಾಪಮಾನದ ವಿರುದ್ಧ ಫ್ಯಾನ್ ವೇಗದ ಶೇಕಡಾವನ್ನು ತೋರಿಸುತ್ತದೆ. ಪವರ್ ಬೂಸ್ಟ್ ಕರ್ವ್ ಅನ್ನು ಮೌಲ್ಯಮಾಪನ ಮಾಡುವ ಮೊದಲು ನಿರಂತರ ವ್ಯಾಟ್ ಡ್ರಾ ಅಡಿಯಲ್ಲಿ ಪರಿಣಾಮಕಾರಿ ತಾಪಮಾನವನ್ನು ಹೆಚ್ಚಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미리보기에는 유효 온도 대비 팬 속도 비율이 표시됩니다. Power Boost는 곡선이 평가되기 전에 지속적인 전력 소모에서 유효 온도를 높입니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Pêşdîtin rêjeya leza fanoyê li hember germahiya bi bandor nîşan dide. Hêz Boost germahiya bandorker di bin kişandina watt ya domdar de berî ku çîçek were nirxandin bilind dike."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Алдын ала көрүү эффективдүү температурага карата желдеткич ылдамдыгын көрсөтөт. Power Boost ийри сызык бааланганга чейин туруктуу ватт тартуу астында эффективдүү температураны жогорулатат."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Praevius ostendit celeritatem ventilationis recipis contra temperiem efficacem. Potestas Boost suscitat effectivam temperaturam sub watt sustentato trahere antequam curva aestimatur."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "D'Virschau weist Fangeschwindegkeet Prozentsaz géint effektiv Temperatur. Power Boost erhéicht déi effektiv Temperatur ënner nohaltege Watt Zeechnen ier d'Kurve evaluéiert gëtt."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ການສະແດງຕົວຢ່າງສະແດງໃຫ້ເຫັນອັດຕາສ່ວນຄວາມໄວພັດລົມຕໍ່ກັບອຸນຫະພູມທີ່ມີປະສິດທິພາບ. Power Boost ເພີ່ມອຸນຫະພູມທີ່ມີປະສິດທິພາບພາຍໃຕ້ການແຕ້ມວັດທີ່ຍືນຍົງກ່ອນທີ່ເສັ້ນໂຄ້ງຈະຖືກປະເມີນ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Peržiūra rodo ventiliatoriaus greičio procentą nuo efektyvios temperatūros. „Power Boost“ padidina efektyvią temperatūrą esant nuolatiniam vatų suvartojimui prieš įvertinant kreivę."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Priekšskatījums parāda ventilatora ātruma procentuālo attiecību pret faktisko temperatūru. Power Boost paaugstina efektīvo temperatūru ar ilgstošu vatu patēriņu, pirms tiek novērtēta līkne."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ny preview dia mampiseho ny isan-jaton'ny hafainganan'ny mpankafy manohitra ny mari-pana mahomby. Power Boost dia mampiakatra ny mari-pana mahomby eo ambanin'ny fisarihana watt maharitra alohan'ny hanombanana ny curve."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko te arokite e whakaatu ana i te ōrau tere o te pā ki te pāmahana whai hua. Ko te Whakanui Hiko ka hiki ake te pāmahana whai hua i raro i te tohanga watt totini i mua i te arotakenga o te ānau."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прегледот го прикажува процентот на брзина на вентилаторот во однос на ефективната температура. Засилувањето на моќноста ја зголемува ефективната температура при постојано исцрпување на вати пред да се оцени кривата."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പ്രിവ്യൂ ഫലപ്രദമായ താപനിലയ്‌ക്കെതിരായ ഫാൻ വേഗതയുടെ ശതമാനം കാണിക്കുന്നു. പവർ ബൂസ്റ്റ്, കർവ് മൂല്യനിർണ്ണയം നടത്തുന്നതിന് മുമ്പ് സുസ്ഥിരമായ വാട്ട് ഡ്രോക്ക് കീഴിൽ ഫലപ്രദമായ താപനില ഉയർത്തുന്നു."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Урьдчилан харах нь үр дүнтэй температурын эсрэг сэнсний хурдны хувийг харуулж байна. Power Boost нь муруйг үнэлэхээс өмнө тогтмол ваттын зарцуулалтын үед үр дүнтэй температурыг нэмэгдүүлдэг."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्वावलोकन प्रभावी तापमानाच्या तुलनेत पंख्याच्या गतीची टक्केवारी दाखवते. वक्र मूल्यमापन करण्यापूर्वी पॉवर बूस्ट शाश्वत वॅट ड्रॉ अंतर्गत प्रभावी तापमान वाढवते."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratonton menunjukkan peratusan kelajuan kipas terhadap suhu berkesan. Power Boost menaikkan suhu berkesan di bawah cabutan watt mampan sebelum lengkung dinilai."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Il-preview turi persentaġġ tal-veloċità tal-fann kontra temperatura effettiva. Power Boost jgħolli t-temperatura effettiva taħt watt sostnut qabel ma tiġi evalwata l-kurva."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "အစမ်းကြည့်ရှုမှုတွင် ထိရောက်သောအပူချိန်နှင့် ပန်ကာအမြန်နှုန်းရာခိုင်နှုန်းကို ပြသသည်။ မျဉ်းကွေးကို အကဲဖြတ်ခြင်းမပြုမီ Power Boost သည် ရေရှည်တည်တံ့သော ဝပ်ဆွဲမှုအောက်တွင် ထိရောက်သောအပူချိန်ကို မြှင့်တင်ပေးပါသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Forhåndsvisningen viser viftehastighetsprosent mot effektiv temperatur. Power Boost øker den effektive temperaturen under vedvarende watttrekk før kurven evalueres."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्वावलोकनले प्रभावकारी तापमान विरुद्ध प्रशंसक गति प्रतिशत देखाउँछ। पावर बूस्टले वक्र मूल्याङ्कन गर्नु अघि दिगो वाट ड्र अन्तर्गत प्रभावकारी तापक्रम बढाउँछ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het voorbeeld toont het ventilatorsnelheidspercentage ten opzichte van de effectieve temperatuur. Power Boost verhoogt de effectieve temperatuur bij aanhoudend wattverbruik voordat de curve wordt geëvalueerd."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Zowoneratu zikuwonetsa kuthamanga kwa mafani motsutsana ndi kutentha kwabwino. Power Boost imakweza kutentha kwabwino pansi pa kujambula kokhazikika kwa watt isanayesedwe."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪੂਰਵਦਰਸ਼ਨ ਪ੍ਰਭਾਵਸ਼ਾਲੀ ਤਾਪਮਾਨ ਦੇ ਵਿਰੁੱਧ ਪੱਖੇ ਦੀ ਗਤੀ ਪ੍ਰਤੀਸ਼ਤਤਾ ਦਿਖਾਉਂਦਾ ਹੈ। ਕਰਵ ਦਾ ਮੁਲਾਂਕਣ ਕਰਨ ਤੋਂ ਪਹਿਲਾਂ ਪਾਵਰ ਬੂਸਟ ਨਿਰੰਤਰ ਵਾਟ ਡਰਾਅ ਦੇ ਅਧੀਨ ਪ੍ਰਭਾਵੀ ਤਾਪਮਾਨ ਨੂੰ ਵਧਾਉਂਦਾ ਹੈ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podgląd pokazuje procent prędkości wentylatora w stosunku do temperatury efektywnej. Funkcja Power Boost podnosi efektywną temperaturę przy stałym poborze mocy przed oceną krzywej."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "مخکتنه د مؤثره تودوخې پروړاندې د فین سرعت سلنه ښیې. د پاور بوسټ د دوامدار واټ ډراو لاندې مؤثره تودوخه لوړوي مخکې لدې چې منحنی ارزونه وشي."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A visualização mostra a porcentagem da velocidade do ventilador em relação à temperatura efetiva. O Power Boost aumenta a temperatura efetiva sob consumo sustentado de watts antes que a curva seja avaliada."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Previzualizarea arată procentul vitezei ventilatorului față de temperatura efectivă. Power Boost crește temperatura efectivă în caz de consum susținut de wați înainte ca curba să fie evaluată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предварительный просмотр показывает процент скорости вращения вентилятора в зависимости от эффективной температуры. Power Boost повышает эффективную температуру при постоянном энергопотреблении до оценки кривой."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "ڏيک ڏيکاري ٿو فين جي رفتار في سيڪڙو موثر درجه حرارت جي خلاف. وکر جو جائزو وٺڻ کان اڳ پاور بوسٽ پائيدار واٽ ڊرا جي تحت موثر درجه حرارت وڌائي ٿو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "පෙරදසුන ඵලදායී උෂ්ණත්වයට එරෙහිව විදුලි පංකා වේග ප්‍රතිශතය පෙන්වයි. පවර් බූස්ට් වක්‍රය ඇගයීමට පෙර තිරසාර වොට් ඇඳීම යටතේ ඵලදායී උෂ්ණත්වය ඉහළ නංවයි."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Náhľad zobrazuje percento rýchlosti ventilátora v porovnaní s efektívnou teplotou. Power Boost zvyšuje efektívnu teplotu pri trvalom odbere wattov pred vyhodnotením krivky."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Predogled prikazuje odstotek hitrosti ventilatorja glede na efektivno temperaturo. Power Boost zviša efektivno temperaturo pri trajni porabi vatov, preden se oceni krivulja."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "O le mua'i fa'aaliga o lo'o fa'aalia ai le pasene o le saoasaoa o le ili e fa'asaga i le vevela lelei. Power Boost e si'itia ai le vevela lelei i lalo ole sustained watt draw a'o le'i iloiloina le pi'o."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Yekutarisisa inoratidza kukurumidza kwe fan percent pakatarisana netembiricha inoshanda. Power Boost inosimudza tembiricha inoshanda pasi peiyo watt dhizaini isati yaitwa curve isati yaongororwa."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Aragtida horudhacku waxay muujinaysaa xawaaraha marawaxada boqolleyda lidka ku ah heerkulka waxtarka leh. Kobcinta Korontadu waxay kor u qaadaa heerkulka wax ku oolka leh ee ku hoos jira sawir gacmeedka watt ka hor inta aan la qiimeyn qalooca."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Pamja paraprake tregon përqindjen e shpejtësisë së ventilatorit kundrejt temperaturës efektive. Rritja e fuqisë rrit temperaturën efektive nën tërheqjen e qëndrueshme të vateve përpara se të vlerësohet kurba."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "The preview shows fan speed percentage against effective temperature. Power Boost raises the effective temperature under sustained watt draw before the curve is evaluated."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponahalo e bonts'a liperesente tsa lebelo la fan khahlano le mocheso o sebetsang. Power Boost e phahamisa mocheso o sebetsang tlas'a toro e tsitsitseng ea watt pele curve e hlahlojoa."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilik nembongkeun persentase laju kipas ngalawan suhu éféktif. Power Boost naekeun suhu anu efektif dina draw watt anu tetep sateuacan kurva dievaluasi."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Förhandsgranskningen visar procentuell fläkthastighet mot effektiv temperatur. Power Boost höjer den effektiva temperaturen under ihållande wattdrag innan kurvan utvärderas."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Onyesho la kukagua linaonyesha asilimia ya kasi ya shabiki dhidi ya halijoto faafu. Power Boost huongeza halijoto faafu chini ya mchoro endelevu wa wati kabla ya curve kutathminiwa."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "முன்னோட்டமானது பயனுள்ள வெப்பநிலைக்கு எதிராக விசிறி வேக சதவீதத்தைக் காட்டுகிறது. பவர் பூஸ்ட், வளைவை மதிப்பிடுவதற்கு முன், நீடித்த வாட் டிராவின் கீழ் பயனுள்ள வெப்பநிலையை உயர்த்துகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రివ్యూ ప్రభావవంతమైన ఉష్ణోగ్రతకు వ్యతిరేకంగా ఫ్యాన్ వేగం శాతాన్ని చూపుతుంది. పవర్ బూస్ట్ కర్వ్ మూల్యాంకనం చేయడానికి ముందు నిరంతర వాట్ డ్రాలో ప్రభావవంతమైన ఉష్ణోగ్రతను పెంచుతుంది."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Пешнамоиш фоизи суръати мухлисонро нисбат ба ҳарорати самаранок нишон медиҳад. Power Boost ҳарорати самарабахшро дар зери истихроҷи устувори ватт пеш аз арзёбии каҷ баланд мекунад."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ภาพตัวอย่างแสดงเปอร์เซ็นต์ความเร็วพัดลมเทียบกับอุณหภูมิที่มีประสิทธิภาพ Power Boost จะเพิ่มอุณหภูมิที่มีประสิทธิภาพภายใต้การใช้วัตต์อย่างต่อเนื่องก่อนที่จะประเมินเส้นโค้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önizleme, etkin sıcaklığa karşı fan hızı yüzdesini gösterir. Power Boost, eğri değerlendirilmeden önce sürekli watt çekişi altında etkin sıcaklığı yükseltir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Попередній перегляд показує відсоток швидкості вентилятора від ефективної температури. Power Boost підвищує ефективну температуру при постійному споживанні потужності перед тим, як буде оцінено криву."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش نظارہ موثر درجہ حرارت کے خلاف پنکھے کی رفتار کا فیصد دکھاتا ہے۔ پاور بوسٹ منحنی خطوط کا جائزہ لینے سے پہلے پائیدار واٹ ڈرا کے تحت موثر درجہ حرارت کو بڑھاتا ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko'rib chiqish fan tezligining samarali haroratga nisbatan foizini ko'rsatadi. Quvvatni oshirish egri chiziqni baholashdan oldin barqaror vatt quvvati ostida samarali haroratni oshiradi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bản xem trước hiển thị phần trăm tốc độ quạt so với nhiệt độ hiệu quả. Power Boost tăng nhiệt độ hiệu quả trong điều kiện tiêu thụ watt liên tục trước khi đánh giá đường cong."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Umboniso ubonisa isantya sabalandeli ngokuchasene nobushushu obusebenzayo. I-Power Boost inyusa ubushushu obusebenzayo phantsi kwe-watt draw ezinzileyo ngaphambi kokuba igophe livavanywe."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "די פאָרויסיקע ווייַזונג ווייזט פאָכער גיכקייַט פּראָצענט קעגן עפעקטיוו טעמפּעראַטור. מאַכט בוסט רייזאַז די עפעקטיוו טעמפּעראַטור אונטער סוסטאַינעד וואט ציען איידער די ויסבייג איז עוואַלואַטעד."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Awotẹlẹ naa fihan iwọn iyara afẹfẹ lodi si iwọn otutu to munadoko. Igbelaruge Agbara gbe iwọn otutu ti o munadoko wa labẹ iyaworan watt ti o duro šaaju ki o to ṣe iṣiro ohun ti tẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预览显示风扇速度相对于有效温度的百分比。在评估曲线之前，功率提升会提高持续功耗下的有效温度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預覽顯示風扇速度相對於有效溫度的百分比。在評估曲線之前，功率提升會提高持續功耗下的有效溫度。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukuhlola kuqala kubonisa iphesenti lesivinini sabalandeli ngokumelene nezinga lokushisa elisebenzayo. I-Power Boost inyusa izinga lokushisa elisebenzayo ngaphansi kwe-watt draw eqhubekayo ngaphambi kokuba ijika lihlolwe."
          }
        }
      }
    },
    "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Die verslag vang programondertekening, hulpinstallasiestatus, konnektiwiteit, goedkeuring van bekendstelling by-aanmelding en kieslysbalk-bereikbaarheid vas sodat ondersteuningskwessies opgespoor kan word sonder om te raai."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ሪፖርቱ የድጋፍ ጉዳዮች ሳይገመቱ እንዲቀያየሩ የመተግበሪያ ፊርማን፣ አጋዥ ጭነት ሁኔታን፣ ግንኙነትን፣ በመግቢያ ጊዜ ማጽደቅን እና የምናሌ አሞሌ ተደራሽነትን ይይዛል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلتقط التقرير توقيع التطبيق، وحالة تثبيت المساعد، والاتصال، والموافقة على التشغيل عند تسجيل الدخول، وإمكانية الوصول إلى شريط القائمة حتى يمكن فرز مشكلات الدعم دون التخمين."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabat proqramın imzalanması, köməkçi quraşdırma vəziyyəti, əlaqə, giriş zamanı işə salınma təsdiqi və menyu çubuğunun əlçatanlığını əks etdirir, beləliklə, dəstək məsələləri təxmin edilmədən həll edilə bilər."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Справаздача фіксуе подпіс прыкладанняў, стан усталявання дапаможніка, падключэнне, зацвярджэнне запуску пры ўваходзе і даступнасць панэлі меню, таму праблемы са службай падтрымкі можна разглядаць без угадвання."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Докладът улавя подписване на приложение, състояние на инсталиране на помощник, свързаност, одобрение при стартиране при влизане и достъпност на лентата с менюта, така че проблемите с поддръжката да могат да бъдат преглеждани без предположения."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রিপোর্টে অ্যাপ সাইনিং, হেল্পার ইন্সটল স্টেট, কানেক্টিভিটি, লঞ্চ-এ-লগইন অ্যাপ্রুভাল এবং মেনু বারে পৌঁছানো যায়, যাতে অনুমান না করেই সহায়তার সমস্যাগুলো ট্রাইজেড করা যায়।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvještaj bilježi potpisivanje aplikacija, stanje instalacije pomoćnika, povezanost, odobrenje pokretanja pri prijavi i dostupnost trake menija tako da se problemi s podrškom mogu trijažirati bez nagađanja."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'informe recull la signatura d'aplicacions, l'estat d'instal·lació de l'ajudant, la connectivitat, l'aprovació del llançament a l'inici de sessió i l'accessibilitat a la barra de menús, de manera que es poden resoldre els problemes de suport sense endevinar-los."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gikuha sa taho ang pagpirma sa app, estado sa pag-install sa katabang, koneksyon, pag-apruba sa paglansad sa pag-login, ug pagkab-ot sa menu bar aron ang mga isyu sa suporta mahimong masulayan nga wala’y pagtag-an."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "U rapportu cattura a firma di l'app, u statu di l'installazione di l'aiutu, a connettività, l'approvazione di u lanciu à u login, è l'accessibilità di a barra di menu per chì i prublemi di supportu ponu esse trigatu senza indovinà."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zpráva zachycuje podepisování aplikací, stav instalace pomocníka, konektivitu, schválení spuštění při přihlášení a dostupnost panelu nabídek, takže problémy s podporou lze řešit bez dohadů."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Mae'r adroddiad yn cofnodi llofnodi ap, cyflwr gosod cynorthwyydd, cysylltedd, cymeradwyaeth lansio-wrth-mewngofnodi, a hygyrchedd bar dewislen fel y gellir brysbennu materion cymorth heb ddyfalu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapporten fanger app-signering, hjælperinstallationstilstand, tilslutningsmuligheder, start-ved-login-godkendelse og menulinjens tilgængelighed, så supportproblemer kan løses uden at gætte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Bericht erfasst die App-Signierung, den Installationsstatus des Hilfsprogramms, die Konnektivität, die Genehmigung des Starts bei der Anmeldung und die Erreichbarkeit der Menüleiste, sodass Supportprobleme ohne Vermutungen untersucht werden können."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αναφορά καταγράφει την υπογραφή εφαρμογών, την κατάσταση εγκατάστασης βοηθού, τη συνδεσιμότητα, την έγκριση εκκίνησης κατά τη σύνδεση και την προσβασιμότητα στη γραμμή μενού, ώστε τα ζητήματα υποστήριξης να μπορούν να επιλυθούν χωρίς εικασίες."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "La raporto kaptas subskribon de aplikaĵoj, staton de instalo de helpanto, konekteblecon, aprobon de lanĉo ĉe ensaluto kaj atingeblo de menubreto, por ke subtenaj problemoj povas esti triigitaj sen divenado."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El informe captura la firma de la aplicación, el estado de instalación del asistente, la conectividad, la aprobación del inicio de sesión y la accesibilidad de la barra de menú para que los problemas de soporte se puedan clasificar sin tener que adivinar."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Aruanne kajastab rakenduse allkirjastamist, abistaja installi olekut, ühenduvust, käivitamise kinnitamist sisselogimisel ja menüüriba juurdepääsetavust, nii et tugiprobleeme saab ilma arvata."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Txostenak aplikazioen sinadura, laguntzailearen instalazioaren egoera, konektibitatea, abiaraztean saioa hasteko onarpena eta menu-barraren irisgarritasuna jasotzen ditu, laguntza-arazoak asmatu gabe aztertu ahal izateko."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این گزارش امضای برنامه، وضعیت نصب کمکی، اتصال، تأیید راه‌اندازی ورود به سیستم و دسترسی به نوار منو را ثبت می‌کند، بنابراین می‌توان مشکلات پشتیبانی را بدون حدس زدن تریاژ کرد."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Raportti tallentaa sovelluksen allekirjoittamisen, apuohjelman asennuksen tilan, liitettävyyden, käynnistyksen sisäänkirjautumisen yhteydessä hyväksynnän ja valikkopalkin saavutettavuuden, joten tukiongelmia voidaan kokeilla arvaamatta."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Kinukuha ng ulat ang pag-sign ng app, helper install state, connectivity, launch-at-login approval, at menu bar reachability para masuri ang mga isyu sa suporta nang hindi hinuhulaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le rapport capture la signature des applications, l'état d'installation de l'assistant, la connectivité, l'approbation du lancement à la connexion et l'accessibilité de la barre de menus afin que les problèmes d'assistance puissent être triés sans deviner."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "It rapport vangt app-ûndertekening, helperynstallaasjestatus, ferbining, goedkarring fan lansearring-by-oanmelde, en berikberens fan menubalke, sadat stipeproblemen kinne wurde triage sûnder rieden."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Gabhann an tuarascáil síniú aipeanna, staid suiteála an chúntóra, nascacht, faomhadh seoladh-ag-logáil isteach, agus insroichteacht an bharra roghchláir ionas gur féidir saincheisteanna tacaíochta a thriáiseáil gan buille faoi thuairim a thabhairt."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Bidh an aithisg a’ glacadh soidhnigeadh app, stàite stàlaidh neach-cuideachaidh, ceangal, cead cur air bhog-aig-logadh a-steach, agus ruigsinneachd bàr clàr-taice gus an tèid cùisean taic a sgrùdadh gun a bhith a’ tomhas."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "O informe recolle a sinatura de aplicacións, o estado de instalación do axudante, a conectividade, a aprobación do inicio no inicio de sesión e a accesibilidade da barra de menús, polo que se poden resolver os problemas de asistencia sen adiviñar."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "રિપોર્ટમાં એપ સાઈનિંગ, હેલ્પર ઈન્સ્ટોલ સ્ટેટ, કનેક્ટિવિટી, લોંચ-એટ-લોગિન એપ્રુવલ અને મેનૂ બારની પહોંચની ક્ષમતાને કેપ્ચર કરવામાં આવી છે જેથી અનુમાન લગાવ્યા વગર સપોર્ટ ઈશ્યુને ટ્રાય કરી શકાય."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Rahoton ya ɗauki sa hannun app, mai shigar da jihar, haɗin kai, amincewar ƙaddamarwa-a-shigo, da isa ga mashaya don haka za a iya daidaita batutuwan tallafi ba tare da hasashe ba."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoʻopaʻa ʻia ka hōʻike i ke kau inoa ʻana o ka app, kōkua e hoʻokomo i ka mokuʻāina, ka hoʻohui ʻana, ka ʻae ʻana i ka hoʻomaka-ma-login, a me ka hiki ʻana o ka papa kuhikuhi i hiki ke hoʻāʻo ʻia nā pilikia kākoʻo me ka manaʻo ʻole."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הדוח מתעד חתימת אפליקציה, מצב התקנת מסייע, קישוריות, אישור הפעלה בכניסה, והנגישות של שורת התפריטים כך שניתן לפתור בעיות תמיכה מבלי לנחש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रिपोर्ट में ऐप साइनिंग, हेल्पर इंस्टॉल स्टेट, कनेक्टिविटी, लॉन्च-एट-लॉगिन अनुमोदन और मेनू बार रीचैबिलिटी को शामिल किया गया है ताकि समर्थन समस्याओं का अनुमान लगाए बिना प्रयास किया जा सके।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Daim ntawv tshaj tawm ntes app kos npe, tus pab txhim kho lub xeev, kev sib txuas, kev tso cai tso tawm-ntawm-tus ID nkag mus, thiab cov ntawv qhia zaub mov muaj peev xwm ncav cuag tau yog li kev txhawb nqa cov teeb meem tuaj yeem raug sim yam tsis xav tau."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvješće bilježi potpisivanje aplikacije, stanje instalacije pomoćnika, povezanost, odobrenje pokretanja pri prijavi i dostupnost trake izbornika tako da se problemi s podrškom mogu riješiti bez nagađanja."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapò a pran siyati aplikasyon, eta enstalasyon asistan, koneksyon, apwobasyon lansman nan koneksyon, ak aksè ba meni pou pwoblèm sipò yo ka triye san yo pa devine."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A jelentés rögzíti az alkalmazás aláírását, a segédprogram telepítési állapotát, a kapcsolatot, a bejelentkezéskor történő indítás jóváhagyását és a menüsor elérhetőségét, így a támogatási problémák találgatások nélkül kivizsgálhatók."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Զեկույցը ֆիքսում է հավելվածների ստորագրումը, օգնականի տեղադրման վիճակը, կապի հնարավորությունը, մուտքի գործարկման հաստատումը և ընտրացանկի տողերի հասանելիությունը, որպեսզի աջակցության խնդիրները հնարավոր լինի լուծել առանց գուշակելու:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan ini mencatat penandatanganan aplikasi, status instalasi pembantu, konektivitas, persetujuan peluncuran saat login, dan jangkauan bilah menu sehingga masalah dukungan dapat diprioritaskan tanpa perlu menebak-nebak."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Akụkọ ahụ weghaara mbinye aka ngwa, onye inyeaka wụnye steeti, njikọta, nnabata mmalite na nbanye, yana ịnweta mmanya menu ka enwere ike ịhazi okwu nkwado na-enweghị ịkọ nkọ."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Skýrslan fangar undirritun forrita, stöðu aðstoðaruppsetningar, tengingar, samþykki ræsingar við innskráningu og aðgengi að valmyndarstikunni svo hægt sé að leysa stuðningsvandamál án þess að giska á."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il report acquisisce la firma dell'app, lo stato di installazione dell'helper, la connettività, l'approvazione del lancio all'accesso e la raggiungibilità della barra dei menu in modo che i problemi di supporto possano essere valutati senza tirare a indovinare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このレポートでは、アプリの署名、ヘルパーのインストール状態、接続、ログイン時の起動の承認、メニュー バーへの到達可能性がキャプチャされるため、推測することなくサポートの問題を優先順位付けできます。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan kasebut njupuk tandha app, status instal helper, konektivitas, persetujuan peluncuran-ing-login, lan keterjangkauan bar menu supaya masalah dhukungan bisa dicoba tanpa ngira."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ანგარიში ასახავს აპლიკაციის ხელმოწერას, დამხმარე ინსტალაციის მდგომარეობას, დაკავშირებას, გაშვების დროს შესვლის დადასტურებას და მენიუს ზოლის ხელმისაწვდომობას, ასე რომ მხარდაჭერის საკითხები შეიძლება გამოიცნოს გარეშე."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Есеп қолданбаға қол қоюды, көмекшінің орнату күйін, қосылымды, кіру кезінде іске қосуды мақұлдауды және мәзір жолағына қол жеткізу мүмкіндігін қамтиды, осылайша қолдау мәселелерін болжаусыз шешуге болады."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "របាយការណ៍នេះចាប់យកការចុះហត្ថលេខាលើកម្មវិធី ជំនួយការដំឡើងស្ថានភាព ការតភ្ជាប់ ការអនុម័តការបើកដំណើរការនៅពេលចូល និងលទ្ធភាពឈានដល់របារម៉ឺនុយ ដូច្នេះបញ្ហាជំនួយអាចត្រូវបានសាកល្បងដោយមិនចាំបាច់ទាយ។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ವರದಿಯು ಅಪ್ಲಿಕೇಶನ್ ಸಹಿ ಮಾಡುವಿಕೆ, ಸಹಾಯಕ ಸ್ಥಾಪನೆ ಸ್ಥಿತಿ, ಸಂಪರ್ಕ, ಲಾಂಚ್-ಆಟ್-ಲಾಗಿನ್ ಅನುಮೋದನೆ ಮತ್ತು ಮೆನು ಬಾರ್ ತಲುಪುವಿಕೆಯನ್ನು ಸೆರೆಹಿಡಿಯುತ್ತದೆ ಆದ್ದರಿಂದ ಬೆಂಬಲ ಸಮಸ್ಯೆಗಳನ್ನು ಊಹಿಸದೆ ಟ್ರಯಜ್ ಮಾಡಬಹುದು."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보고서는 앱 서명, 도우미 설치 상태, 연결, 로그인 시 실행 승인, 메뉴 표시줄 연결 가능성을 포착하므로 추측 없이 지원 문제를 분류할 수 있습니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapor îmzakirina sepanê, rewşa sazkirina arîkar, girêdan, pejirandina destpêkirina têketinê, û gihîştina barika menuyê digire da ku pirsgirêkên piştgirî bêyî texmîn bêne ceribandin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Отчет колдонмого кол коюуну, жардамчы орнотуунун абалын, туташууну, кирүү учурунда ишке киргизүүнү бекитүүнү жана меню тилкесинин жеткиликтүүлүгүн чагылдырат, андыктан колдоо маселелерин ойлобостон чечүүгө болот."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Renuntiatio app subscriptionem capit, statum adiutorium inauguratum, connectivity, ad-login approbationem launch, et tabularum tabularum reachability ut subsidia quaestiones sine coniectura temptari possunt."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "De Bericht erfaasst App-Ënnerschreiwe, Hëllefsinstallatiounszoustand, Konnektivitéit, Start-um-Login Genehmegung, a Menübar-Erreechbarkeet, sou datt Ënnerstëtzungsprobleemer kënne triagéiert ginn ouni ze roden."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ບົດລາຍງານບັນທຶກການລົງນາມໃນແອັບຯ, ຜູ້ຊ່ວຍການຕິດຕັ້ງສະຖານະ, ການເຊື່ອມຕໍ່, ການອະນຸມັດການເປີດຕົວເມື່ອເຂົ້າສູ່ລະບົບ, ແລະການເຂົ້າເຖິງແຖບເມນູເພື່ອໃຫ້ບັນຫາການສະຫນັບສະຫນູນສາມາດຖືກທົດລອງໂດຍບໍ່ມີການຄາດເດົາ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ataskaitoje fiksuojamas programos pasirašymas, pagalbinio diegimo būsena, ryšys, paleidimo patvirtinimas prisijungimo metu ir meniu juostos pasiekiamumas, todėl palaikymo problemas galima išspręsti nespėliojant."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pārskatā ir ietverta lietotņu parakstīšana, palīga instalēšanas stāvoklis, savienojamība, palaišanas apstiprinājums pieteikšanās brīdī un izvēlņu joslas sasniedzamība, lai atbalsta problēmas varētu noteikt bez minējumiem."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ny tatitra dia mirakitra ny sonia fampiharana, mpanampy amin'ny fametrahana ny fanjakana, ny fifandraisana, ny fankatoavan'ny fanombohana amin'ny fidirana, ary ny fahafaha-miditra amin'ny menio mba hahafahan'ny olan'ny fanohanana azo jerena tsy misy vinavina."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ka hopuhia e te purongo te hainatanga taupānga, te kaiawhina ki te whakauru i te ahua, te hono, te whakaaetanga whakarewa-a-takiuru, me te toronga pae tahua kia taea ai te tarai i nga take tautoko me te kore e pohehe."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Извештајот го доловува потпишувањето на апликацијата, состојбата на инсталацијата на помошникот, поврзувањето, одобрувањето за стартување при најавување и достапноста на лентата со мени, така што проблемите со поддршката може да се решат без погодување."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ആപ്പ് സൈനിംഗ്, ഹെൽപ്പർ ഇൻസ്റ്റാളേഷൻ അവസ്ഥ, കണക്റ്റിവിറ്റി, ലോഞ്ച്-അറ്റ്-ലോഗിൻ അപ്രൂവൽ, മെനു ബാർ റീച്ചബിലിറ്റി എന്നിവ റിപ്പോർട്ട് ക്യാപ്‌ചർ ചെയ്യുന്നു, അതിനാൽ പിന്തുണാ പ്രശ്‌നങ്ങൾ ഊഹിക്കാതെ തന്നെ പരിഹരിക്കാനാകും."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Уг тайланд апп-д гарын үсэг зурах, туслах суулгацын төлөв, холболт, нэвтрэх үед эхлүүлэх зөвшөөрөл, цэс рүү нэвтрэх боломж зэргийг багтаасан тул тусламжийн асуудлыг тааваргүйгээр шийдвэрлэх боломжтой."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "अहवालात ॲप साइनिंग, हेल्पर इन्स्टॉल स्थिती, कनेक्टिव्हिटी, लॉन्च-एट-लॉग-इन मंजूरी आणि मेनू बार पोहोचण्यायोग्यता कॅप्चर करते जेणेकरून समर्थन समस्या अंदाज न लावता ट्राय केले जाऊ शकतात."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan itu merakam tandatangan apl, keadaan pemasangan pembantu, ketersambungan, kelulusan pelancaran semasa log masuk dan kebolehcapaian bar menu supaya isu sokongan boleh dicuba tanpa meneka."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ir-rapport jaqbad l-iffirmar tal-app, l-istat tal-installazzjoni tal-helper, il-konnettività, l-approvazzjoni tat-tnedija waqt il-login, u l-aċċessibilità tal-bar tal-menu sabiex il-kwistjonijiet tal-appoġġ ikunu jistgħu jiġu ttrattati mingħajr guessing."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "အစီရင်ခံစာသည် အက်ပ်လက်မှတ်ထိုးခြင်း၊ အကူအညီပေးသူ ထည့်သွင်းသည့်အခြေအနေ၊ ချိတ်ဆက်မှု၊ စတင်သည့်အချိန်၌ လော့ဂ်အင်ခွင့်ပြုချက်နှင့် မီနူးဘားရောက်ရှိနိုင်မှုတို့ကို ဖမ်းယူထားသောကြောင့် ပံ့ပိုးမှုပြဿနာများကို မှန်းဆစရာမလိုဘဲ စမ်းသပ်နိုင်သည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapporten fanger opp appsignering, hjelpeinstallasjonsstatus, tilkobling, godkjenning ved start ved pålogging og tilgjengelighet for menylinjen, slik at støtteproblemer kan løses uten å gjette."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "रिपोर्टले एप साइनिङ, सहायक स्थापना अवस्था, जडान, लन्च-एट-लगइन स्वीकृति, र मेनु पट्टी पहुँच योग्यता क्याप्चर गर्दछ ताकि समर्थन मुद्दाहरू अनुमान नगरी ट्र्याज गर्न सकिन्छ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het rapport legt de ondertekening van de app, de installatiestatus van de helper, de connectiviteit, de goedkeuring bij het opstarten bij het inloggen en de bereikbaarheid van de menubalk vast, zodat ondersteuningsproblemen zonder gissen kunnen worden beoordeeld."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Lipotilo limajambula kusaina kwa pulogalamu, kuyika kwa othandizira, kulumikizidwa, kuvomereza kolowera, ndi kupezeka kwa menyu kuti zithandizire zitha kuyesedwa popanda kulingalira."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਰਿਪੋਰਟ ਐਪ ਸਾਈਨਿੰਗ, ਸਹਾਇਕ ਸਥਾਪਨਾ ਸਥਿਤੀ, ਕਨੈਕਟੀਵਿਟੀ, ਲੌਂਚ-ਐਟ-ਲੌਗਇਨ ਮਨਜ਼ੂਰੀ, ਅਤੇ ਮੀਨੂ ਬਾਰ ਦੀ ਪਹੁੰਚਯੋਗਤਾ ਨੂੰ ਕੈਪਚਰ ਕਰਦੀ ਹੈ ਤਾਂ ਜੋ ਅਨੁਮਾਨ ਲਗਾਏ ਬਿਨਾਂ ਸਹਾਇਤਾ ਸਮੱਸਿਆਵਾਂ ਨੂੰ ਟ੍ਰਾਈਜ ਕੀਤਾ ਜਾ ਸਕੇ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Raport rejestruje podpisywanie aplikacji, stan instalacji pomocniczej, łączność, zatwierdzanie uruchomienia przy logowaniu i dostępność paska menu, dzięki czemu można bez zgadywania rozwiązywać problemy związane z pomocą techniczną."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "راپور د اپلیکیشن لاسلیک کول ، د مرستندویه انسټال حالت ، ارتباط ، د لانچ په وخت کې د ننوتلو تصویب ، او د مینو بار لاسرسي نیولي نو د ملاتړ مسلې پرته له اټکل څخه تعقیب کیدی شي."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O relatório captura a assinatura do aplicativo, o estado de instalação do auxiliar, a conectividade, a aprovação de inicialização no login e a acessibilidade da barra de menu para que os problemas de suporte possam ser triados sem adivinhação."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Raportul surprinde semnarea aplicației, starea de instalare a ajutorului, conectivitate, aprobarea lansării la conectare și accesibilitatea barei de meniu, astfel încât problemele de asistență să poată fi rezolvate fără a ghici."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отчет фиксирует подписание приложения, состояние установки помощника, подключение, одобрение запуска при входе в систему и доступность строки меню, поэтому проблемы поддержки можно решать без догадок."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "رپورٽ ايپ سائننگ، مددگار انسٽال اسٽيٽ، ڪنيڪشن، لانچ-اي-لاگ ان جي منظوري، ۽ مينيو بار جي رسائي تي قبضو ڪري ٿي، تنهنڪري سپورٽ مسئلن کي بغير اندازو لڳائي سگهجي ٿو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "වාර්තාව යෙදුම් අත්සන් කිරීම, උපකාරක ස්ථාපන තත්ත්වය, සම්බන්ධතාව, දියත් කිරීමේ දී-පිවිසුම් අනුමැතිය සහ මෙනු තීරුව වෙත ළඟා වීමේ හැකියාව ග්‍රහණය කරයි, එබැවින් අනුමාන කිරීමකින් තොරව සහාය ගැටළු පරීක්ෂා කළ හැකිය."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Správa zachytáva podpisovanie aplikácií, stav inštalácie pomocníka, konektivitu, schválenie spustenia pri prihlásení a dostupnosť panela s ponukami, takže problémy s podporou možno riešiť bez hádania."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Poročilo zajema podpisovanje aplikacij, stanje namestitve pomočnika, povezljivost, odobritev zagona ob prijavi in dosegljivost menijske vrstice, tako da je mogoče težave s podporo preizkusiti brez ugibanja."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "O le lipoti o lo'o maua ai le saini o le app, fesoasoani fa'apipi'i le setete, feso'ota'iga, fa'atagaga-i-login fa'atagaga, ma le lisi o mea e mafai ona o'o atu ina ia mafai ona fa'ata'ita'iina mataupu lagolago e aunoa ma le matematega."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Chirevo chinotora kusaina kweapp, mubatsiri wekuisa mamiriro, kubatana, kuvhura-ku-login mvumo, uye menyu bar yekusvikika kuitira kuti nyaya dzekutsigira dzitariswe pasina kufungidzira."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Warbixintu waxa ay qabataa saxeexa abka, rakibida caawiye gobolka, isku xidhka, ogolaanshaha bilawga-galitaanka, iyo gaadhista bar menu-ka si arrimaha taageerada loo kala sooci karo iyada oo aan la malaynayn."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Raporti kap nënshkrimin e aplikacionit, gjendjen e instalimit të ndihmës, lidhjen, miratimin e nisjes në hyrje dhe aksesin e shiritit të menysë, në mënyrë që çështjet e mbështetjes të mund të zgjidhen pa hamendje."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "The report captures app signing, helper install state, connectivity, launch-at-login approval, and menu bar reachability so support issues can be triaged without guessing."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Tlaleho e ts'oara ho saena ha lits'ebetso, boemo ba ho kenya bathusi, khokahanyo, tumello ea ho qala ha u kena, le mokhoa oa ho fihlella bara ea menyetla e le hore litaba tsa tšehetso li ka rarolloa ntle le ho hakanya."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan éta ngarebut penandatanganan aplikasi, asisten masang kaayaan, konektipitas, persetujuan peluncuran-di-login, sareng bar menu bar reachability ku kituna masalah pangrojong tiasa di-triaged tanpa ditebak."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapporten fångar appsignering, hjälpinstallationsstatus, anslutning, godkännande av start vid inloggning och nåbarhet i menyraden så att supportproblem kan lösas utan att gissa."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Ripoti hunasa kipengele cha kuambatisha cheti kwenye programu, hali ya usakinishaji wa msaidizi, muunganisho, idhini ya kuzindua baada ya kuingia, na ufikiaji wa upau wa menyu ili masuala ya usaidizi yaweze kutatuliwa bila kubahatisha."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அறிக்கையானது ஆப்ஸ் கையொப்பமிடுதல், உதவியாளர் நிறுவல் நிலை, இணைப்பு, உள்நுழைவு அனுமதி மற்றும் மெனு பார் அணுகல் ஆகியவற்றைப் படம்பிடிக்கிறது, எனவே ஆதரவு சிக்கல்களை யூகிக்காமல் முயற்சி செய்யலாம்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "నివేదిక యాప్ సంతకం చేయడం, సహాయక ఇన్‌స్టాల్ స్థితి, కనెక్టివిటీ, లాంచ్-ఎట్-లాగిన్ ఆమోదం మరియు మెను బార్ రీచ్‌బిలిటీని క్యాప్చర్ చేస్తుంది కాబట్టి మద్దతు సమస్యలను ఊహించకుండానే పరిష్కరించవచ్చు."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ҳисобот имзои барнома, ҳолати насби ёрирасон, пайвастшавӣ, тасдиқи оғози воридшавӣ ва дастрасии сатри менюро сабт мекунад, то масъалаҳои дастгирӣ бидуни тахмин ҳал карда шаванд."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายงานรวบรวมการลงนามแอป สถานะการติดตั้งตัวช่วย การเชื่อมต่อ การอนุมัติเมื่อเข้าสู่ระบบ และการเข้าถึงแถบเมนู เพื่อให้สามารถแก้ไขปัญหาการสนับสนุนได้โดยไม่ต้องเดา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rapor, uygulama imzalamayı, yardımcı yükleme durumunu, bağlantıyı, oturum açma sırasında başlatma onayını ve menü çubuğu erişilebilirliğini yakalayarak destek sorunlarının tahmin edilmeden önceliklendirilebilmesini sağlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Звіт фіксує підпис додатка, стан встановлення помічника, підключення, схвалення запуску під час входу та доступність рядка меню, щоб проблеми з підтримкою можна було перевірити без здогадів."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "رپورٹ ایپ پر دستخط کرنے، مددگار انسٹال کرنے کی حالت، کنیکٹیویٹی، لاگ ان کے آغاز کی منظوری، اور مینو بار کی قابل رسائی کو کیپچر کرتی ہے تاکہ سپورٹ کے مسائل کا اندازہ لگائے بغیر ٹرائی کیا جا سکے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Hisobot ilovaga imzo qoʻyish, yordamchi oʻrnatish holati, ulanish, tizimga kirishda ishga tushirishni tasdiqlash va menyu paneliga kirish imkoniyatini aks ettiradi, shuning uchun qoʻllab-quvvatlash bilan bogʻliq muammolarni taxmin qilmasdan hal qilish mumkin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Báo cáo ghi lại quá trình ký ứng dụng, trạng thái cài đặt trợ giúp, khả năng kết nối, phê duyệt khởi chạy khi đăng nhập và khả năng tiếp cận thanh menu để có thể phân loại các vấn đề hỗ trợ mà không cần đoán trước."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingxelo ibamba ukusayinwa kwe-app, umncedisi wokufakela imo, uqhagamshelo, imvume yokuqalisa ukungena, kunye nokufikelela kwibha yemenyu ukuze imiba yenkxaso ijongwe ngaphandle kokuqikelela."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "דער באַריכט קאַפּטשערז אַפּ סיינינג, העלפּער ינסטאַלירן שטאַט, קאַנעקטיוויטי, קאַטער-ביי-לאָגין האַסקאָמע, און מעניו באַר ריטשאַביליטי אַזוי שטיצן ישוז קענען זיין טריידזשד אָן געסינג."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ijabọ naa ṣe ifilọlẹ fawabale app, oluranlọwọ fifi sori ẹrọ ipo, Asopọmọra, ifọwọsi ifilọlẹ-ni-iwọle, ati wiwa ọpa akojọ aṣayan ki awọn ọran atilẹyin le jẹ triage laisi amoro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该报告捕获应用程序签名、帮助程序安装状态、连接性、登录时启动批准和菜单栏可达性，因此可以在无需猜测的情况下对支持问题进行分类。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該報告捕獲應用程式簽名、幫助程式安裝狀態、連接性、登入時啟動批准和功能表列可達性，因此可以在無需猜測的情況下對支援問題進行分類。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Umbiko uthwebula ukusayinda uhlelo lokusebenza, isimo sokufakwa komsizi, uxhumo, ukuvunyelwa kokungena ngemvume, kanye nokufinyeleleka kwebha yemenyu ukuze izinkinga zosekelo zicutshungulwe ngaphandle kokuqagela."
          }
        }
      }
    },
