          "stringUnit": {
            "state": "translated",
            "value": "మీ MacBook యొక్క Touch Barని Core Monitor విడ్జెట్‌లు మరియు నియంత్రణలతో అనుకూలీకరించండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook-и Touch Bar-и худро бо виджетҳо ва назорати Core Monitor фармоиш диҳед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปรับแต่ง Touch Bar ของ MacBook ของคุณด้วยวิดเจ็ตและการควบคุม Core Monitor"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook'nizin Touch Bar'sini Core Monitor widget'ları ve kontrolleriyle özelleştirin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштуйте свій Touch Bar MacBook за допомогою віджетів і елементів керування Core Monitor."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے MacBook کے Touch Bar کو Core Monitor وجیٹس اور کنٹرولز کے ساتھ حسب ضرورت بنائیں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "MacBook Touch Bar-ni Core Monitor vidjetlari va boshqaruvlari bilan moslashtiring."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tùy chỉnh Touch Bar của MacBook của bạn với các tiện ích và điều khiển Core Monitor."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Lungiselela i-MacBook's Touch Bar yakho ngeewijethi ze-Core Monitor kunye nolawulo."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "קאַסטאַמייז די Touch Bar פון דיין MacBook מיט Core Monitor ווידזשיץ און קאָנטראָלס."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ṣe akanṣe MacBook's Touch Bar rẹ pẹlu awọn ẹrọ ailorukọ Core Monitor ati awọn idari."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Core Monitor 小部件和控件自定义您的 MacBook 的 Touch Bar。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Core Monitor 小工具和控制項自訂您的 MacBook 的 Touch Bar。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Yenza ngokwezifiso i-Touch Bar yakho ye-MacBook ngamawijethi nezilawuli ze-Core Monitor."
          }
        }
      }
    },
