        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Dashboardka Guudmarku waxa uu bixiyaa koobid dhamaystiran oo ku saabsan xaaladaada Mac ee hadda ay ku jiraan CPU, GPU, xusuusta, kulaylka, tamarta, iyo macluumaadka shabakada nool."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Paneli i Përmbledhjes ofron një përmbledhje gjithëpërfshirëse të gjendjes aktuale të Mac-it tuaj duke përfshirë CPU, GPU, memorien, termike, energjinë dhe informacionin e rrjetit të drejtpërdrejtë."
          }
        },
        "sr": {
