        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dan it-tqassim huwa wiesa 'wisq għal Touch Bar sħiħ. Uża ssettjar minn qabel idjaq biex tevita widgets maqtugħin."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ဤအပြင်အဆင်သည် Touch Bar အပြည့်အစုံအတွက် အလွန်ကျယ်သည်။ ညှပ်ထားသောဝစ်ဂျက်များကိုရှောင်ရှားရန် ပိုမိုကျဉ်းမြောင်းသောကြိုတင်ပြင်ဆင်မှုကိုသုံးပါ။"
