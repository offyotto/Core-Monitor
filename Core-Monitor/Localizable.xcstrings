        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inga hjälpsektioner matchade \"%@\". Prova termer som hjälpreda, väder, inloggningsobjekt, menyrad eller Touch Bar."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Hakuna sehemu za usaidizi zinazolingana na \"%@\". Jaribu maneno kama vile msaidizi, hali ya hewa, vipengee vya kuingia, upau wa menyu, au Touch Bar."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" உடன் எந்த உதவிப் பிரிவுகளும் பொருந்தவில்லை. உதவியாளர், வானிலை, உள்நுழைவு உருப்படிகள், மெனு பார் அல்லது Touch Bar போன்ற சொற்களை முயற்சிக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"కి ఏ సహాయ విభాగాలు సరిపోలలేదు. సహాయకుడు, వాతావరణం, లాగిన్ అంశాలు, మెను బార్ లేదా Touch Bar వంటి నిబంధనలను ప్రయత్నించండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ягон бахшҳои кӯмак ба \"%@\" мувофиқат намекарданд. Шартҳои монанди ёрдамчӣ, обу ҳаво, ҷузъҳои воридшавӣ, сатри меню ё Touch Bar -ро санҷед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีส่วนช่วยเหลือที่ตรงกับ \"%@\" ลองใช้คำต่างๆ เช่น ตัวช่วย สภาพอากาศ รายการเข้าสู่ระบบ แถบเมนู หรือ Touch Bar"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ile eşleşen yardım bölümü yok. Yardımcı, hava durumu, oturum açma öğeleri, menü çubuğu veya Touch Bar gibi terimleri deneyin."
          }
