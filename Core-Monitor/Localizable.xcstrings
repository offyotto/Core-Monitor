        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Fa'aali su'ega natia ma tatala le laupapa ping pong toe fo'i i lalo."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Inoratidza zvakavanzwa zviedzo uye inovhura iyo retro ping pong bhodhi pazasi."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Wuxuu muujiyaa tijaabooyin qarsoon wuxuuna furayaa looxa pingpong retro hoos."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Tregon eksperimente të fshehura dhe zhbllokon tabelën retro të ping-pongut më poshtë."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows hidden experiments and unlocks the retro ping pong board below."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "E bonts'a liteko tse patiloeng le ho notlolla boto ea retro ping pong ka tlase."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Némbongkeun ékspérimén disumputkeun sareng muka konci papan ping pong retro di handap."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Visar dolda experiment och låser upp retro pingisbrädan nedan."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Huonyesha majaribio yaliyofichwa na kufungua ubao wa retro wa ping pong hapa chini."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மறைக்கப்பட்ட சோதனைகளைக் காட்டும் மற்றும் கீழே உள்ள ரெட்ரோ பிங் பாங் போர்டைத் திறக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "దాచిన ప్రయోగాలను చూపుతుంది మరియు దిగువన ఉన్న రెట్రో పింగ్ పాంగ్ బోర్డ్‌ను అన్‌లాక్ చేస్తుంది."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Таҷрибаҳои пинҳоншударо нишон медиҳад ва тахтаи ретро пинг теннисро дар зер мекушояд."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แสดงการทดลองที่ซ่อนอยู่และปลดล็อคกระดานปิงปองย้อนยุคด้านล่าง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gizli deneyleri gösterir ve aşağıdaki retro pinpon tahtasının kilidini açar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Показує приховані експерименти та відкриває ретро дошку для пінг-понгу нижче."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پوشیدہ تجربات دکھاتا ہے اور نیچے ریٹرو پنگ پونگ بورڈ کو کھولتا ہے۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Yashirin tajribalarni ko'rsatadi va quyida retro stol tennisi taxtasini ochadi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiển thị các thử nghiệm ẩn và mở khóa bảng bóng bàn cổ điển bên dưới."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Ibonisa imifuniselo efihliweyo kwaye ivule ibhodi ye-retro ping pong engezantsi."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "ווייַזן פאַרבאָרגן יקספּעראַמאַנץ און אַנלאַקס די רעטראָ פּינג פּאָנג ברעט אונטן."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ṣe afihan awọn adanwo ti o farapamọ ati ṣiṣi igbimọ ping pong retro ni isalẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示隐藏的实验并解锁下面的复古乒乓球板。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示隱藏的實驗並解鎖下面的復古乒乓球板。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ibonisa izivivinyo ezifihliwe futhi ivula ibhodi le-retro ping pong ngezansi."
          }
        }
      }
    },
