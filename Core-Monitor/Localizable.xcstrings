        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo stack di widget attivi è più ampio di un Touch Bar completo. Taglia o riordina i widget per evitare il ritaglio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなウィジェット スタックは、完全な Touch Bar よりも幅が広くなります。クリッピングを避けるためにウィジェットをトリミングまたは並べ替えます。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tumpukan widget aktif luwih amba tinimbang Touch Bar lengkap. Potong utawa atur ulang widget supaya ora dipotong."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "აქტიური ვიჯეტის დასტა უფრო ფართოა, ვიდრე სრული Touch Bar. ამოჭრის თავიდან ასაცილებლად ვიჯეტების მორთვა ან გადაკვეთა."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Белсенді виджет стек толық Touch Bar қарағанда кеңірек. Қиып кетпеу үшін виджеттерді кесіңіз немесе қайта реттеңіз."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "ជង់ធាតុក្រាហ្វិកសកម្មគឺធំជាង Touch Bar ពេញលេញ។ កាត់ ឬតម្រៀបធាតុក្រាហ្វិកឡើងវិញ ដើម្បីជៀសវាងការច្រឹប។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಕ್ರಿಯ ವಿಜೆಟ್ ಸ್ಟಾಕ್ ಪೂರ್ಣ Touch Bar ಗಿಂತ ವಿಶಾಲವಾಗಿದೆ. ಕ್ಲಿಪ್ಪಿಂಗ್ ಅನ್ನು ತಪ್ಪಿಸಲು ವಿಜೆಟ್‌ಗಳನ್ನು ಟ್ರಿಮ್ ಮಾಡಿ ಅಥವಾ ಮರುಕ್ರಮಗೊಳಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 위젯 스택은 전체 Touch Bar보다 넓습니다. 잘림을 방지하려면 위젯을 자르거나 재정렬하세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Staka widgetê ya çalak ji Touch Bar-ya tevahî firehtir e. Ji bo ku ji qutkirinê dûr nekevin, widgetan bibirrin an ji nû ve rêz bikin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Жигердүү виджет стек толук Touch Bar караганда кененирээк. Кыркууну болтурбоо үчүн виджеттерди кыркыңыз же иреттеңиз."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "BIBLIOTHECA activa pythonistica latior est quam plenus Touch Bar. Trim vel reorder content ne tonsuram."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den aktive Widget-Stack ass méi breet wéi e vollen Touch Bar. Trimmen oder nei bestellen Widgets fir Ausschnëtter ze vermeiden."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "stack widget ທີ່ເຮັດວຽກແມ່ນກວ້າງກວ່າ Touch Bar ເຕັມ. ຕັດ ຫຼືຈັດຮຽງວິດເຈັດຄືນໃໝ່ເພື່ອຫຼີກເວັ້ນການຕັດ."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktyvių valdiklių krūva yra platesnė nei visas Touch Bar. Apkarpykite arba pertvarkykite valdiklius, kad išvengtumėte iškirpimo."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktīvā logrīku kopa ir plašāka nekā pilna Touch Bar. Apgrieziet vai pārkārtojiet logrīkus, lai izvairītos no izgriešanas."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Mivelatra kokoa noho ny Touch Bar feno ny fitambaran'ny widget mavitrika. Hetezo na avereno alao ny widget mba tsy ho tapaka."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "He whanui ake te puranga widget hohe i te Touch Bar katoa. Kuti, whakaraupapa ano ranei i nga widget kia kore ai e tope."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Активниот куп на виџети е поширок од целосен Touch Bar. Скратете ги или прередете ги виџетите за да избегнете клипирање."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "സജീവമായ വിജറ്റ് സ്റ്റാക്ക് ഒരു പൂർണ്ണ Touch Bar-നേക്കാൾ വിശാലമാണ്. ക്ലിപ്പിംഗ് ഒഴിവാക്കാൻ വിജറ്റുകൾ ട്രിം ചെയ്യുക അല്ലെങ്കിൽ പുനഃക്രമീകരിക്കുക."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Идэвхтэй виджетийн стек нь бүрэн Touch Bar-ээс өргөн. Хайчлахаас зайлсхийхийн тулд виджетүүдийг тайрч эсвэл дахин эрэмбэлээрэй."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "सक्रिय विजेट स्टॅक पूर्ण Touch Bar पेक्षा विस्तृत आहे. क्लिपिंग टाळण्यासाठी विजेट्स ट्रिम करा किंवा पुनर्क्रमित करा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Timbunan widget aktif lebih lebar daripada Touch Bar penuh. Potong atau susun semula widget untuk mengelakkan keratan."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Il-munzell ta 'widget attiv huwa usa' minn Touch Bar sħiħ. Ittrimmja jew ordna mill-ġdid il-widgets biex tevita l-qtugħ."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "အသုံးပြုနေသောဝစ်ဂျက်အစုသည် Touch Bar အပြည့်အစုံထက် ပိုကျယ်သည်။ ညှပ်ခြင်းကို ရှောင်ရှားရန် ဝစ်ဂျက်များကို ချုံ့ပါ သို့မဟုတ် ပြန်စီပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den aktive widgetstabelen er bredere enn en full Touch Bar. Trim eller omorganiser widgets for å unngå klipping."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "सक्रिय विजेट स्ट्याक पूर्ण Touch Bar भन्दा फराकिलो छ। क्लिपिङबाट बच्न विजेटहरू ट्रिम वा पुन: क्रमबद्ध गर्नुहोस्।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De actieve widgetstapel is breder dan een volledige Touch Bar. Knip widgets bij of herschik ze om knippen te voorkomen."
