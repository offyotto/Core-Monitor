        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "መሰረታዊ ሁነታ የ Core Monitor በይነገጽ እና የክትትል አማራጮችን ያቃልላል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعمل الوضع الأساسي على تبسيط واجهة Core Monitor وخيارات المراقبة."
          }
