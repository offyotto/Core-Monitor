        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Palibe zigawo zothandizira zofananira \"%@\". Yesani mawu ngati wothandizira, nyengo, zinthu zolowera, menyu bar, kapena Touch Bar."
