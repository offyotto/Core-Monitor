        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuaca ngagunakeun Apple WeatherKit dina ngawangun WeatherKit-diaktipkeun. Ngidinan aksés lokasi pikeun Core Monitor supados widget cuaca langsung tiasa nunjukkeun kaayaan anu akurat sareng waktos hujan."
          }
