        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Tá an chairn ghiuirléid gníomhach níos leithne ná Touch Bar iomlán. Baile Átha Troim nó athordaigh giuirléidí chun bearradh a sheachaint."
          }
