    "Custom layout active. Toggle individual items below for a mixed setup.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasgemaakte uitleg aktief. Wissel individuele items hieronder vir 'n gemengde opstelling."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ብጁ አቀማመጥ ንቁ። ለተደባለቀ ማዋቀር ግለሰባዊ እቃዎችን ከታች ይቀያይሩ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التخطيط المخصص نشط. قم بتبديل العناصر الفردية أدناه لإعداد مختلط."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom layout active. Toggle individual items below for a mixed setup."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom layout active. Toggle individual items below for a mixed setup."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Fərdi tərtibat aktivdir. Qarışıq quraşdırma üçün aşağıda fərdi elementləri dəyişin."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Карыстальніцкі макет актыўны. Пераключыце асобныя элементы ніжэй для змешанай налады."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Персонализирано оформление е активно. Превключете отделни елементи по-долу за смесена настройка."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom layout active. Toggle individual items below for a mixed setup."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কাস্টম লেআউট সক্রিয়। একটি মিশ্র সেটআপের জন্য নীচে পৃথক আইটেম টগল করুন।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom layout active. Toggle individual items below for a mixed setup."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Prilagođeni izgled je aktivan. Uključite pojedinačne stavke ispod za mješovitu postavku."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Disseny personalitzat actiu. Commuta els elements individuals a continuació per a una configuració mixta."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktibo ang custom nga layout. I-toggle ang tagsa-tagsa nga mga butang sa ubos para sa nagkasagol nga setup."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Disposizione persunalizata attiva. Cambia l'articuli individuali sottu per una configurazione mista."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vlastní rozložení je aktivní. Přepínáním jednotlivých položek níže získáte smíšené nastavení."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Cynllun personol yn weithredol. Toglo eitemau unigol isod ar gyfer gosodiad cymysg."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brugerdefineret layout aktivt. Skift individuelle elementer nedenfor for en blandet opsætning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Benutzerdefiniertes Layout aktiv. Schalten Sie unten einzelne Elemente um, um ein gemischtes Setup zu erhalten."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Custom layout active. Toggle individual items below for a mixed setup."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ενεργή προσαρμοσμένη διάταξη. Εναλλαγή μεμονωμένων στοιχείων παρακάτω για μικτή ρύθμιση."
          }
        },
