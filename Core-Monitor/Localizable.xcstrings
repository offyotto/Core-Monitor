        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Օգտագործեք %@ Core Monitor-ն առջևում բերելու համար, նույնիսկ եթե macOS-ը թաքցրել է ցանկի գծի տարրերը: Նույն դյուրանցումը հայտնվում է նաև հավելվածի ցանկում, մինչ Core Monitor ակտիվ է:"
