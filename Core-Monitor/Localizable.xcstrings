        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "A pila de widgets activa é máis ampla que un Touch Bar completo. Recorta ou reordena os widgets para evitar recortes."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "The active widget stack is wider than a full Touch Bar. Trim or reorder widgets to avoid clipping."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "સક્રિય વિજેટ સ્ટેક સંપૂર્ણ Touch Bar કરતાં પહોળો છે. ક્લિપિંગ ટાળવા માટે વિજેટ્સને ટ્રિમ કરો અથવા ફરીથી ગોઠવો."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarin kayan aikin widget din yana da fadi fiye da cikakken Touch Bar. Gyara ko sake yin odar widget din don gujewa yankewa."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "ʻOi aku ka laulā o ka puʻu hāmeʻa ikaika ma mua o Touch Bar piha. E ʻoki a hoʻonohonoho hou i nā widget e pale i ka ʻoki ʻana."
