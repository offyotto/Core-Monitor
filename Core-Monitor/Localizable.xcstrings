    "Reorder with the arrows, remove what you do not need, and add widgets from the library below.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Herrangskik met die pyle, verwyder wat jy nie nodig het nie, en voeg legstukke by uit die biblioteek hieronder."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "በቀስቶቹ እንደገና ይዘዙ፣ የማይፈልጉትን ያስወግዱ እና ንዑስ ፕሮግራሞችን ከታች ካለው ቤተ-መጽሐፍት ያክሉ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أعد الترتيب باستخدام الأسهم، وأزل ما لا تحتاجه، وأضف عناصر واجهة المستخدم من المكتبة أدناه."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Oxlarla yenidən sıralayın, lazım olmayanları çıxarın və aşağıdakı kitabxanadan vidjetlər əlavə edin."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Змяніце парадак з дапамогай стрэлак, выдаліце тое, што вам не патрэбна, і дадайце віджэты з бібліятэкі ніжэй."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Пренаредете със стрелките, премахнете това, от което не се нуждаете, и добавете джаджи от библиотеката по-долу."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "তীরগুলি দিয়ে পুনরায় সাজান, আপনার যা প্রয়োজন নেই তা সরান এবং নীচের লাইব্রেরি থেকে উইজেট যোগ করুন।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Promijenite redoslijed pomoću strelica, uklonite ono što vam nije potrebno i dodajte widgete iz biblioteke ispod."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordena amb les fletxes, elimina el que no necessites i afegeix ginys de la biblioteca de sota."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Paghan-ay pag-usab gamit ang mga pana, kuhaa ang wala nimo kinahanglana, ug idugang ang mga widget gikan sa librarya sa ubos."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Riordinate cù e frecce, sguassate ciò chì ùn avete micca bisognu, è aghjunghje widgets da a biblioteca sottu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Změňte pořadí pomocí šipek, odeberte to, co nepotřebujete, a přidejte widgety z knihovny níže."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ail-archebwch gyda'r saethau, tynnwch yr hyn nad oes ei angen arnoch, ac ychwanegwch widgets o'r llyfrgell isod."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Omarranger med pilene, fjern det, du ikke har brug for, og tilføj widgets fra biblioteket nedenfor."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordnen Sie mit den Pfeilen neu, entfernen Sie nicht benötigte Elemente und fügen Sie Widgets aus der Bibliothek unten hinzu."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αναδιάταξη με τα βέλη, αφαιρέστε ό,τι δεν χρειάζεστε και προσθέστε γραφικά στοιχεία από την παρακάτω βιβλιοθήκη."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordu per la sagoj, forigu tion, kion vi ne bezonas, kaj aldonu fenestraĵojn el la malsupra biblioteko."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordene con las flechas, elimine lo que no necesita y agregue widgets de la biblioteca a continuación."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestage nooltega ümber, eemaldage need, mida te ei vaja, ja lisage vidinad allolevast teegist."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Berrantola ezazu geziekin, kendu behar ez duzuna eta gehitu widget-ak beheko liburutegitik."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "با فلش ها مرتب کنید، مواردی را که نیاز ندارید حذف کنید و ویجت ها را از کتابخانه زیر اضافه کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestä uudelleen nuolilla, poista tarpeettomat ja lisää widgetit alla olevasta kirjastosta."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Muling ayusin gamit ang mga arrow, alisin ang hindi mo kailangan, at magdagdag ng mga widget mula sa library sa ibaba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réorganisez avec les flèches, supprimez ce dont vous n'avez pas besoin et ajoutez des widgets de la bibliothèque ci-dessous."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestelle opnij mei de pylken, ferwiderje wat jo net nedich binne, en foegje widgets ta út 'e bibleteek hjirûnder."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Déan athordú leis na saigheada, bain na rudaí nach bhfuil uait, agus cuir giuirléidí ón leabharlann thíos."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Dèan ath-òrdachadh leis na saighdean, thoir air falbh na rudan nach eil a dhìth ort, agus cuir widgets bhon leabharlann gu h-ìosal."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordena coas frechas, elimina o que non necesitas e engade widgets da biblioteca de abaixo."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "તીરો સાથે પુનઃક્રમાંકિત કરો, તમને જેની જરૂર નથી તે દૂર કરો અને નીચેની લાઇબ્રેરીમાંથી વિજેટ્સ ઉમેરો."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Sake yin oda tare da kiban, cire abin da ba ku buƙata, kuma ƙara widgets daga ɗakin karatu na ƙasa."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "E hoʻonohonoho hou me nā pua, wehe i nā mea āu e pono ʻole ai, a hoʻohui i nā widget mai ka waihona ma lalo."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "סדר מחדש עם החצים, הסר את מה שאתה לא צריך והוסף ווידג'טים מהספרייה למטה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तीरों के साथ पुन: व्यवस्थित करें, जिसकी आपको आवश्यकता नहीं है उसे हटा दें और नीचे दी गई लाइब्रेरी से विजेट जोड़ें।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder nrog cov xub, tshem tawm yam koj tsis xav tau, thiab ntxiv widgets los ntawm lub tsev qiv ntawv hauv qab no."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Promijenite redoslijed pomoću strelica, uklonite ono što vam ne treba i dodajte widgete iz knjižnice u nastavku."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekòmande ak flèch yo, retire sa ou pa bezwen, epi ajoute widgets nan bibliyotèk ki anba a."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendezd át a nyilakkal, távolítsd el, amire nincs szükséged, és adj hozzá widgeteket az alábbi könyvtárból."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Վերադասավորեք սլաքներով, հեռացրեք այն, ինչ ձեզ հարկավոր չէ և ավելացրեք վիջեթներ ստորև գտնվող գրադարանից:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Susun ulang dengan panah, hapus yang tidak diperlukan, dan tambahkan widget dari perpustakaan di bawah."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Jiri akụ dozigharịa, wepụ ihe ị na-achọghị, tinye wijetị n'ọbá akwụkwọ dị n'okpuru."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Endurraðaðu með örvarnar, fjarlægðu það sem þú þarft ekki og bættu við græjum úr bókasafninu hér að neðan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riordina con le frecce, rimuovi ciò che non ti serve e aggiungi i widget dalla libreria sottostante."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "矢印を使用して並べ替え、不要なものを削除し、下のライブラリからウィジェットを追加します。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Urutan maneh karo panah, mbusak apa sing ora perlu, lan nambah widget saka perpustakaan ing ngisor iki."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ხელახლა დაალაგეთ ისრებით, წაშალეთ ის, რაც არ გჭირდებათ და დაამატეთ ვიჯეტები ქვემოთ მოცემულ ბიბლიოთეკიდან."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Көрсеткілер арқылы ретін өзгертіңіз, қажет емес нәрсені алып тастаңыз және төмендегі кітапханадан виджеттер қосыңыз."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "តម្រៀបឡើងវិញដោយប្រើព្រួញ យកអ្វីដែលអ្នកមិនត្រូវការ ហើយបន្ថែមធាតុក្រាហ្វិកពីបណ្ណាល័យខាងក្រោម។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಬಾಣಗಳೊಂದಿಗೆ ಮರುಕ್ರಮಗೊಳಿಸಿ, ನಿಮಗೆ ಅಗತ್ಯವಿಲ್ಲದ್ದನ್ನು ತೆಗೆದುಹಾಕಿ ಮತ್ತು ಕೆಳಗಿನ ಲೈಬ್ರರಿಯಿಂದ ವಿಜೆಟ್‌ಗಳನ್ನು ಸೇರಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화살표로 순서를 바꾸고, 필요하지 않은 것을 제거하고, 아래 라이브러리에서 위젯을 추가하세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Bi tîran re ji nû ve rêz bikin, tiştê ku hûn ne hewce ne derxînin, û widgetan ji pirtûkxaneya jêrîn lê zêde bikin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Жебелер менен иреттеп, кереги жок нерселерди алып салыңыз жана төмөнкү китепканадан виджеттерди кошуңуз."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder sagittis, remove quod non opus est, et adde contenta e bibliotheca infra."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Neibestellung mat de Pfeile, läscht wat Dir net braucht, a füügt Widgets aus der Bibliothéik hei drënner."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "ຈັດລໍາດັບໃຫມ່ດ້ວຍລູກສອນ, ເອົາສິ່ງທີ່ເຈົ້າບໍ່ຕ້ອງການອອກ, ແລະເພີ່ມ widget ຈາກຫ້ອງສະຫມຸດຂ້າງລຸ່ມນີ້."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pertvarkykite tvarką naudodami rodykles, pašalinkite tai, ko jums nereikia, ir pridėkite valdiklių iš toliau esančios bibliotekos."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pārkārtojiet, izmantojot bultiņas, noņemiet nevajadzīgo un pievienojiet logrīkus no tālāk esošās bibliotēkas."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Avereno alamina miaraka amin'ny zana-tsipìka, esory izay tsy ilainao, ary ampio widgets avy amin'ny tranomboky etsy ambany."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Whakaritea ano me nga pere, tangohia nga mea kaore e hiahiatia ana, ka taapirihia nga widget mai i te whare pukapuka i raro nei."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Повторете наредба со стрелките, отстранете го она што не ви треба и додајте виџети од библиотеката подолу."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "അമ്പടയാളങ്ങൾ ഉപയോഗിച്ച് പുനഃക്രമീകരിക്കുക, നിങ്ങൾക്ക് ആവശ്യമില്ലാത്തത് നീക്കം ചെയ്യുക, താഴെയുള്ള ലൈബ്രറിയിൽ നിന്ന് വിജറ്റുകൾ ചേർക്കുക."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Сумнуудаар дахин эрэмбэлж, хэрэггүй зүйлээ устгаад доорх номын сангаас виджет нэмнэ үү."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "बाणांसह पुनर्क्रमित करा, तुम्हाला जे आवश्यक नाही ते काढून टाका आणि खालील लायब्ररीमधून विजेट जोडा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Susun semula dengan anak panah, alih keluar perkara yang anda tidak perlukan dan tambahkan widget daripada pustaka di bawah."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordna mill-ġdid bil-vleġeġ, neħħi dak li m'għandekx bżonn, u żid widgets mil-librerija hawn taħt."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "မြှားများဖြင့် ပြန်လည်စီစစ်ပါ၊ သင်မလိုအပ်သောအရာကို ဖယ်ရှားကာ အောက်ဖော်ပြပါ စာကြည့်တိုက်မှ ဝစ်ဂျက်များကို ထည့်ပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestill på nytt med pilene, fjern det du ikke trenger, og legg til widgets fra biblioteket nedenfor."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "तीरहरूसँग पुन: क्रमबद्ध गर्नुहोस्, तपाईंलाई आवश्यक नपर्ने कुराहरू हटाउनुहोस्, र तलको पुस्तकालयबाट विजेटहरू थप्नुहोस्।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Herschik met de pijlen, verwijder wat je niet nodig hebt en voeg widgets toe uit de onderstaande bibliotheek."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzaninso ndi mivi, chotsani zomwe simukufuna, ndikuwonjezera ma widget kuchokera mulaibulale yomwe ili pansipa."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਤੀਰਾਂ ਨਾਲ ਮੁੜ ਕ੍ਰਮਬੱਧ ਕਰੋ, ਜਿਸ ਚੀਜ਼ ਦੀ ਤੁਹਾਨੂੰ ਲੋੜ ਨਹੀਂ ਹੈ ਉਸਨੂੰ ਹਟਾਓ, ਅਤੇ ਹੇਠਾਂ ਦਿੱਤੀ ਲਾਇਬ੍ਰੇਰੀ ਤੋਂ ਵਿਜੇਟਸ ਸ਼ਾਮਲ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmień kolejność za pomocą strzałek, usuń to, czego nie potrzebujesz i dodaj widżety z biblioteki poniżej."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "د تیرونو سره بیا تنظیم کړئ، هغه څه لرې کړئ چې تاسو ورته اړتیا نلرئ، او د لاندې کتابتون څخه ویجټونه اضافه کړئ."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordene com as setas, remova o que não precisa e adicione widgets da biblioteca abaixo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Reordonați cu săgețile, eliminați ceea ce nu aveți nevoie și adăugați widget-uri din biblioteca de mai jos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Измените порядок с помощью стрелок, удалите то, что вам не нужно, и добавьте виджеты из библиотеки ниже."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "تير سان ٻيهر ترتيب ڏيو، جيڪي توهان کي گهربل نه آهن انهن کي هٽايو، ۽ هيٺ ڏنل لائبريري مان ويجٽ شامل ڪريو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ඊතල සමඟ නැවත අනුපිළිවෙළට සකසන්න, ඔබට අවශ්‍ය නොවන දේ ඉවත් කරන්න, සහ පහත පුස්තකාලයෙන් විජට් එක් කරන්න."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zmeňte poradie pomocou šípok, odstráňte to, čo nepotrebujete, a pridajte miniaplikácie z knižnice nižšie."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Preuredite s puščicami, odstranite tisto, kar ne potrebujete, in dodajte pripomočke iz spodnje knjižnice."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Toe fa'atonu ma aū, aveese mea e te le mana'omia, ma fa'aopoopo widget mai le faletusi i lalo."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Rongazve nemiseve, bvisa zvausingade, uye wedzera majeti kubva muraibhurari pazasi."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Ku celi fallaadhaha, ka saar waxaadan u baahnayn, oo ku dar widgets maktabadda hoose."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Renditni përsëri me shigjeta, hiqni atë që nuk ju nevojitet dhe shtoni miniaplikacione nga biblioteka më poshtë."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reorder with the arrows, remove what you do not need, and add widgets from the library below."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlophisa hape ka metsu, tlosa seo u sa se hlokeng, 'me u kenye li-widget ho tsoa laebraring e ka tlase."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Susun deui nganggo panah, cabut naon anu anjeun henteu peryogikeun, sareng tambahkeun widget ti perpustakaan di handap."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordna om med pilarna, ta bort det du inte behöver och lägg till widgets från biblioteket nedan."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Panga upya kwa mishale, ondoa usichohitaji, na uongeze wijeti kutoka kwenye maktaba hapa chini."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "அம்புக்குறிகளைக் கொண்டு மறுவரிசைப்படுத்தவும், உங்களுக்குத் தேவையில்லாதவற்றை அகற்றி, கீழே உள்ள நூலகத்திலிருந்து விட்ஜெட்களைச் சேர்க்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "బాణాలతో క్రమాన్ని మార్చండి, మీకు అవసరం లేని వాటిని తీసివేయండి మరియు దిగువ లైబ్రరీ నుండి విడ్జెట్‌లను జోడించండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Бо тирчаҳо аз нав фармоиш диҳед, он чизеро, ки ба шумо лозим нест, хориҷ кунед ва виджетҳоро аз китобхонаи зер илова кунед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เรียงลำดับใหม่ด้วยลูกศร ลบสิ่งที่คุณไม่ต้องการ และเพิ่มวิดเจ็ตจากไลบรารีด้านล่าง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oklarla yeniden sıralayın, ihtiyacınız olmayanları kaldırın ve aşağıdaki kitaplıktan widget'lar ekleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Змініть порядок за допомогою стрілок, видаліть те, що вам не потрібно, і додайте віджети з бібліотеки нижче."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تیروں کے ساتھ دوبارہ ترتیب دیں، جس چیز کی آپ کو ضرورت نہیں ہے اسے ہٹا دیں، اور ذیل کی لائبریری سے ویجٹ شامل کریں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "O'qlar bilan tartibni o'zgartiring, keraksiz narsalarni olib tashlang va quyidagi kutubxonadan vidjetlarni qo'shing."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sắp xếp lại bằng các mũi tên, xóa những gì bạn không cần và thêm các tiện ích từ thư viện bên dưới."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Lungisa kwakhona ngeentolo, susa into ongayifuniyo, kwaye wongeze iwijethi kwithala leencwadi elingezantsi."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "ריאָרדער מיט די אַראָוז, אַראָפּנעמען וואָס איר טאָן ניט דאַרפֿן און לייגן ווידזשיץ פון דער ביבליאָטעק אונטן."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ṣe atunṣe pẹlu awọn ọfa, yọ ohun ti o ko nilo, ki o si fi awọn ẹrọ ailorukọ kun lati ile-ikawe ni isalẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用箭头重新排序，删除不需要的内容，然后从下面的库中添加小部件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用箭頭重新排序，刪除不需要的內容，然後從下面的庫中新增小工具。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hlela kabusha ngemicibisholo, susa lokho ongakudingi, bese wengeza amawijethi kusuka kulabhulali engezansi."
          }
        }
      }
    },
