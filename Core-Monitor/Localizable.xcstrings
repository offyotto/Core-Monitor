    "Power users can still inspect or copy the generated preset JSON. Editing happens through the safer form above.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Kraggebruikers kan steeds die gegenereerde voorafinstelling JSON inspekteer of kopieer. Redigering vind plaas deur die veiliger vorm hierbo."
          }
        },
        "am": {
          "stringUnit": {
