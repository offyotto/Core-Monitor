    },
    "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdie Mac het geen beheerbare waaiers blootgestel nie, so monitering sal werk, maar waaierbeheer sal onbeskikbaar bly."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ይህ ማክ ምንም አይነት ቁጥጥር ሊደረግባቸው የሚችሉ ደጋፊዎችን አላጋለጠም፣ ስለዚህ ክትትል ይሰራል ነገር ግን የደጋፊዎች ቁጥጥር እንደማይገኝ ይቆያል።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يكشف جهاز Mac هذا عن أي مراوح يمكن التحكم فيها، لذا ستعمل المراقبة ولكن التحكم في المروحة سيظل غير متاح."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac heç bir idarə oluna bilən fanatları ifşa etmədi, ona görə də monitorinq işləyəcək, lakin fan nəzarəti əlçatan olmayacaq."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Гэты Mac не выстаўляў вентылятараў, якія можна кантраляваць, таму маніторынг будзе працаваць, але кіраванне вентылятарамі застанецца недаступным."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Този Mac не е изложил контролируеми вентилатори, така че наблюдението ще работи, но управлението на вентилатора ще остане недостъпно."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ম্যাক কোনো নিয়ন্ত্রণযোগ্য অনুরাগী প্রকাশ করেনি, তাই পর্যবেক্ষণ কাজ করবে কিন্তু ফ্যান নিয়ন্ত্রণ অনুপলব্ধ থাকবে।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovaj Mac nije izložio ventilatore koji se mogu kontrolirati, tako da će nadzor raditi, ali kontrola ventilatora će ostati nedostupna."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aquest Mac no va exposar cap ventilador controlable, de manera que la monitorització funcionarà, però el control del ventilador no estarà disponible."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kini nga Mac wala nagbutyag sa bisan unsa nga kontroladong mga fans, mao nga ang pagmonitor molihok apan ang kontrol sa fan magpabilin nga dili magamit."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Stu Mac ùn hà micca espunutu fanni cuntrullabili, cusì u monitoraghju funziona, ma u cuntrollu di i fan ùn resta micca dispunibule."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento Mac nevystavil žádné ovladatelné ventilátory, takže monitorování bude fungovat, ale ovládání ventilátoru zůstane nedostupné."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni ddatgelodd y Mac hwn unrhyw gefnogwyr y gellir eu rheoli, felly bydd monitro'n gweithio ond ni fydd rheolaeth ffan ar gael o hyd."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne Mac afslørede ikke nogen kontrollerbare blæsere, så overvågning vil fungere, men blæserstyring forbliver utilgængelig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Mac verfügt über keine steuerbaren Lüfter, sodass die Überwachung zwar funktioniert, die Lüftersteuerung jedoch weiterhin nicht verfügbar ist."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό το Mac δεν εξέθεσε κανέναν ελεγχόμενο ανεμιστήρα, επομένως η παρακολούθηση θα λειτουργήσει, αλλά ο έλεγχος του ανεμιστήρα θα παραμείνει μη διαθέσιμος."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ĉi tiu Mac ne elmontris iujn ajn kontroleblajn ventolilojn, do monitorado funkcios sed ventumilo kontrolo restos neatingebla."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta Mac no expuso ningún ventilador controlable, por lo que la supervisión funcionará pero el control de los ventiladores no estará disponible."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "See Mac ei paljastanud ühtegi juhitavat ventilaatorit, nii et jälgimine töötab, kuid ventilaatori juhtimine jääb kättesaamatuks."
          }
        },
        "eu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac honek ez zuen zale kontrolagarririk agerian utzi, beraz, monitorizazioak funtzionatuko du baina haizagailuen kontrola ez da erabilgarri egongo."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "این مک هیچ فن قابل کنترلی را نشان نداد، بنابراین نظارت کار خواهد کرد اما کنترل فن در دسترس نخواهد بود."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä Mac ei paljastanut ohjattavia tuulettimia, joten valvonta toimii, mutta tuulettimen ohjaus ei ole käytettävissä."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ang Mac na ito ay hindi naglantad ng anumang nakokontrol na mga tagahanga, kaya ang pagsubaybay ay gagana ngunit ang kontrol ng tagahanga ay mananatiling hindi magagamit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce Mac n'a exposé aucun ventilateur contrôlable, donc la surveillance fonctionnera mais le contrôle des ventilateurs restera indisponible."
          }
        },
        "fy": {
          "stringUnit": {
            "state": "translated",
            "value": "Dizze Mac hat gjin kontrolearbere fans bleatsteld, dus kontrôle sil wurkje, mar fankontrôle sil net beskikber bliuwe."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Níor nocht an Mac seo aon lucht leanúna inrialaithe, mar sin oibreoidh an mhonatóireacht ach ní bheidh rialú lucht leanúna ar fáil."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Cha do nochd am Mac seo luchd-leantainn a ghabhas smachdachadh, agus mar sin obraichidh sgrùdadh ach cha bhith smachd luchd-leantainn ri fhaighinn."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Este Mac non expuxo ningún ventilador controlable, polo que a vixilancia funcionará, pero o control do ventilador non estará dispoñible."
          }
        },
        "gn": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "આ Mac એ કોઈપણ નિયંત્રણક્ષમ ચાહકોને ખુલ્લા પાડ્યા નથી, તેથી મોનિટરિંગ કાર્ય કરશે પરંતુ ચાહક નિયંત્રણ અનુપલબ્ધ રહેશે."
          }
        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Wannan Mac bai fallasa duk wani magoya baya da za a iya sarrafawa ba, don haka saka idanu zai yi aiki amma sarrafa fan ba zai kasance ba."
          }
        },
        "haw": {
          "stringUnit": {
            "state": "translated",
            "value": "ʻAʻole i hōʻike kēia Mac i nā mea pā i hiki ke hoʻopaʻa ʻia, no laila e hana ka nānā ʻana akā ʻaʻole i loaʻa ka mana o ka peʻahi."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ה-Mac הזה לא חשף מאווררים הניתנים לשליטה, אז הניטור יעבוד אבל בקרת המאווררים תישאר לא זמינה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस मैक ने किसी भी नियंत्रण योग्य पंखे को उजागर नहीं किया, इसलिए निगरानी काम करेगी लेकिन पंखे का नियंत्रण अनुपलब्ध रहेगा।"
          }
        },
        "hmn": {
          "stringUnit": {
            "state": "translated",
            "value": "Lub Mac no tsis tau nthuav tawm cov kiv cua uas tswj tau, yog li kev saib xyuas yuav ua haujlwm tab sis kiv cua tswj yuav tsis muaj."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovaj Mac nije izložio nijedan ventilator koji se može kontrolirati, tako da će nadzor raditi, ali kontrola ventilatora neće biti dostupna."
          }
        },
        "ht": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac sa a pa t ekspoze okenn fanatik kontwole, kidonk siveyans ap travay men kontwòl fanatik ap rete disponib."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a Mac nem tett ki vezérelhető ventilátorokat, így a felügyelet működik, de a ventilátorvezérlés nem elérhető."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Այս Mac-ը չի բացահայտել կառավարելի երկրպագուներ, ուստի մոնիտորինգը կաշխատի, բայց օդափոխիչի կառավարումը կմնա անհասանելի:"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac ini tidak mengekspos kipas yang dapat dikontrol, sehingga pemantauan akan berfungsi namun kontrol kipas akan tetap tidak tersedia."
          }
        },
        "ig": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac a ekpughere ndị fan ọ bụla nwere ike ịchịkwa, yabụ nleba anya ga-arụ ọrụ mana njikwa fan agaghị adị."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Þessi Mac afhjúpaði engar stjórnanlegar viftur, svo eftirlit mun virka en viftustýring verður áfram ótiltæk."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo Mac non ha esposto alcuna ventola controllabile, quindi il monitoraggio funzionerà ma il controllo della ventola rimarrà non disponibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac は制御可能なファンを公開していないため、監視は機能しますが、ファン制御は利用できないままになります。"
          }
        },
        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac iki ora mbabarake penggemar sing bisa dikontrol, mula ngawasi bakal bisa digunakake nanging kontrol penggemar tetep ora kasedhiya."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "ამ Mac-მა არ გამოავლინა კონტროლირებადი გულშემატკივარი, ამიტომ მონიტორინგი იმუშავებს, მაგრამ ვენტილატორის კონტროლი მიუწვდომელი დარჩება."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Бұл Mac басқарылатын желдеткіштерді көрсетпеді, сондықтан бақылау жұмыс істейді, бірақ желдеткішті басқару қолжетімсіз болып қалады."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac នេះ​មិន​បាន​បង្ហាញ​កង្ហារ​ដែល​អាច​គ្រប់គ្រង​បាន​ទេ ដូច្នេះ​ការ​ត្រួត​ពិនិត្យ​នឹង​ដំណើរការ ប៉ុន្តែ​ការ​គ្រប់​គ្រង​កង្ហារ​នឹង​នៅ​តែ​មិន​អាច​ប្រើ​បាន។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಈ ಮ್ಯಾಕ್ ಯಾವುದೇ ನಿಯಂತ್ರಿಸಬಹುದಾದ ಅಭಿಮಾನಿಗಳನ್ನು ಬಹಿರಂಗಪಡಿಸಲಿಲ್ಲ, ಆದ್ದರಿಂದ ಮಾನಿಟರಿಂಗ್ ಕೆಲಸ ಮಾಡುತ್ತದೆ ಆದರೆ ಫ್ಯಾನ್ ನಿಯಂತ್ರಣವು ಲಭ್ಯವಿರುವುದಿಲ್ಲ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac은 제어 가능한 팬을 노출하지 않았으므로 모니터링은 작동하지만 팬 제어는 계속 사용할 수 없습니다."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Vê Mac-ê tu temaşevanên kontrolkirî dernexistiye holê, ji ber vê yekê çavdêrî dê bixebite lê kontrola fan dê ne berdest bimîne."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "Бул Mac башкарылуучу күйөрмандарды ачкан жок, андыктан мониторинг иштейт, бирок желдеткич башкаруу жеткиликсиз бойдон калат."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Haec Mac non aliquas ventilationes moderatiores patefecit, ita vigilantia operabitur sed imperium ventilabrum pervulgatum non erit."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dëse Mac huet keng kontrolléierbar Fans ausgesat, sou datt d'Iwwerwaachung funktionnéiert awer d'Fankontroll bleift net verfügbar."
          }
        },
        "lo": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac ນີ້ບໍ່ໄດ້ເປີດເຜີຍພັດລົມທີ່ສາມາດຄວບຄຸມໄດ້, ດັ່ງນັ້ນການຕິດຕາມຈະເຮັດວຽກແຕ່ການຄວບຄຸມພັດລົມຈະບໍ່ສາມາດໃຊ້ໄດ້."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Šiame „Mac“ nebuvo jokių valdomų ventiliatorių, todėl stebėjimas veiks, bet ventiliatoriaus valdymas liks nepasiekiamas."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Šis Mac neatklāja nevienu vadāmu ventilatoru, tāpēc uzraudzība darbosies, bet ventilatora vadība paliks nepieejama."
          }
        },
        "mg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ity Mac ity dia tsy nampiseho mpankafy azo fehezina, noho izany dia hiasa ny fanaraha-maso fa ny fanaraha-maso ny mpankafy dia hijanona tsy ho azo."
          }
        },
        "mi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaore tenei Mac i whakaatu i nga kaiwhaiwhai ka taea te whakahaere, no reira ka mahi te aro turuki engari ka noho kore te mana o te kaiwhaiwhai."
          }
        },
        "mk": {
          "stringUnit": {
            "state": "translated",
            "value": "Овој Mac не изложи никакви вентилатори што може да се контролираат, така што следењето ќе работи, но контролата на вентилаторот ќе остане недостапна."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "നിയന്ത്രിക്കാവുന്ന ഫാനുകളൊന്നും ഈ മാക് വെളിപ്പെടുത്തിയിട്ടില്ല, അതിനാൽ നിരീക്ഷണം പ്രവർത്തിക്കും എന്നാൽ ഫാൻ നിയന്ത്രണം ലഭ്യമല്ലാതാകും."
          }
        },
        "mn": {
          "stringUnit": {
            "state": "translated",
            "value": "Энэ Mac нь ямар ч хяналттай фэнүүдийг илрүүлээгүй тул хяналт ажиллах боловч сэнсний хяналт боломжгүй хэвээр байх болно."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "या Mac ने कोणतेही नियंत्रण करण्यायोग्य चाहते उघड केले नाहीत, त्यामुळे निरीक्षण कार्य करेल परंतु पंखे नियंत्रण अनुपलब्ध राहील."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac ini tidak mendedahkan mana-mana peminat yang boleh dikawal, jadi pemantauan akan berfungsi tetapi kawalan kipas akan kekal tidak tersedia."
          }
        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dan il-Mac ma espona l-ebda fannijiet kontrollabbli, għalhekk il-monitoraġġ se jaħdem iżda l-kontroll tal-fann se jibqa’ mhux disponibbli."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ဤ Mac သည် ထိန်းချုပ်နိုင်သော ပန်ကာများကို မပြသထားသောကြောင့် စောင့်ကြည့်ခြင်း အလုပ်ဖြစ်မည်ဖြစ်သော်လည်း ပန်ကာထိန်းချုပ်မှု မရရှိနိုင်ပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne Mac-en har ikke eksponert noen kontrollerbare vifter, så overvåking vil fungere, men viftekontroll vil forbli utilgjengelig."
          }
        },
        "ne": {
          "stringUnit": {
            "state": "translated",
            "value": "यो म्याकले कुनै पनि नियन्त्रण गर्न मिल्ने फ्यानहरूलाई पर्दाफास गरेको छैन, त्यसैले अनुगमनले काम गर्नेछ तर फ्यान नियन्त्रण अनुपलब्ध रहनेछ।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze Mac had geen regelbare ventilatoren, dus monitoring werkt wel, maar ventilatorbediening blijft niet beschikbaar."
          }
        },
        "ny": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac iyi sinawonetse mafani osinthika, kotero kuwunika kudzagwira ntchito koma kuwongolera kwa mafani sikudzakhalako."
          }
        },
        "or": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਇਸ ਮੈਕ ਨੇ ਕਿਸੇ ਵੀ ਨਿਯੰਤਰਣਯੋਗ ਪ੍ਰਸ਼ੰਸਕਾਂ ਦਾ ਪਰਦਾਫਾਸ਼ ਨਹੀਂ ਕੀਤਾ, ਇਸਲਈ ਨਿਗਰਾਨੀ ਕੰਮ ਕਰੇਗੀ ਪਰ ਪ੍ਰਸ਼ੰਸਕ ਨਿਯੰਤਰਣ ਉਪਲਬਧ ਨਹੀਂ ਰਹੇਗਾ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten komputer Mac nie udostępnia żadnych wentylatorów, którymi można sterować, więc monitorowanie będzie działać, ale sterowanie wentylatorami pozostanie niedostępne."
          }
        },
        "ps": {
          "stringUnit": {
            "state": "translated",
            "value": "دا ماک هیڅ د کنټرول وړ پرستار افشا نه کړل، نو څارنه به کار وکړي مګر د فین کنټرول به شتون ونلري."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este Mac não expôs nenhum ventilador controlável, portanto o monitoramento funcionará, mas o controle do ventilador permanecerá indisponível."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Acest Mac nu a expus niciun ventilator controlabil, așa că monitorizarea va funcționa, dar controlul ventilatorului va rămâne indisponibil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом Mac не было управляемых вентиляторов, поэтому мониторинг будет работать, но управление вентиляторами останется недоступным."
          }
        },
        "rw": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "هي ميڪ ڪنهن به ڪنٽرول لائق مداحن کي ظاهر نه ڪيو، تنهنڪري مانيٽرنگ ڪم ڪندي پر فين ڪنٽرول دستياب نه رهندو."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "මෙම මැක් පාලනය කළ හැකි පංකා කිසිවක් හෙළි නොකළ නිසා අධීක්ෂණය ක්‍රියා කරනු ඇති නමුත් විදුලි පංකා පාලනය ලබා ගත නොහැකි වනු ඇත."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento Mac nevystavil žiadne ovládateľné ventilátory, takže monitorovanie bude fungovať, ale ovládanie ventilátora zostane nedostupné."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta Mac ni izpostavil nobenega nadzorovanega ventilatorja, tako da bo nadzor deloval, vendar nadzor ventilatorja ne bo na voljo."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "E le'i fa'aalia e lenei Mac so'o se tagata e mafai ona pulea, o lea o le a aoga le mata'ituina ae o le a tumau pea le le avanoa o le fa'atonuga."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Iyi Mac haina kufumura chero mafeni anodzoreka, saka kutarisisa kuchashanda asi kutonga kwe fan kunoramba kusipo."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac-kan ma soo bandhigin wax taageere ah oo la kontarooli karo, marka la socodka wuu shaqayn doonaa laakiin xakamaynta taageerayaashu waxay ahaanaysaa mid aan la heli karin."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Ky Mac nuk ekspozoi asnjë tifoz të kontrollueshëm, kështu që monitorimi do të funksionojë, por kontrolli i ventilatorit do të mbetet i padisponueshëm."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac did not expose any controllable fans, so monitoring will work but fan control will stay unavailable."
          }
        },
        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac ena ha ea ka ea pepesa libapali tse laolehang, kahoo ho beha leihlo ho tla sebetsa empa taolo ea fan e tla lula e le sieo."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac ieu henteu ngalaan kipas anu tiasa dikontrol, janten ngawaskeun tiasa dianggo tapi kontrol kipas bakal tetep teu sayogi."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna Mac exponerade inte några kontrollerbara fläktar, så övervakning kommer att fungera men fläktkontroll kommer att förbli otillgänglig."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac hii haikufichua mashabiki wowote wanaoweza kudhibitiwa, kwa hivyo ufuatiliaji utafanya kazi lakini udhibiti wa mashabiki hautapatikana."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "இந்த Mac கட்டுப்படுத்தக்கூடிய ரசிகர்களை வெளிப்படுத்தவில்லை, எனவே கண்காணிப்பு வேலை செய்யும் ஆனால் ரசிகர் கட்டுப்பாடு கிடைக்காமல் இருக்கும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ఈ Mac నియంత్రించదగిన అభిమానులను బహిర్గతం చేయలేదు, కాబట్టి పర్యవేక్షణ పని చేస్తుంది కానీ ఫ్యాన్ నియంత్రణ అందుబాటులో ఉండదు."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Ин Mac ягон мухлиси идорашавандаро фош накардааст, аз ин рӯ мониторинг кор хоҳад кард, аммо назорати мухлисон дастнорас хоҳад монд."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac เครื่องนี้ไม่ได้เปิดเผยพัดลมที่ควบคุมได้ ดังนั้นการตรวจสอบจะทำงานแต่การควบคุมพัดลมจะไม่สามารถใช้งานได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Mac kontrol edilebilir herhangi bir fanı açığa çıkarmadığından izleme çalışacak ancak fan kontrolü kullanılamayacaktır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей Mac не показував жодних керованих вентиляторів, тому моніторинг працюватиме, але керування вентилятором залишатиметься недоступним."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس میک نے کسی قابل کنٹرول پرستار کو بے نقاب نہیں کیا، لہذا نگرانی کام کرے گی لیکن پنکھے کا کنٹرول دستیاب نہیں رہے گا۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ushbu Mac boshqariladigan fanatlarni ko'rsatmadi, shuning uchun monitoring ishlaydi, lekin fan nazorati mavjud bo'lmaydi."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Máy Mac này không hiển thị bất kỳ quạt có thể điều khiển nào, vì vậy việc giám sát sẽ hoạt động nhưng tính năng điều khiển quạt sẽ không khả dụng."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Mac ayizange iveze nabaphi na abalandeli abalawulekayo, ngoko ke ukubeka iliso kuya kusebenza kodwa ulawulo lwabalandeli luya kuhlala lungafumaneki."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "דער מעק האט נישט ויסשטעלן קיין קאַנטראָולאַבאַל פאַנס, אַזוי מאָניטאָרינג וועט אַרבעטן אָבער פאָכער קאָנטראָל וועט בלייבן אַנאַוויילאַבאַל."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac yii ko ṣe afihan eyikeyi awọn onijakidijagan iṣakoso, nitorinaa ibojuwo yoo ṣiṣẹ ṣugbọn iṣakoso afẹfẹ yoo duro ko si."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这台 Mac 没有暴露任何可控制的风扇，因此监控可以工作，但风扇控制将不可用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這台 Mac 沒有暴露任何可控制的風扇，因此監控可以工作，但風扇控制將不可用。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Mac ayizange idalule abalandeli abalawulekayo, ngakho ukuqapha kuzosebenza kodwa ukulawulwa kwabalandeli kuzohlala kungatholakali."
          }
        }
      }
    },
    "This layout is too wide for a full Touch Bar. Use a narrower preset to avoid clipped widgets.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdie uitleg is te wyd vir 'n volle Touch Bar. Gebruik 'n nouer voorafinstelling om geknipte legstukke te vermy."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ይህ አቀማመጥ ለሙሉ Touch Bar በጣም ሰፊ ነው። የተቀነጠቁ መግብሮችን ለማስወገድ ጠባብ ቅድመ ዝግጅትን ይጠቀሙ።"
