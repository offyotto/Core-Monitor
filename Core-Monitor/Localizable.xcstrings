            "value": "Hulela ka har'a lebala ho tsamaisa paddle ea hau."
          }
        },
        "su": {
          "stringUnit": {
            "state": "translated",
            "value": "Séred ka jero arena pikeun mindahkeun dayeuh anjeun."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dra in i arenan för att flytta din paddel."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Buruta ndani ya uwanja ili kusogeza kasia yako."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உங்கள் துடுப்பை நகர்த்த அரங்கின் உள்ளே இழுக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "మీ తెడ్డును తరలించడానికి అరేనా లోపలికి లాగండి."
          }
        },
        "tg": {
          "stringUnit": {
            "state": "translated",
            "value": "Барои ҳаракат додани бели худ дар дохили арена кашед."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลากเข้าไปในสนามประลองเพื่อขยับไม้พายของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raketinizi hareket ettirmek için arenanın içine sürükleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетягніть всередину арени, щоб перемістити весло."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنے پیڈل کو حرکت دینے کے لیے میدان کے اندر گھسیٹیں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Eshkakni siljitish uchun arena ichiga torting."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kéo vào trong đấu trường để di chuyển mái chèo của bạn."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Tsala ngaphakathi kwebala ukuhambisa iphini lokubheqa."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "שלעפּן ין דער ארענע צו מאַך דיין רודער."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Fa inu gbagede lati gbe paddle rẹ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在竞技场内拖动以移动球拍。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在競技場內拖曳以移動球拍。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hudulela ngaphakathi kwenkundla ukuze uhambise i-paddle yakho."
          }
        }
      }
    },
