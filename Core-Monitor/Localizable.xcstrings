        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Uzu %@ por alporti Core Monitor al la fronto eĉ se macOS kaŝis la menubrejojn. La sama ŝparvojo ankaŭ aperas en la aplika menuo dum Core Monitor estas aktiva."
