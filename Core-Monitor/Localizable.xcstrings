        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "விரிவாக்கப்பட்ட வானிலைக் காட்சி நீண்ட நிலைக் கோட்டைக் காட்டுகிறது."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "విస్తరించిన వాతావరణ వీక్షణ పొడవైన కండిషన్ లైన్‌ని చూపుతోంది."
          }
        },
        "tg": {
