    "Translations are machine-generated and may not be perfect in every language or context.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertalings is masjiengegenereer en is dalk nie perfek in elke taal of konteks nie."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "ትርጉሞች በማሽን የተፈጠሩ ናቸው እና በሁሉም ቋንቋ ወይም አውድ ፍፁም ላይሆኑ ይችላሉ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم إنشاء الترجمات آليًا وقد لا تكون مثالية في كل اللغات أو السياقات."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Translations are machine-generated and may not be perfect in every language or context."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Translations are machine-generated and may not be perfect in every language or context."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Tərcümələr maşın tərəfindən yaradılır və hər dildə və ya kontekstdə mükəmməl olmaya bilər."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Пераклады ствараюцца машынай і не могуць быць ідэальнымі для кожнай мовы ці кантэксту."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Преводите са машинно генерирани и може да не са перфектни за всеки език или контекст."
          }
