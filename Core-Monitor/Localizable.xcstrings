        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پشته ویجت فعال گسترده تر از یک Touch Bar کامل است. برای جلوگیری از بریده شدن، ویجت ها را برش دهید یا مرتب کنید."
          }
