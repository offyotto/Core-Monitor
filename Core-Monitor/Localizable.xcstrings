            "value": "Chế độ cơ bản đơn giản hóa các tùy chọn giám sát và giao diện của Core Monitor."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Imowudi esisiseko yenza lula ujongano lweCore Monitor kunye nokhetho lokubeka iliso."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "באַסיק מאָדע סימפּלאַפייז די Core Monitor צובינד און מאָניטאָרינג אָפּציעס."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Ipo ipilẹ jẹ ki wiwo Core Monitor rọrun ati awọn aṣayan ibojuwo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "基本模式简化了 Core Monitor 的界面和监控选项。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "基本模式簡化了 Core Monitor 的介面和監控選項。"
          }
