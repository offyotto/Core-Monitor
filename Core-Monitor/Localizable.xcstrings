        "jv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ora ana bagean pitulung sing cocog karo \"%@\". Coba istilah kaya helper, cuaca, item login, garis menu, utawa Touch Bar."
          }
        },
        "ka": {
          "stringUnit": {
            "state": "translated",
            "value": "დახმარების სექციები არ შეესაბამება \"%@\". სცადეთ ისეთი ტერმინები, როგორიცაა დამხმარე, ამინდი, შესვლის ელემენტები, მენიუს ზოლი ან Touch Bar."
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" анықтамалық бөлімдері сәйкес келмеді. Көмекші, ауа райы, кіру элементтері, мәзір жолағы немесе Touch Bar сияқты шарттарды қолданып көріңіз."
          }
        },
        "km": {
          "stringUnit": {
            "state": "translated",
            "value": "មិនមានផ្នែកជំនួយដែលត្រូវគ្នានឹង \"%@\" ទេ។ សាកល្បងប្រើពាក្យដូចជា ជំនួយការ អាកាសធាតុ ធាតុចូល របារម៉ឺនុយ ឬ Touch Bar ។"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ಗೆ ಯಾವುದೇ ಸಹಾಯ ವಿಭಾಗಗಳು ಹೊಂದಿಕೆಯಾಗಲಿಲ್ಲ. ಸಹಾಯಕ, ಹವಾಮಾನ, ಲಾಗಿನ್ ಐಟಂಗಳು, ಮೆನು ಬಾರ್ ಅಥವಾ Touch Bar ನಂತಹ ಪದಗಳನ್ನು ಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"와 일치하는 도움말 섹션이 없습니다. 도우미, 날씨, 로그인 항목, 메뉴 표시줄 또는 Touch Bar와 같은 용어를 사용해 보세요."
          }
        },
        "ku": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu beşên alîkariyê li hev nayên \"%@\". Mercên wekî arîkar, hewa, hêmanên têketinê, barika menu, an Touch Bar biceribînin."
          }
        },
        "ky": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" дал келген жардам бөлүмдөрү жок. Жардамчы, аба ырайы, кирүү элементтери, меню тилкеси же Touch Bar сыяктуу шарттарды колдонуп көрүңүз."
          }
        },
        "la": {
          "stringUnit": {
            "state": "translated",
            "value": "Nullae sectiones iuvandae congruerunt \"%@\". Conare verba sicut adiutorium, tempestatum, login items, talea tabula, vel Touch Bar."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Keng Hëllef Rubriken mat \"%@\". Probéiert Begrëffer wéi Helper, Wieder, Loginartikelen, Menübar oder Touch Bar."
