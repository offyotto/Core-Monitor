          }
        },
        "sd": {
          "stringUnit": {
            "state": "translated",
            "value": "عمل جي بصيرت بند آهي. ياداشت جا نظارا مقامي رهندا آهن بغير ايپ جا نالا ڏيکارڻ."
          }
        },
        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "ක්‍රියාවලි ඇතුළාන්ත අක්‍රියයි. යෙදුම් නම් පෙන්වීමෙන් තොරව මතක දසුන් දේශීයව පවතී."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Procesné štatistiky sú vypnuté. Zobrazenia pamäte zostávajú lokálne bez zobrazovania názvov aplikácií."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vpogledi v proces so izklopljeni. Pogledi pomnilnika ostanejo lokalni brez prikaza imen aplikacij."
