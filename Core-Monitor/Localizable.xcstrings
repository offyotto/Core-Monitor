        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Benotzt %@ fir Core Monitor op d'Front ze bréngen, och wann macOS d'Menubar Elementer verstoppt huet. Déi selwecht Ofkiirzung schéngt och am App Menü iwwerdeems Core Monitor aktiv ass."
          }
