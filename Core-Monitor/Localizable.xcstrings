        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" နှင့် ကိုက်ညီသော အကူအညီကဏ္ဍများ မရှိပါ။ အကူအညီပေးသူ၊ ရာသီဥတု၊ အကောင့်ဝင်သည့်အရာများ၊ မီနူးဘား သို့မဟုတ် Touch Bar ကဲ့သို့သော စည်းကမ်းချက်များကို စမ်းကြည့်ပါ။"
          }
        },
        "nb": {
          "stringUnit": {
