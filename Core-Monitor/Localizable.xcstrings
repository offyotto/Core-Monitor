          "stringUnit": {
            "state": "translated",
            "value": "کم از کم ایک مینو بار آئٹم کو مرئی رکھیں، یا ڈیش بورڈ شارٹ کٹ کو فال بیک کے طور پر فعال کریں۔"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyu satrining kamida bitta bandini ko‘rinadigan holda saqlang yoki boshqaruv paneli yorlig‘ini zaxira sifatida yoqing."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ ít nhất một mục thanh menu hiển thị hoặc bật lối tắt trang tổng quan làm dự phòng."
          }
        },
        "xh": {
          "stringUnit": {
            "state": "translated",
            "value": "Gcina ubuncinane into enye yebha yemenyu ibonakala, okanye yenza i-shortboard yedeshibhodi ibe yinto yokubuyela umva."
          }
        },
        "yi": {
          "stringUnit": {
            "state": "translated",
            "value": "האַלטן בייַ מינדסטער איין מעניו באַר נומער קענטיק, אָדער געבן די דאַשבאָרד דורכוועג ווי אַ פאַלבאַק."
          }
        },
        "yo": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeki o kere ju ohun kan igi akojọ aṣayan kan han, tabi mu ọna abuja dasibodu ṣiṣẹ bi ipadasẹhin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "至少保持一个菜单栏项可见，或启用仪表板快捷方式作为后备。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "至少保持一個選單列項目可見，或啟用儀表板捷徑作為後備。"
          }
        },
        "zu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gcina okungenani into eyodwa yebha yemenyu ibonakala, noma unike amandla isinqamuleli sedeshibhodi njengendlela yokubuyela emuva."
          }
        }
      }
    },
