    "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Onlangse CPU, GPU, waaier, krag, geheue, netwerk en ruil geskiedenis sonder om die paneelbord te verlaat."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "የቅርብ ጊዜ CPU፣ GPU፣ ደጋፊ፣ ሃይል፣ ማህደረ ትውስታ፣ አውታረ መረብ እና ከዳሽቦርዱ ሳይወጡ የመቀያየር ታሪክ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أحدث CPU وGPU والمروحة والطاقة والذاكرة والشبكة وسجل المبادلة دون مغادرة لوحة القيادة."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Ən son CPU, GPU, fan, güc, yaddaş, şəbəkə və idarəetmə panelini tərk etmədən dəyişdirmə tarixçəsi."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Апошнія CPU, GPU, вентылятар, сілкаванне, памяць, сетка і гісторыя абмену, не пакідаючы прыборнай панэлі."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Скорошни CPU, GPU, вентилатор, захранване, памет, мрежа и хронология на размяната, без да напускате таблото за управление."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সাম্প্রতিক CPU, GPU, ফ্যান, পাওয়ার, মেমরি, নেটওয়ার্ক, এবং ড্যাশবোর্ড ছাড়াই অদলবদল ইতিহাস৷"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedavna CPU, GPU, ventilator, napajanje, memorija, mreža i istorija zamjene bez napuštanja kontrolne ploče."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Historial recent de CPU, GPU, ventilador, potència, memòria, xarxa i intercanvi sense sortir del tauler."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bag-o nga CPU, GPU, fan, gahum, memorya, network, ug kasaysayan sa swap nga dili mobiya sa dashboard."
          }
        },
        "co": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, putenza, memoria, reta, è scambià storia senza lascià u dashboard."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedávná historie CPU, GPU, ventilátor, napájení, paměť, síť a swap, aniž byste opustili palubní desku."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU diweddar, GPU, ffan, pŵer, cof, rhwydwaith, a hanes cyfnewid heb adael y dangosfwrdd."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Seneste CPU, GPU, blæser, strøm, hukommelse, netværk og swap-historik uden at forlade dashboardet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktueller CPU-, GPU-, Lüfter-, Strom-, Speicher-, Netzwerk- und Swap-Verlauf, ohne das Dashboard zu verlassen."
          }
        },
        "dv": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πρόσφατο ιστορικό CPU, GPU, ανεμιστήρας, τροφοδοσία, μνήμη, δίκτυο και ανταλλαγή χωρίς έξοδο από το ταμπλό."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent CPU, GPU, fan, power, memory, network, and swap history without leaving the dashboard."
          }
        },
        "eo": {
