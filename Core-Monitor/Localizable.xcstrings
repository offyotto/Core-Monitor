        "si": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" කිසිදු උපකාරක කොටස් නොගැලපේ. සහායක, කාලගුණය, පිවිසුම් අයිතම, මෙනු තීරුව, හෝ Touch Bar වැනි නියමයන් උත්සාහ කරන්න."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Žiadne sekcie pomocníka nezodpovedajú \"%@\". Vyskúšajte výrazy ako pomocník, počasie, prihlasovacie položky, panel s ponukami alebo Touch Bar."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Noben razdelek pomoči se ne ujema z \"%@\". Preizkusite izraze, kot so pomočnik, vreme, elementi za prijavo, menijska vrstica ali Touch Bar."
          }
        },
        "sm": {
          "stringUnit": {
            "state": "translated",
            "value": "Leai se vaega fesoasoani e fetaui ma le \"%@\". Fa'ata'ita'i upu e pei o le fesoasoani, tau, mea e saini ai, pa o lisi, po'o le Touch Bar."
          }
        },
        "sn": {
          "stringUnit": {
            "state": "translated",
            "value": "Hapana zvikamu zvekubatsira zvinoenderana ne \"%@\". Edza mazwi akadai semubatsiri, mamiriro ekunze, zvinhu zvekupinda, menyu bar, kana Touch Bar."
          }
        },
        "so": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma jiraan qaybo caawimo oo u dhigma \"%@\". Isku day ereyada sida caawiye, cimilada, shayada soo gelida, bar menu, ama Touch Bar."
