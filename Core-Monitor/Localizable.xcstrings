        "st": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha ho likarolo tsa thuso tse tsamaellanang le \"%@\". Leka mantsoe a kang mothusi, boemo ba leholimo, lintho tsa ho kena, menu bar, kapa Touch Bar."
