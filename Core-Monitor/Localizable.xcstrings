    "Swipe sideways to move between guide cards.": {
      "localizations": {
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Swiep sywaarts om tussen gidskaarte te beweeg."
          }
        },
        "am": {
          "stringUnit": {
            "state": "translated",
            "value": "በመመሪያ ካርዶች መካከል ለመንቀሳቀስ ወደ ጎን ያንሸራትቱ።"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب جانبيًا للتنقل بين بطاقات الدليل."
          }
        },
        "as": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe sideways to move between guide cards."
          }
        },
        "ay": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe sideways to move between guide cards."
          }
        },
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Bələdçi kartları arasında hərəkət etmək üçün yana sürüşdürün."
          }
        },
        "be": {
          "stringUnit": {
            "state": "translated",
            "value": "Правядзіце пальцам убок, каб перамяшчацца паміж карткамі-даведнікамі."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Плъзнете настрани, за да се придвижвате между картите с водач."
          }
        },
        "bm": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe sideways to move between guide cards."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "গাইড কার্ডের মধ্যে সরানোর জন্য পাশের দিকে সোয়াইপ করুন।"
          }
        },
        "bo": {
          "stringUnit": {
            "state": "translated",
            "value": "Swipe sideways to move between guide cards."
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevucite prstom u stranu da se krećete između kartica vodiča."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Fes lliscar cap als costats per moure't entre les targetes de guia."
          }
        },
        "ceb": {
          "stringUnit": {
            "state": "translated",
            "value": "Pag-swipe sa kilid aron molihok tali sa mga guide card."
          }
        },
        "co": {
