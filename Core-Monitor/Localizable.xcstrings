        },
        "ha": {
          "stringUnit": {
            "state": "translated",
            "value": "Yi amfani da %@ don kawo Core Monitor zuwa gaba ko da macOS ya ɓoye abubuwan mashaya menu. Hakanan gajeriyar hanya iri ɗaya tana bayyana a cikin menu na app yayin da Core Monitor ke aiki."
