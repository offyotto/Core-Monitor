        },
        "mt": {
          "stringUnit": {
            "state": "translated",
            "value": "L-ebda sezzjoni ta' għajnuna ma kienet imqabbla ma' \"%@\". Ipprova termini bħal helper, temp, oġġetti tal-login, menu bar, jew Touch Bar."
