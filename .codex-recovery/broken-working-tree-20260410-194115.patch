+    private func isAuthorizedClient(_ connection: NSXPCConnection) -> Bool {
+        let pid = connection.processIdentifier
+        guard pid > 0 else { return false }
+
+        let requirement: SecRequirement
+        if let cached = clientRequirement {
+            requirement = cached
+        } else {
+            var createdRequirement: SecRequirement?
+            let status = SecRequirementCreateWithString(
+                authorizedClientRequirement as CFString,
+                [],
+                &createdRequirement
+            )
+            guard status == errSecSuccess, let createdRequirement else {
+                return false
+            }
+            clientRequirement = createdRequirement
+            requirement = createdRequirement
+        }
+
+        let attributes = [kSecGuestAttributePid as String: pid] as CFDictionary
+        var guestCode: SecCode?
+        guard SecCodeCopyGuestWithAttributes(nil, attributes, [], &guestCode) == errSecSuccess,
+              let guestCode else {
+            return false
+        }
+
+        return SecCodeCheckValidity(guestCode, [], requirement) == errSecSuccess
+    }
 }
 
