-    private static func legacySnapshot(timeout: TimeInterval) -> SystemNowPlayingSnapshot? {
-        guard let nowPlayingInfoFn else { return nil }
-
-        var isPlaying = true
-        if let isPlayingFn {
-            let playingSemaphore = DispatchSemaphore(value: 0)
